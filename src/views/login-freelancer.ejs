<!DOCTYPE html>
<html lang="<%= (typeof lang !== 'undefined' && lang) ? String(lang) : 'en' %>">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= (typeof t === 'function') ? t('auth.freelancer_signin_page_title', 'Vamper - Sign In (Freelancer / Student)') : 'Vamper - Sign In (Freelancer / Student)' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="style.css">
</head>

<body>
    <%- include('../public/header') %>

    <main>
        <section class="py-5">
            <div class="container">
                <div class="row justify-content-center">
                    <div class="col-12 col-md-10 col-lg-6">
                        <div class="card border-0 shadow-sm rounded-4">
                            <div class="card-body p-4 p-md-5">
                                <div class="d-flex align-items-center justify-content-between mb-4">
                                    <div>
                                        <h3 class="fw-bold mb-1"><%= (typeof t === 'function') ? t('auth.sign_in', 'Sign in') : 'Sign in' %></h3>
                                        <div class="text-muted"><%= (typeof t === 'function') ? t('auth.freelancer_student', 'Freelancer / Student') : 'Freelancer / Student' %></div>
                                    </div>
                                    <div class="bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center"
                                        style="width: 44px; height: 44px;">
                                        <i class="bi bi-person-workspace fs-4"></i>
                                    </div>
                                </div>

                                <% const pageQuery = (typeof query !== 'undefined' && query) ? query : {}; %>
                                <% const rawError = (pageQuery && pageQuery.error) ? String(pageQuery.error) : ''; %>
                                <% const errorMessage = rawError === 'invalid_email_format'
                                    ? ((typeof t === 'function') ? t('auth.errors.invalid_email_format', 'Invalid email format.') : 'Invalid email format.')
                                    : (rawError === 'password_required'
                                        ? ((typeof t === 'function') ? t('auth.errors.password_required', 'Password is required.') : 'Password is required.')
                                        : (rawError === 'email_not_found'
                                            ? ((typeof t === 'function') ? t('auth.errors.email_not_found', 'Email does not exist.') : 'Email does not exist.')
                                            : (rawError === 'wrong_password'
                                                ? ((typeof t === 'function') ? t('auth.errors.wrong_password', 'Incorrect password.') : 'Incorrect password.')
                                                : (rawError === 'account_blocked'
                                                    ? 'Your account has been blocked for violating our platform policies. Please contact customer support immediately or send information through the contact page.'
                                                    : (rawError === 'invalid_role'
                                                        ? ((typeof t === 'function') ? t('auth.errors.invalid_role', 'This account does not belong to this role.') : 'This account does not belong to this role.')
                                                        : rawError)))));
                                %>
                                <% if (pageQuery && pageQuery.registered) { %>
                                    <div class="alert alert-success" role="alert">
                                        <%= (typeof t === 'function') ? t('auth.register_success_signin', 'Registration successful. Please sign in.') : 'Registration successful. Please sign in.' %>
                                    </div>
                                <% } %>
                                <% if (errorMessage) { %>
                                    <div class="alert alert-danger" role="alert">
                                        <%= errorMessage %>
                                    </div>
                                <% } %>

                                <form method="post" action="/login">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <input type="hidden" name="role" value="freelancer">

                                    <div class="mb-3">
                                        <label class="form-label fw-semibold"><%= (typeof t === 'function') ? t('auth.email', 'Email') : 'Email' %></label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-white"><i
                                                    class="bi bi-envelope"></i></span>
                                            <input type="email" class="form-control" name="email"
                                                placeholder="<%= (typeof t === 'function') ? t('auth.email_placeholder', 'you@example.com') : 'you@example.com' %>" required>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-semibold"><%= (typeof t === 'function') ? t('auth.password', 'Password') : 'Password' %></label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-white"><i
                                                    class="bi bi-lock"></i></span>
                                            <input type="password" class="form-control" name="password"
                                                placeholder="<%= (typeof t === 'function') ? t('auth.password_placeholder', '••••••••') : '••••••••' %>" required>
                                        </div>
                                    </div>

                                    <div class="d-flex align-items-center justify-content-between mb-4">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" value="1"
                                                id="rememberFreelancer" name="remember">
                                            <label class="form-check-label" for="rememberFreelancer"><%= (typeof t === 'function') ? t('auth.remember_me', 'Remember me') : 'Remember me' %></label>
                                        </div>
                                        <a href="/forgot-password" class="text-decoration-none"><%= (typeof t === 'function') ? t('auth.forgot_password', 'Forgot password?') : 'Forgot password?' %></a>
                                    </div>

                                    <button type="submit" class="btn btn-primary w-100 fw-semibold py-2"><%= (typeof t === 'function') ? t('auth.sign_in', 'Sign in') : 'Sign in' %></button>

                                    <!-- Social login - temporarily hidden
                                    <div class="text-center text-muted my-3">or</div>
                                    <div class="d-grid gap-2">
                                        <button type="button" class="btn btn-outline-secondary fw-semibold">
                                            <i class="bi bi-google me-2"></i>Continue with Google
                                        </button>
                                        <button type="button" class="btn btn-outline-secondary fw-semibold">
                                            <i class="bi bi-github me-2"></i>Continue with GitHub
                                        </button>
                                    </div>
                                    -->

                                    <div class="text-center mt-4">
                                        <span class="text-muted"><%= (typeof t === 'function') ? t('auth.are_you_employer', 'Are you an Employer?') : 'Are you an Employer?' %></span>
                                        <a class="text-decoration-none fw-semibold" href="/login?role=employer"><%= (typeof t === 'function') ? t('auth.signin_as_employer', 'Sign in as Employer') : 'Sign in as Employer' %></a>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

        <%- include('../public/footer') %>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
                integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
                crossorigin="anonymous"></script>
</body>

</html>