<!DOCTYPE html>
<html lang="<%= (typeof lang !== 'undefined' && lang) ? String(lang) : 'en' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= (typeof t === 'function') ? t('auth.forgot_password_title', 'Forgot Password - Vamper') : 'Forgot Password - Vamper' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('../public/header') %>
    <main>
        <section class="py-5">
            <div class="container">
                <div class="row justify-content-center">
                    <div class="col-12 col-md-8 col-lg-5">
                        <div class="card border-0 shadow-sm rounded-4">
                            <div class="card-body p-4 p-md-5">
                                <h3 class="fw-bold mb-3"><%= (typeof t === 'function') ? t('auth.forgot_password', 'Forgot password?') : 'Forgot password?' %></h3>
                                <p class="text-muted mb-4"><%= (typeof t === 'function') ? t('auth.forgot_password_desc', 'Enter your email address and we will send you a link to reset your password.') : 'Enter your email address and we will send you a link to reset your password.' %></p>

                                <% 
                                   const errorMsg = (typeof error_msg !== 'undefined' && error_msg && error_msg.length > 0) ? error_msg : '';
                                   const successMsg = (typeof success_msg !== 'undefined' && success_msg && success_msg.length > 0) ? success_msg : '';
                                %>

                                <% if (errorMsg && errorMsg.length > 0) { %>
                                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                        <%= errorMsg %>
                                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                    </div>
                                <% } %>
                                <% if (successMsg && successMsg.length > 0) { %>
                                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                                        <i class="bi bi-check-circle-fill me-2"></i>
                                        <%= successMsg %>
                                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                    </div>
                                <% } %>

                                <form action="/forgot-password" method="POST">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold"><%= (typeof t === 'function') ? t('auth.email', 'Email') : 'Email' %></label>
                                        <input type="email" name="email" id="forgotEmail" class="form-control" placeholder="you@example.com" value="<%= typeof submitted_email !== 'undefined' ? submitted_email : '' %>" required>
                                        <div class="invalid-feedback">Please enter a valid email address.</div>
                                    </div>
                                    <button type="submit" class="btn btn-primary w-100 fw-semibold py-2"><%= (typeof t === 'function') ? t('auth.send_reset_link', 'Send Reset Link') : 'Send Reset Link' %></button>
                                </form>
                                <div class="text-center mt-4">
                                    <a href="/login" class="text-decoration-none fw-semibold"><i class="bi bi-arrow-left me-1"></i><%= (typeof t === 'function') ? t('auth.back_to_login', 'Back to Login') : 'Back to Login' %></a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
    <%- include('../public/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
