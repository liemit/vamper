<!DOCTYPE html>
<html lang="<%= (typeof lang !== 'undefined' && lang) ? String(lang) : 'en' %>">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vamper - Freelancer Profile</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <%- include('../../public/header') %>

        <main class="container-fluid py-3 py-md-4">
            <div class="row">
                <%- include('./layouts/menu') %>

                    <section class="col-md-9 ms-sm-auto col-lg-10 px-2 px-md-4 freelancer-profile">
                        <% if (success_msg && success_msg.length> 0) { %>
                            <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
                                <i class="bi bi-check-circle-fill me-2"></i>
                                <%= success_msg %>
                                    <button type="button" class="btn-close" data-bs-dismiss="alert"
                                        aria-label="Close"></button>
                            </div>
                            <% } %>

                                <% if (error_msg && error_msg.length> 0) { %>
                                    <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                        <%= error_msg %>
                                            <button type="button" class="btn-close" data-bs-dismiss="alert"
                                                aria-label="Close"></button>
                                    </div>
                                    <% } %>

                                        <div
                                            class="d-flex flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                                            <h1 class="h2">Freelancer Profile</h1>
                                        </div>

                                        <% const p=(typeof profile !=='undefined' && profile) ? profile : {}; %>

                                            <form id="mainProfileForm" method="POST"
                                                action="/freelancer/profile?_csrf=<%= csrfToken %>"
                                                enctype="multipart/form-data" class="card border-0 shadow-sm rounded-4">
                                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                <input type="hidden" name="existing_avatar_url"
                                                    value="<%= p.avatar_url ? p.avatar_url : '' %>">
                                                <input type="hidden" name="existing_cv_url"
                                                    value="<%= p.cv_url ? p.cv_url : '' %>">

                                                <div class="card-body p-4">
                                                    <div
                                                        class="d-flex flex-column flex-lg-row align-items-start gap-3 mb-4">
                                                        <div class="d-flex align-items-center gap-3">
                                                            <div class="user-avatar d-inline-flex align-items-center justify-content-center"
                                                                style="width: 34px; height: 34px; min-width: 34px; min-height: 34px; max-width: 34px; max-height: 34px; flex: 0 0 34px; overflow: hidden;"
                                                                id="avatar-preview-container">
                                                                <% if (p.avatar_url) { %>
                                                                    <img src="<%= p.avatar_url %>" alt="Avatar"
                                                                        style="width: 100%; height: 100%; object-fit: cover; display: block;"
                                                                        onerror="this.style.display='none'">
                                                                    <% } else { %>
                                                                        <i class="bi bi-person-circle"></i>
                                                                        <% } %>
                                                            </div>

                                                            <div>
                                                                <div class="fw-bold">
                                                                    <%= p.full_name ? p.full_name : (user &&
                                                                        user.full_name ? user.full_name : 'Your profile'
                                                                        ) %>
                                                                </div>
                                                                <div class="text-muted small">
                                                                    <%= p.title ? p.title
                                                                        : 'Complete your profile so employers can evaluate you faster.'
                                                                        %>
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <div class="flex-grow-1">
                                                            <label class="form-label">Profile photo (Optional)</label>
                                                            <input class="form-control" type="file" id="avatar"
                                                                name="avatar" accept="image/*">
                                                            <div class="form-text">Recommended size: 400x400px. Max
                                                                size: 2MB.</div>
                                                        </div>
                                                    </div>

                                                    <ul class="nav nav-pills gap-2 mb-4" id="freelancerProfileTabs"
                                                        role="tablist">
                                                        <li class="nav-item" role="presentation">
                                                            <button class="nav-link active" id="tab-basic"
                                                                data-bs-toggle="pill" data-bs-target="#pane-basic"
                                                                type="button" role="tab" aria-controls="pane-basic"
                                                                aria-selected="true">
                                                                <i class="bi bi-card-text me-1"></i>Basic
                                                            </button>
                                                        </li>
                                                        <li class="nav-item" role="presentation">
                                                            <button class="nav-link" id="tab-about"
                                                                data-bs-toggle="pill" data-bs-target="#pane-about"
                                                                type="button" role="tab" aria-controls="pane-about"
                                                                aria-selected="false">
                                                                <i class="bi bi-stars me-1"></i>About & Skills
                                                            </button>
                                                        </li>
                                                        <li class="nav-item" role="presentation">
                                                            <button class="nav-link" id="tab-links"
                                                                data-bs-toggle="pill" data-bs-target="#pane-links"
                                                                type="button" role="tab" aria-controls="pane-links"
                                                                aria-selected="false">
                                                                <i class="bi bi-link-45deg me-1"></i>Links
                                                            </button>
                                                        </li>
                                                        <li class="nav-item" role="presentation">
                                                            <button class="nav-link" id="tab-resume"
                                                                data-bs-toggle="pill" data-bs-target="#pane-resume"
                                                                type="button" role="tab" aria-controls="pane-resume"
                                                                aria-selected="false">
                                                                <i class="bi bi-file-earmark-text me-1"></i>Resume
                                                            </button>
                                                        </li>
                                                        <li class="nav-item" role="presentation">
                                                            <button class="nav-link" id="tab-plan" data-bs-toggle="pill"
                                                                data-bs-target="#pane-plan" type="button" role="tab"
                                                                aria-controls="pane-plan" aria-selected="false">
                                                                <i class="bi bi-box me-1"></i>Plan
                                                            </button>
                                                        </li>
                                                        <li class="nav-item" role="presentation">
                                                            <button class="nav-link" id="tab-settings"
                                                                data-bs-toggle="pill" data-bs-target="#pane-settings"
                                                                type="button" role="tab" aria-controls="pane-settings"
                                                                aria-selected="false">
                                                                <i class="bi bi-gear me-1"></i>Settings
                                                            </button>
                                                        </li>
                                                    </ul>

                                                    <div class="tab-content" id="freelancerProfileTabContent">
                                                        <div class="tab-pane fade show active" id="pane-basic"
                                                            role="tabpanel" aria-labelledby="tab-basic" tabindex="0">
                                                            <div class="row g-3">
                                                                <div class="col-12 col-lg-6">
                                                                    <label class="form-label">Full name</label>
                                                                    <input type="text" name="full_name"
                                                                        class="form-control"
                                                                        value="<%= p.full_name ? p.full_name : '' %>">
                                                                </div>

                                                                <div class="col-12 col-lg-6">
                                                                    <label class="form-label">Professional title</label>
                                                                    <input type="text" name="title" class="form-control"
                                                                        placeholder="Frontend Developer, Data Analyst..."
                                                                        value="<%= p.title ? p.title : '' %>">
                                                                </div>

                                                                <div class="col-12 col-lg-6">
                                                                    <label class="form-label">Location</label>
                                                                    <input type="text" name="location"
                                                                        class="form-control"
                                                                        placeholder="Ho Chi Minh City"
                                                                        value="<%= p.location ? p.location : '' %>">
                                                                </div>

                                                                <div class="col-12 col-lg-3">
                                                                    <label class="form-label">Experience level</label>
                                                                    <select name="experience_level" class="form-select">
                                                                        <% const exp=p.experience_level ?
                                                                            String(p.experience_level) : '' ; %>
                                                                            <option value="" <%=!exp ? 'selected' : ''
                                                                                %>>Select</option>
                                                                            <option value="intern" <%=exp==='intern'
                                                                                ? 'selected' : '' %>>Intern</option>
                                                                            <option value="junior" <%=exp==='junior'
                                                                                ? 'selected' : '' %>>Junior</option>
                                                                            <option value="mid" <%=exp==='mid'
                                                                                ? 'selected' : '' %>>Mid-level</option>
                                                                            <option value="senior" <%=exp==='senior'
                                                                                ? 'selected' : '' %>>Senior</option>
                                                                    </select>
                                                                </div>

                                                                <div class="col-12 col-lg-3">
                                                                    <label class="form-label">Expected rate</label>
                                                                    <div class="input-group">
                                                                        <span class="input-group-text">$</span>
                                                                        <input type="number" step="0.01" min="0"
                                                                            name="hourly_rate" class="form-control"
                                                                            placeholder="10"
                                                                            value="<%= (p.hourly_rate !== undefined && p.hourly_rate !== null) ? p.hourly_rate : '' %>">
                                                                        <span class="input-group-text">/hr</span>
                                                                    </div>
                                                                </div>


                                                            </div>
                                                        </div>

                                                        <div class="tab-pane fade" id="pane-about" role="tabpanel"
                                                            aria-labelledby="tab-about" tabindex="0">
                                                            <div class="row g-3">
                                                                <div class="col-12">
                                                                    <label class="form-label">About me</label>
                                                                    <textarea name="bio" class="form-control" rows="6"
                                                                        placeholder="Write a short introduction about your skills, experience, and what you're looking for..."><%= p.bio ? p.bio : '' %></textarea>
                                                                </div>

                                                                <div class="col-12">
                                                                    <label class="form-label">Skills</label>
                                                                    <input type="text" name="skills"
                                                                        class="form-control"
                                                                        placeholder="React, Node.js, SQL, Docker..."
                                                                        value="<%= p.skills ? p.skills : '' %>">
                                                                    <div class="form-text">Separate skills with commas.
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <div class="tab-pane fade" id="pane-links" role="tabpanel"
                                                            aria-labelledby="tab-links" tabindex="0">
                                                            <div class="row g-3">
                                                                <div class="col-12 col-lg-6">
                                                                    <label class="form-label">Portfolio URL</label>
                                                                    <input type="url" name="portfolio_url"
                                                                        class="form-control" placeholder="https://"
                                                                        value="<%= p.portfolio_url ? p.portfolio_url : '' %>">
                                                                </div>

                                                                <div class="col-12 col-lg-6">
                                                                    <label class="form-label">GitHub</label>
                                                                    <input type="url" name="github_url"
                                                                        class="form-control"
                                                                        placeholder="https://github.com/"
                                                                        value="<%= p.github_url ? p.github_url : '' %>">
                                                                </div>

                                                                <div class="col-12 col-lg-6">
                                                                    <label class="form-label">LinkedIn</label>
                                                                    <input type="url" name="linkedin_url"
                                                                        class="form-control"
                                                                        placeholder="https://linkedin.com/in/"
                                                                        value="<%= p.linkedin_url ? p.linkedin_url : '' %>">
                                                                </div>

                                                                <div class="col-12 col-lg-6">
                                                                    <label class="form-label">Personal website</label>
                                                                    <input type="url" name="website"
                                                                        class="form-control" placeholder="https://"
                                                                        value="<%= p.website ? p.website : '' %>">
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <div class="tab-pane fade" id="pane-resume" role="tabpanel"
                                                            aria-labelledby="tab-resume" tabindex="0">
                                                            <div class="row g-3">
                                                                <div class="col-12 col-lg-6">
                                                                    <label class="form-label">CV / Resume
                                                                        (Optional)</label>
                                                                    <input class="form-control" type="file" id="cv"
                                                                        name="cv" accept=".pdf,.doc,.docx">
                                                                    <div class="form-text">Accepted: PDF, DOC, DOCX. Max
                                                                        size: 5MB.</div>
                                                                    <% if (p.cv_url) { %>
                                                                        <div class="mt-2">
                                                                            <a href="<%= p.cv_url %>" target="_blank"
                                                                                rel="noopener"
                                                                                class="text-decoration-none">
                                                                                <i
                                                                                    class="bi bi-file-earmark-text me-1"></i>View
                                                                                current CV
                                                                            </a>
                                                                        </div>
                                                                        <% } %>
                                                                </div>

                                                                <div class="col-12 col-lg-6">
                                                                    <label class="form-label">Education</label>
                                                                    <input type="text" name="education"
                                                                        class="form-control"
                                                                        placeholder="University, major..."
                                                                        value="<%= p.education ? p.education : '' %>">
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <div class="tab-pane fade" id="pane-plan" role="tabpanel"
                                                            aria-labelledby="tab-plan" tabindex="0">
                                                            <% const ps=(typeof planStatus !=='undefined' && planStatus)
                                                                ? planStatus : {}; %>
                                                                <div class="border rounded-4 p-3 p-md-4">
                                                                    <div
                                                                        class="d-flex justify-content-between align-items-center mb-2">
                                                                        <div class="h5 mb-0">Current Plan</div>
                                                                        <span
                                                                            class="badge <%= ps.code ? 'bg-primary' : 'bg-secondary' %>">
                                                                            <%= ps.name ? ps.name : 'None' %>
                                                                        </span>
                                                                    </div>
                                                                    <div class="text-muted small mb-3">
                                                                        <span>Start (UTC): <%= ps.start_utc ?
                                                                                ps.start_utc : '—' %></span>
                                                                        <span class="ms-3">End (UTC): <%= ps.end_utc ?
                                                                                ps.end_utc : '—' %></span>
                                                                        <span class="ms-3">Price: <%= (ps.price_monthly
                                                                                !==null && ps.price_monthly
                                                                                !==undefined) ? ps.price_monthly : '—'
                                                                                %>/<%= ps.currency ? 'month · ' +
                                                                                    ps.currency : 'month' %></span>
                                                                    </div>
                                                                    <% if (ps.code && ps.price_monthly > 0) { %>
                                                                    <div class="mb-3 d-flex align-items-center gap-2">
                                                                        <div class="form-check form-switch mb-0">
                                                                            <input class="form-check-input" type="checkbox" role="switch"
                                                                                id="autoRenewToggleFreelancer"
                                                                                <%= ps.auto_renew ? 'checked' : '' %>>
                                                                            <label class="form-check-label fw-semibold" for="autoRenewToggleFreelancer">
                                                                                Auto-renew
                                                                            </label>
                                                                        </div>
                                                                        <span class="text-muted small" id="autoRenewStatusFreelancer">
                                                                            <%= ps.auto_renew ? 'Enabled — plan will renew automatically when expired or quota is full' : 'Disabled — you will need to renew manually' %>
                                                                        </span>
                                                                    </div>
                                                                    <% } %>
                                                                    <div class="row g-3">
                                                                        <div class="col-12 col-md-6">
                                                                            <div class="card border-0 shadow-sm h-100">
                                                                                <div class="card-body">
                                                                                    <div class="fw-semibold mb-2">Limits
                                                                                    </div>
                                                                                    <% const lim=ps.limits || {}; %>
                                                                                        <div class="text-muted small">
                                                                                            Image: per-file <%=
                                                                                                lim.image &&
                                                                                                lim.image.max_file_mb ?
                                                                                                lim.image.max_file_mb
                                                                                                : '—' %>MB · monthly <%=
                                                                                                    lim.image &&
                                                                                                    lim.image.monthly_quota_mb
                                                                                                    ?
                                                                                                    lim.image.monthly_quota_mb
                                                                                                    : '—' %>MB</div>
                                                                                        <div class="text-muted small">
                                                                                            Video: per-file <%=
                                                                                                lim.video &&
                                                                                                lim.video.max_file_mb ?
                                                                                                lim.video.max_file_mb
                                                                                                : '—' %>MB · monthly <%=
                                                                                                    lim.video &&
                                                                                                    lim.video.monthly_quota_mb
                                                                                                    ?
                                                                                                    lim.video.monthly_quota_mb
                                                                                                    : '—' %>MB</div>
                                                                                        <div class="text-muted small">
                                                                                            File: per-file <%= lim.file
                                                                                                && lim.file.max_file_mb
                                                                                                ? lim.file.max_file_mb
                                                                                                : '—' %>MB · monthly <%=
                                                                                                    lim.file &&
                                                                                                    lim.file.monthly_quota_mb
                                                                                                    ?
                                                                                                    lim.file.monthly_quota_mb
                                                                                                    : '—' %>MB</div>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                        <div class="col-12 col-md-6">
                                                                            <div class="card border-0 shadow-sm h-100">
                                                                                <div class="card-body">
                                                                                    <div class="fw-semibold mb-2">This
                                                                                        Month Usage (UTC)</div>
                                                                                    <% const us=ps.usage || {}; %>
                                                                                        <div class="text-muted small">
                                                                                            Period: <%= us.period_key ?
                                                                                                us.period_key : '—' %>
                                                                                        </div>
                                                                                        <div class="text-muted small">
                                                                                            Image: <%= us.image_bytes
                                                                                                !==undefined ?
                                                                                                Math.round(us.image_bytes/1024/1024)
                                                                                                : 0 %>MB</div>
                                                                                        <div class="text-muted small">
                                                                                            Video: <%= us.video_bytes
                                                                                                !==undefined ?
                                                                                                Math.round(us.video_bytes/1024/1024)
                                                                                                : 0 %>MB</div>
                                                                                        <div class="text-muted small">
                                                                                            File: <%= us.file_bytes
                                                                                                !==undefined ?
                                                                                                Math.round(us.file_bytes/1024/1024)
                                                                                                : 0 %>MB</div>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="mt-4">
                                                                    <div class="h6 mb-3">Available Plans</div>
                                                                    <div id="planCatalogFreelancer"
                                                                        class="vstack gap-3"></div>
                                                                </div>
                                                        </div>
                                                        <!-- pane-settings replaces the end of tab-content -->
                                                        <div class="tab-pane fade" id="pane-settings" role="tabpanel"
                                                            aria-labelledby="tab-settings" tabindex="0">
                                                            <div class="card border-0 shadow-sm rounded-4 mt-3">
                                                                <div class="card-body p-4">
                                                                    <div class="row g-4">
                                                                        <div class="col-12 col-lg-6">
                                                                            <h6 class="fw-bold mb-3">Change Password
                                                                            </h6>
                                                                            <div
                                                                                class="card border-0 bg-light rounded-4">
                                                                                <div class="card-body p-4">
                                                                                    <div id="changePasswordAlert"
                                                                                        class="alert d-none small py-2"
                                                                                        role="alert"></div>
                                                                                    <div id="changePasswordWrapper">
                                                                                        <div class="mb-3">
                                                                                            <label
                                                                                                class="form-label small text-muted fw-semibold">Current
                                                                                                Password</label>
                                                                                            <input type="password"
                                                                                                name="current_password"
                                                                                                class="form-control"
                                                                                                placeholder="Enter current password">
                                                                                        </div>
                                                                                        <div class="mb-3">
                                                                                            <label
                                                                                                class="form-label small text-muted fw-semibold">New
                                                                                                Password</label>
                                                                                            <input type="password"
                                                                                                name="new_password"
                                                                                                class="form-control"
                                                                                                placeholder="Enter new password">
                                                                                        </div>
                                                                                        <div class="mb-4">
                                                                                            <label
                                                                                                class="form-label small text-muted fw-semibold">Confirm
                                                                                                New Password</label>
                                                                                            <input type="password"
                                                                                                name="confirm_new_password"
                                                                                                class="form-control"
                                                                                                placeholder="Confirm new password">
                                                                                        </div>
                                                                                    </div>
                                                                                </div>
                                                                            </div>
                                                                        </div>

                                                                        <div class="col-12 col-lg-6">
                                                                            <h6 class="fw-bold mb-3">Active Sessions
                                                                            </h6>
                                                                            <div
                                                                                class="card border-0 bg-light rounded-4">
                                                                                <div class="card-body"
                                                                                    id="sessionsContainerFreelancer">
                                                                                    <div
                                                                                        class="d-flex align-items-center justify-content-center py-3">
                                                                                        <div class="spinner-border text-primary spinner-border-sm me-2"
                                                                                            role="status"></div>
                                                                                        <span
                                                                                            class="small text-muted">Loading
                                                                                            sessions...</span>
                                                                                    </div>
                                                                                </div>
                                                                                <script>
                                                                                    document.addEventListener('DOMContentLoaded', async function () {
                                                                                        const container = document.getElementById('sessionsContainerFreelancer');
                                                                                        if (!container) return;
                                                                                        try {
                                                                                            const res = await fetch('/sessions');
                                                                                            const data = await res.json();
                                                                                            if (data.ok && data.sessions) {
                                                                                                container.innerHTML = '';
                                                                                                const PAGE_SIZE = 3;
                                                                                                const sessions = data.sessions;
                                                                                                let shown = 0;

                                                                                                function renderSessionEl(s) {
                                                                                                    const isCurrent = s.is_current;
                                                                                                    const dev = s.device;
                                                                                                    const loginTime = dev.login_time ? new Date(dev.login_time).toLocaleString() : 'Unknown time';
                                                                                                    const el = document.createElement('div');
                                                                                                    el.className = 'd-flex align-items-start gap-3 mb-3';
                                                                                                    el.innerHTML = `
                    <i class="bi bi-display fs-4 ${isCurrent ? 'text-primary' : 'text-secondary'}"></i>
                    <div class="flex-grow-1">
                        <div class="fw-bold d-flex justify-content-between align-items-center">
                            <span>${isCurrent ? 'Current Device' : 'Other Device'}</span>
                        </div>
                        <div class="text-muted small">${dev.os_browser} &bull; ${dev.ip || 'Unknown IP'}</div>
                        <div class="text-muted small" style="font-size: 0.75rem;">Login: ${loginTime}</div>
                        ${isCurrent ?
                                                                                                            '<div class="text-success small fw-semibold mt-1"><i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i>Active now</div>' :
                                                                                                            `<button type="button" class="btn btn-sm btn-outline-danger py-0 px-2 mt-2 revoke-btn" style="font-size:0.75rem" data-session-id="${s.id}">Log out</button>`}
                    </div>
                `;
                                                                                                    if (!isCurrent) {
                                                                                                        const btn = el.querySelector('.revoke-btn');
                                                                                                        if (btn) btn.addEventListener('click', function() {
                                                                                                            window.revokeSessionFreelancer(this.dataset.sessionId);
                                                                                                        });
                                                                                                    }
                                                                                                    return el;
                                                                                                }

                                                                                                function showMore() {
                                                                                                    const end = Math.min(shown + PAGE_SIZE, sessions.length);
                                                                                                    for (; shown < end; shown++) {
                                                                                                        container.insertBefore(renderSessionEl(sessions[shown]), loadMoreBtn);
                                                                                                    }
                                                                                                    const remaining = sessions.length - shown;
                                                                                                    if (remaining <= 0) {
                                                                                                        loadMoreBtn.style.display = 'none';
                                                                                                    } else {
                                                                                                        loadMoreBtn.textContent = `Load more (${remaining} more)`;
                                                                                                    }
                                                                                                }

                                                                                                const loadMoreBtn = document.createElement('button');
                                                                                                loadMoreBtn.type = 'button';
                                                                                                loadMoreBtn.className = 'btn btn-sm btn-outline-secondary w-100 mb-2';
                                                                                                loadMoreBtn.style.display = 'none';
                                                                                                loadMoreBtn.onclick = showMore;
                                                                                                container.appendChild(loadMoreBtn);

                                                                                                showMore();

                                                                                                const info = document.createElement('div');
                                                                                                info.innerHTML = '<hr class="my-2 border-secondary opacity-25"><p class="small text-muted mb-0 mt-2">Manage all active sessions across your devices.</p>';
                                                                                                container.appendChild(info);
                                                                                            } else {
                                                                                                container.innerHTML = '<div class="text-danger small">Failed to load sessions</div>';
                                                                                            }
                                                                                        } catch (e) {
                                                                                            container.innerHTML = '<div class="text-danger small">Error loading sessions</div>';
                                                                                        }
                                                                                    });

                                                                                    window.revokeSessionFreelancer = async function (id) {
                                                                                        const btn = document.querySelector(`.revoke-btn[data-session-id="${id}"]`);
                                                                                        if (btn) { btn.disabled = true; btn.textContent = 'Logging out...'; }
                                                                                        try {
                                                                                            const csrfToken = window.__CSRF__ || '';
                                                                                            const res = await fetch('/freelancer/sessions/revoke', {
                                                                                                method: 'POST',
                                                                                                headers: {
                                                                                                    'Content-Type': 'application/json',
                                                                                                    ...(csrfToken ? { 'CSRF-Token': csrfToken, 'X-CSRF-Token': csrfToken } : {})
                                                                                                },
                                                                                                body: JSON.stringify({ session_id: id, _csrf: csrfToken })
                                                                                            });
                                                                                            const data = await res.json();
                                                                                            if (data.ok) {
                                                                                                // Remove session card from DOM
                                                                                                const card = btn ? btn.closest('.d-flex.align-items-start') : null;
                                                                                                if (card) card.remove();
                                                                                                // Show toast
                                                                                                showSessionToast('Device has been logged out successfully.', 'success');
                                                                                            } else {
                                                                                                if (btn) { btn.disabled = false; btn.textContent = 'Log out'; }
                                                                                                showSessionToast(data.error || 'Failed to log out device.', 'danger');
                                                                                            }
                                                                                        } catch (e) {
                                                                                            if (btn) { btn.disabled = false; btn.textContent = 'Log out'; }
                                                                                            showSessionToast('Network error. Please try again.', 'danger');
                                                                                        }
                                                                                    }

                                                                                    function showSessionToast(message, type) {
                                                                                        const container = document.getElementById('sessionsContainerFreelancer');
                                                                                        const toast = document.createElement('div');
                                                                                        toast.className = `alert alert-${type} alert-dismissible fade show mt-2 py-2 px-3`;
                                                                                        toast.style.fontSize = '0.85rem';
                                                                                        toast.innerHTML = `<i class="bi bi-${type === 'success' ? 'check-circle' : 'exclamation-triangle'} me-2"></i>${message}<button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>`;
                                                                                        if (container) container.prepend(toast);
                                                                                        setTimeout(() => { if (toast.parentNode) toast.remove(); }, 4000);
                                                                                    }
                                                                                </script>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div> <!-- Close tab-content -->
                                                </div> <!-- Close mainProfileForm card-body -->

                                                <div class="card-footer bg-transparent border-0 px-4 pb-4">
                                                    <button type="submit" class="btn btn-primary">
                                                        <i class="bi bi-save me-1"></i>Save changes
                                                    </button>
                                                </div>
                                            </form>
                    </section>
            </div>
        </main>

        <%- include('../../public/footer') %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
                crossorigin="anonymous"></script>
            <script>
                    (function () {
                        const avatarInput = document.getElementById('avatar');
                        const previewContainer = document.getElementById('avatar-preview-container');

                        if (!avatarInput || !previewContainer) {
                            return;
                        }

                        avatarInput.addEventListener('change', function () {
                            const file = avatarInput.files && avatarInput.files[0] ? avatarInput.files[0] : null;
                            if (!file) {
                                return;
                            }

                            const url = URL.createObjectURL(file);
                            previewContainer.innerHTML = '';
                            const img = document.createElement('img');
                            img.src = url;
                            img.alt = 'Avatar preview';
                            previewContainer.style.width = '34px';
                            previewContainer.style.height = '34px';
                            previewContainer.style.minWidth = '34px';
                            previewContainer.style.minHeight = '34px';
                            previewContainer.style.maxWidth = '34px';
                            previewContainer.style.maxHeight = '34px';
                            previewContainer.style.overflow = 'hidden';
                            previewContainer.style.borderRadius = '50%';
                            img.style.objectFit = 'cover';
                            img.style.width = '100%';
                            img.style.height = '100%';
                            img.style.display = 'block';
                            previewContainer.appendChild(img);
                        });
                    })();
            </script>
            <script>
                (function () {
                    const wrap = document.getElementById('planCatalogFreelancer');
                    if (!wrap) return;
                    async function loadPlans() {
                        try {
                            const res = await fetch('/freelancer/plans', { credentials: 'same-origin' });
                            if (!res.ok) return;
                            const data = await res.json();
                            const list = Array.isArray(data.items) ? data.items : [];
                            const activeCode = data.active_plan_code || null;
                            const byPlan = {};
                            list.forEach(it => {
                                const key = it.code || it.id;
                                if (!byPlan[key]) byPlan[key] = { code: it.code, name: it.name, price: it.price_monthly, currency: it.currency, limits: {} };
                                if (it.kind) byPlan[key].limits[it.kind] = { max: it.max_file_mb, quota: it.monthly_quota_mb };
                            });
                            wrap.innerHTML = '';
                            Object.values(byPlan).forEach(p => {
                                const box = document.createElement('div');
                                box.className = 'border rounded-4 p-3';
                                const h = document.createElement('div');
                                h.className = 'fw-bold mb-1';
                                h.textContent = p.name;
                                const price = document.createElement('div');
                                price.className = 'text-muted small mb-2';
                                const priceStr = (p.price !== undefined && p.price !== null) ? (p.price + '/month') : '—';
                                price.innerHTML = 'Price: <i class="bi bi-gem text-primary"></i> ' + priceStr;
                                const d = document.createElement('div');
                                d.className = 'text-muted small mb-2';
                                ['image', 'video', 'file'].forEach(k => {
                                    const line = document.createElement('div');
                                    const lim = p.limits[k] || {};
                                    line.textContent = (k.charAt(0).toUpperCase() + k.slice(1)) + ': Per-file ' + (lim.max || '—') + 'MB · Monthly ' + (lim.quota || '—') + 'MB';
                                    d.appendChild(line);
                                });
                                const btn = document.createElement('button');
                                const isActive = p.code && p.code === activeCode;
                                if (isActive) {
                                    btn.className = 'btn btn-outline-secondary btn-sm';
                                    btn.textContent = 'Free';
                                    btn.type = 'button';
                                    btn.onclick = () => { };
                                } else {
                                    btn.className = 'btn btn-primary btn-sm';
                                    btn.textContent = 'Activate';
                                    btn.type = 'button';
                                    btn.onclick = async () => {
                                        const csrf = document.querySelector('input[name=\"_csrf\"]');
                                        const params = new URLSearchParams();
                                        params.set('plan_code', p.code);
                                        if (csrf) params.set('_csrf', csrf.value);
                                        const r = await fetch('/freelancer/plans/activate', {
                                            method: 'POST',
                                            headers: Object.assign({ 'Content-Type': 'application/x-www-form-urlencoded' }, csrf ? { 'CSRF-Token': csrf.value, 'X-CSRF-Token': csrf.value } : {}),
                                            body: params.toString(),
                                            credentials: 'same-origin'
                                        });
                                        let ok = r.ok, msg = '';
                                        try { const j = await r.json(); ok = j && j.ok; msg = j && j.error ? j.error : ''; if (j && j.new_balance !== undefined && j.new_balance !== null) { const valEl = document.getElementById('headerBalanceValue'); if (valEl) { const num = Number(j.new_balance); valEl.textContent = Number.isFinite(num) ? num.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) : String(j.new_balance); } } } catch (_) { }
                                        if (ok) {
                                            alert('Plan activated successfully!');
                                            location.reload();
                                        } else {
                                            alert(msg || 'Activation failed');
                                        }
                                    };
                                }
                                box.appendChild(h);
                                box.appendChild(price);
                                box.appendChild(d);
                                box.appendChild(btn);
                                wrap.appendChild(box);
                            });
                        } catch (_) { }
                    }
                    loadPlans();
                })();

                // Auto-renew toggle — freelancer
                (function() {
                    const toggle = document.getElementById('autoRenewToggleFreelancer');
                    const statusEl = document.getElementById('autoRenewStatusFreelancer');
                    if (!toggle) return;
                    toggle.addEventListener('change', async function() {
                        const val = toggle.checked ? 1 : 0;
                        const csrf = document.querySelector('input[name="_csrf"]');
                        const params = new URLSearchParams();
                        params.set('auto_renew', val);
                        if (csrf) params.set('_csrf', csrf.value);
                        try {
                            const r = await fetch('/freelancer/plans/toggle-auto-renew', {
                                method: 'POST',
                                headers: Object.assign({'Content-Type': 'application/x-www-form-urlencoded'}, csrf ? {'CSRF-Token': csrf.value, 'X-CSRF-Token': csrf.value} : {}),
                                body: params.toString(),
                                credentials: 'same-origin'
                            });
                            const j = await r.json();
                            if (j && j.ok) {
                                if (statusEl) statusEl.textContent = val ? 'Enabled — plan will renew automatically when expired or quota is full' : 'Disabled — you will need to renew manually';
                            } else {
                                toggle.checked = !toggle.checked;
                                alert((j && j.error) ? j.error : 'Failed to update auto-renew');
                            }
                        } catch(_) {
                            toggle.checked = !toggle.checked;
                            alert('Network error');
                        }
                    });
                })();

                // Combined Profile and Change Password AJAX submission
                document.addEventListener("DOMContentLoaded", function () {
                    const mainForm = document.getElementById('mainProfileForm');
                    const cpWrapper = document.getElementById('changePasswordWrapper');
                    const mainSaveBtn = mainForm ? mainForm.querySelector('button[type="submit"]') : null;

                    if (mainForm && cpWrapper) {
                        mainForm.addEventListener('submit', async function (e) {
                            const settingsTabItem = document.getElementById('pane-settings');
                            const isSettingsActive = settingsTabItem && settingsTabItem.classList.contains('active');

                            if (isSettingsActive) {
                                e.preventDefault();

                                const currentPass = cpWrapper.querySelector('input[name="current_password"]').value;
                                const newPass = cpWrapper.querySelector('input[name="new_password"]').value;
                                const confirmPass = cpWrapper.querySelector('input[name="confirm_new_password"]').value;

                                const alertBox = document.getElementById('changePasswordAlert');

                                if (!currentPass || !newPass || !confirmPass) {
                                    alertBox.classList.remove('d-none', 'alert-success');
                                    alertBox.classList.add('alert-danger');
                                    alertBox.innerHTML = '<i class="bi bi-exclamation-triangle-fill me-2"></i>Please fill in all password fields.';
                                    return;
                                }

                                if (newPass.length < 8) {
                                    alertBox.classList.remove('d-none', 'alert-success');
                                    alertBox.classList.add('alert-danger');
                                    alertBox.innerHTML = '<i class="bi bi-exclamation-triangle-fill me-2"></i>New password must be at least 8 characters.';
                                    return;
                                }

                                if (newPass !== confirmPass) {
                                    alertBox.classList.remove('d-none', 'alert-success');
                                    alertBox.classList.add('alert-danger');
                                    alertBox.innerHTML = '<i class="bi bi-exclamation-triangle-fill me-2"></i>New password and confirmation do not match.';
                                    return;
                                }

                                if (newPass === currentPass) {
                                    alertBox.classList.remove('d-none', 'alert-success');
                                    alertBox.classList.add('alert-danger');
                                    alertBox.innerHTML = '<i class="bi bi-exclamation-triangle-fill me-2"></i>New password must be different from the current password.';
                                    return;
                                }

                                if (mainSaveBtn) {
                                    mainSaveBtn.disabled = true;
                                    mainSaveBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Saving...';
                                }

                                alertBox.classList.add('d-none');

                                const data = {
                                    current_password: currentPass,
                                    new_password: newPass,
                                    confirm_new_password: confirmPass,
                                    _csrf: mainForm.querySelector('input[name="_csrf"]').value
                                };

                                try {
                                    const res = await fetch('/freelancer/change-password', {
                                        method: 'POST',
                                        headers: {
                                            'Content-Type': 'application/json',
                                            'Accept': 'application/json',
                                            'CSRF-Token': data._csrf || '',
                                            'X-CSRF-Token': data._csrf || ''
                                        },
                                        body: JSON.stringify(data)
                                    });

                                    const result = await res.json();

                                    if (!result.ok) {
                                        // Show error and halt profile submission
                                        let tabElement = document.querySelector('button[data-bs-target="#pane-settings"]');
                                        if (tabElement) new bootstrap.Tab(tabElement).show();

                                        alertBox.classList.remove('d-none', 'alert-success');
                                        alertBox.classList.add('alert-danger');
                                        alertBox.innerHTML = '<i class="bi bi-exclamation-triangle-fill me-2"></i>' + (result.error || 'Failed to update password.');

                                        if (mainSaveBtn) {
                                            mainSaveBtn.disabled = false;
                                            mainSaveBtn.innerHTML = '<i class="bi bi-save me-1"></i>Save changes';
                                        }
                                        return;
                                    }
                                } catch (err) {
                                    let tabElement = document.querySelector('button[data-bs-target="#pane-settings"]');
                                    if (tabElement) new bootstrap.Tab(tabElement).show();

                                    alertBox.classList.remove('d-none', 'alert-success');
                                    alertBox.classList.add('alert-danger');
                                    alertBox.innerHTML = '<i class="bi bi-exclamation-triangle-fill me-2"></i>An error occurred. Please try again.';

                                    if (mainSaveBtn) {
                                        mainSaveBtn.disabled = false;
                                        mainSaveBtn.innerHTML = '<i class="bi bi-save me-1"></i>Save changes';
                                    }
                                    return;
                                }

                                // Clean up password fields so they aren't accidentally re-submitted
                                cpWrapper.querySelector('input[name="current_password"]').value = '';
                                cpWrapper.querySelector('input[name="new_password"]').value = '';
                                cpWrapper.querySelector('input[name="confirm_new_password"]').value = '';

                                // User requested English success message REGARDLESS
                                alertBox.classList.remove('d-none', 'alert-danger');
                                alertBox.classList.add('alert-success');
                                alertBox.innerHTML = '<i class="bi bi-check-circle-fill me-2"></i>Password updated successfully!';

                                if (mainSaveBtn) {
                                    mainSaveBtn.disabled = false;
                                    mainSaveBtn.innerHTML = '<i class="bi bi-save me-1"></i>Save changes';
                                }

                                // DO NOT submit main form native. We only update password from this tab!
                            } else {
                                // If NOT on Settings tab, submit main form natively
                                HTMLFormElement.prototype.submit.call(mainForm);
                            }
                        });
                    }
                });

                // Auto-open tab based on URL hash
                document.addEventListener("DOMContentLoaded", function () {
                    let hash = window.location.hash;
                    if (hash) {
                        let tabElement = document.querySelector('button[data-bs-target="' + hash + '"]');
                        if (tabElement) {
                            let tab = new bootstrap.Tab(tabElement);
                            tab.show();
                        }
                    }
                });
            </script>
</body>

</html>