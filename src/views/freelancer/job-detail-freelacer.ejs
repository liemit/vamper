<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= job && job.title ? job.title : 'Job Detail' %> - Vamper</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <%- include('../../public/header') %>

        <main>
            <section class="py-4 py-md-5">
                <div class="container">
                    <div class="d-flex align-items-center justify-content-between mb-4">
                        <a href="/" class="text-decoration-none">
                            <i class="bi bi-arrow-left"></i> Back
                        </a>
                        <div class="d-flex gap-3">
                            <span class="text-muted small"><i class="bi bi-eye me-1"></i> <%= fmtViews(job && job.total_views ? job.total_views : 0) %> views</span>
                            <span class="text-muted small">Posted: <%= job && job.created_at ? new Date(job.created_at).toLocaleDateString() : '' %></span>
                        </div>
                    </div>
                    
                    <div class="alert alert-warning alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <strong>Security Notice:</strong> Please be cautious with information provided by users. We are not responsible for any transactions or agreements made outside our platform!
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>

                    <div class="row g-4">
                        <div class="col-lg-8">
                            <% if (success_msg && success_msg.length > 0) { %>
                                <div class="alert alert-success alert-dismissible fade show" role="alert">
                                    <i class="bi bi-check-circle-fill me-2"></i>
                                    <%= success_msg %>
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            <% } %>
                            <% if (error_msg && error_msg.length > 0) { %>
                                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                    <%= error_msg %>
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            <% } %>
                            <div class="card border-0 shadow-sm rounded-4">
                                <div class="card-body p-4 p-md-5">
                                    <div class="d-flex align-items-start gap-3">
                                        <div class="job-thumb rounded border bg-light d-flex align-items-center justify-content-center">
                                            <% if (job && job.thumbnail_url) { %>
                                                <img src="<%= job.thumbnail_url %>" alt="<%= job.title %>">
                                            <% } else { %>
                                                <i class="bi bi-briefcase fs-2 text-secondary"></i>
                                            <% } %>
                                        </div>

                                        <div class="flex-grow-1">
                                            <h1 class="h4 fw-bold mb-2"><%= job && job.title ? job.title : '' %></h1>
                                            <div class="d-flex flex-wrap gap-3 text-muted small">
                                                <span><i class="bi bi-building me-1"></i> <%= job && job.company_name ? job.company_name : 'Company' %></span>
                                                <% if (job && job.category_name) { %>
                                                    <span><i class="bi bi-tags me-1"></i> <%= job.category_name %></span>
                                                <% } %>
                                                <span><i class="bi bi-geo-alt me-1"></i> Remote</span>
                                                <% if (job && job.deadline) { %>
                                                    <span><i class="bi bi-calendar-event me-1"></i> Deadline: <%= new Date(job.deadline).toLocaleDateString() %></span>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>

                                    <hr class="my-4">

                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h5 class="fw-bold mb-0"><%= (typeof t === 'function') ? t('bodycontent.tagDescription', 'Project Description') : 'Project Description' %></h5>
                                        <button class="btn btn-sm btn-outline-secondary d-none" id="toggle-image-view" title="Toggle image gallery view">
                                            <i class="bi bi-grid-3x3-gap-fill"></i>
                                        </button>
                                    </div>
                                    <div class="text-muted vamper-richtext" id="job-description-content"><%- job && job.description ? job.description : '' %></div>

                                    <!-- Banner: job_detail -->
                                    <% const jobDetailBanners = (typeof banners !== 'undefined') ? banners.filter(b => b.position === 'job_detail') : []; %>
                                    <% if (jobDetailBanners.length > 0) { %>
                                    <div class="mt-4">
                                        <hr class="mb-2">
                                        <div class="text-muted small mb-2" style="font-size:0.7rem;letter-spacing:0.05em;">Ads</div>
                                        <div class="d-flex flex-column gap-3">
                                        <% jobDetailBanners.forEach(b => { %>
                                            <div>
                                                <% if (b.ad_code) { %>
                                                    <%- b.ad_code %>
                                                <% } else { %>
                                                    <% if (b.link_url) { %><a href="<%= b.link_url %>" target="_blank" rel="noopener"><% } %>
                                                    <img src="<%= b.image_url %>" alt="<%= b.title %>" class="img-fluid rounded-4 w-100" style="max-height:180px;object-fit:cover;">
                                                    <% if (b.link_url) { %></a><% } %>
                                                <% } %>
                                            </div>
                                        <% }); %>
                                        </div>
                                    </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-4">
                            <div class="card border-0 shadow-sm rounded-4 mb-4">
                                <div class="card-body p-4">
                                    <% const budgetNum = (job && job.budget !== undefined && job.budget !== null) ? Number(job.budget) : null; %>
                                    <% const budgetLabel = (budgetNum !== null && Number.isFinite(budgetNum)) ? ('<i class="bi bi-gem text-primary"></i> ' + budgetNum.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 2 })) : 'Negotiable'; %>
                                    <% const typeLabel = (job && job.job_type === 'hourly') ? 'Hourly' : 'Project'; %>

                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <div class="fw-bold"><%= (typeof t === 'function') ? t('bodycontent.tagBudget', 'Budget') : 'Budget' %></div>
                                        <div class="badge bg-light text-primary border border-primary-subtle"><%- budgetLabel %></div>
                                    </div>

                                    <div class="d-flex justify-content-between align-items-center mb-4">
                                        <div class="fw-bold"><%= (typeof t === 'function') ? t('bodycontent.tagType', 'Type') : 'Type' %></div>
                                        <div class="badge bg-success-subtle text-success"><%= typeLabel %></div>
                                    </div>

                                    <% const alreadyApplied = ((typeof hasApplied !== 'undefined' && hasApplied) || (typeof req !== 'undefined' && req && req.query && String(req.query.applied) === '1')); %>
                                    <% const isOpen = job && job.status === 'open'; %>
                                    <% if (!isOpen || alreadyApplied) { %>
                                        <button type="button" class="btn btn-secondary w-100 fw-semibold py-2" disabled>
                                            <%= alreadyApplied ? 'Applied' : 'Closed' %>
                                        </button>
                                    <% } else { %>
                                        <form method="POST" action="/freelancer/proposals/apply?_csrf=<%= csrfToken %>">
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                            <input type="hidden" name="job_id" value="<%= job && job.id ? job.id : '' %>">
                                            <button type="submit" class="btn btn-primary w-100 fw-semibold py-2">Apply</button>
                                        </form>
                                    <% } %>
                                    <a href="/freelancer/messages?<%= (job && job.employer_id ? ('to=' + encodeURIComponent(String(job.employer_id))) : '') %><%= (job && job.id ? ( (job && job.employer_id ? '&' : '') + 'job=' + encodeURIComponent(String(job.id)) ) : '') %>" class="btn btn-outline-primary w-100 fw-semibold py-2 mt-2">
                                        <i class="bi bi-chat-dots me-1"></i><%= (typeof t === 'function') ? t('common.message', 'Message') : 'Message' %>
                                    </a>

                                    <div class="text-muted small mt-2">
                                        <%= (typeof t === 'function') ? t('bodycontent.tagNote', 'Your application will be sent to the employer.') : 'Your application will be sent to the employer.' %>
                                    </div>
                                </div>
                            </div>

                            <div class="card border-0 shadow-sm rounded-4">
                                <div class="card-body p-4">
                                    <h5 class="fw-bold mb-3">Employer</h5>

                                    <div class="d-flex align-items-center gap-3 mb-3">
                                        <div class="job-thumb rounded border bg-light d-flex align-items-center justify-content-center">
                                            <% if (job && job.logo_url) { %>
                                                <img src="<%= job.logo_url %>" alt="Logo">
                                            <% } else { %>
                                                <i class="bi bi-building fs-4 text-secondary"></i>
                                            <% } %>
                                        </div>
                                        <div>
                                            <div class="fw-semibold"><%= job && job.company_name ? job.company_name : 'Company' %></div>
                                            <% if (job && job.city) { %>
                                                <div class="text-muted small"><i class="bi bi-geo-alt me-1"></i><%= job.city %></div>
                                            <% } %>
                                        </div>
                                    </div>

                                    <% if (job && job.company_description) { %>
                                        <div class="text-muted small vamper-richtext"><%- job.company_description %></div>
                                    <% } else { %>
                                        <div class="text-muted small">No company description provided.</div>
                                    <% } %>

                                    <% if (job && job.website) { %>
                                        <div class="mt-3">
                                            <a class="text-decoration-none" href="<%= job.website %>" target="_blank" rel="noopener noreferrer">
                                                <i class="bi bi-link-45deg"></i> Company website
                                            </a>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </main>

        <%- include('../../public/footer') %>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
                integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
                crossorigin="anonymous"></script>
            <script src="/js/job-image-gallery.js?v=2"></script>
</body>

</html>
