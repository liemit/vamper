<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vamper - Withdraw Funds</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <%- include('../../public/header') %>

    <main class="container-fluid py-4">
        <div class="row">
            <%- include('./layouts/menu') %>

            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
                <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                    <h1 class="h2">Withdraw Funds</h1>
                </div>

                <% if (success_msg && success_msg.length > 0) { %>
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <%= success_msg %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>

                <% if (error_msg && error_msg.length > 0) { %>
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <%= error_msg %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>

                <div class="row justify-content-center">
                    <div class="col-md-8 col-lg-6">
                        <div class="card border-0 shadow-sm rounded-4">
                            <div class="card-body p-4">
                                <h5 class="card-title fw-bold mb-3">Request a withdrawal</h5>
                                <div class="text-muted small mb-3">Minimum withdrawal amount is 100 Credits</div>

                                <form action="/freelancer/withdraw" method="POST">
                                    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

                                    <div class="mb-3">
                                        <label class="form-label text-muted small fw-bold text-uppercase">PayPal email</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light"><i class="bi bi-paypal"></i></span>
                                            <input type="email" class="form-control" name="paypalEmail" placeholder="you@example.com" required>
                                        </div>
                                    </div>

                                    <div class="mb-4">
                                        <label class="form-label text-muted small fw-bold text-uppercase">Amount (Credits)</label>
                                        <div class="input-group input-group-lg">
                                            <span class="input-group-text bg-light border-end-0 fw-bold"><i class="bi bi-gem text-primary"></i></span>
                                            <input type="number" class="form-control border-start-0 ps-0 fw-bold" name="amount" placeholder="100" min="100" step="0.01" required>
                                        </div>
                                    </div>

                                    <div class="d-grid">
                                        <button type="submit" class="btn btn-primary btn-lg fw-bold">
                                            Submit Withdraw Request <i class="bi bi-arrow-right ms-2"></i>
                                        </button>
                                    </div>

                                    <div class="text-center mt-3">
                                        <small class="text-muted">Your request will be reviewed by admin. You will receive a notification when it is processed.</small>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>

            </main>
        </div>
    </main>

    <%- include('../../public/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
