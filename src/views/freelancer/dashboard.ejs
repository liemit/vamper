<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vamper - Freelancer Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <%- include('../../public/header') %>

        <main class="container-fluid py-4">
            <div class="row">
                <%- include('./layouts/menu') %>

                <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
                    <div
                        class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                        <h1 class="h2">Freelancer Dashboard</h1>
                        <div class="btn-toolbar mb-2 mb-md-0">
                            <div class="btn-group me-2">
                                <button type="button" class="btn btn-sm btn-outline-secondary">Share</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary">Export</button>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-xl-3 col-md-6 mb-4">
                            <div class="card border-left-primary shadow h-100 py-2">
                                <div class="card-body">
                                    <div class="row no-gutters align-items-center">
                                        <div class="col mr-2">
                                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                                Active Projects</div>
                                            <div class="h5 mb-0 font-weight-bold text-gray-800"><%= (typeof stats !== 'undefined' && stats.active_projects) ? stats.active_projects : 0 %></div>
                                        </div>
                                        <div class="col-auto">
                                            <i class="bi bi-briefcase fa-2x text-gray-300"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-xl-3 col-md-6 mb-4">
                            <div class="card border-left-success shadow h-100 py-2">
                                <div class="card-body">
                                    <div class="row no-gutters align-items-center">
                                        <div class="col mr-2">
                                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Total
                                                Earnings</div>
                                            <div class="h5 mb-0 font-weight-bold text-gray-800"><i class="bi bi-gem"></i> <%= (typeof stats !== 'undefined' && stats.total_earnings) ? stats.total_earnings.toLocaleString() : '0' %></div>
                                        </div>
                                        <div class="col-auto">
                                            <i class="bi bi-gem fa-2x text-gray-300"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-xl-3 col-md-6 mb-4">
                            <div class="card border-left-info shadow h-100 py-2">
                                <div class="card-body">
                                    <div class="row no-gutters align-items-center">
                                        <div class="col mr-2">
                                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                                                Completed Projects</div>
                                            <div class="h5 mb-0 font-weight-bold text-gray-800"><%= (typeof stats !== 'undefined' && stats.completed_projects) ? stats.completed_projects : 0 %></div>
                                        </div>
                                        <div class="col-auto">
                                            <i class="bi bi-check-circle fa-2x text-gray-300"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-xl-3 col-md-6 mb-4">
                            <div class="card border-left-warning shadow h-100 py-2">
                                <div class="card-body">
                                    <div class="row no-gutters align-items-center">
                                        <div class="col mr-2">
                                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                                                Pending Proposals</div>
                                            <div class="h5 mb-0 font-weight-bold text-gray-800"><%= (typeof stats !== 'undefined' && stats.pending_proposals) ? stats.pending_proposals : 0 %></div>
                                        </div>
                                        <div class="col-auto">
                                            <i class="bi bi-hourglass-split fa-2x text-gray-300"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12 mb-4">
                            <div class="card shadow">
                                <div class="card-header py-3 d-flex align-items-center justify-content-between">
                                    <h6 class="m-0 font-weight-bold text-primary">Latest Jobs</h6>
                                    <a href="/freelancer/jobs" class="text-decoration-none fw-semibold">View all</a>
                                </div>
                                <div class="card-body">
                                    <% const latestJobs = (typeof jobs !== 'undefined' && Array.isArray(jobs)) ? jobs : []; %>
                                    <% if (latestJobs.length === 0) { %>
                                        <p class="text-muted mb-0">No jobs found.</p>
                                    <% } else { %>
                                        <div class="list-group list-group-flush">
                                            <% latestJobs.forEach(function(job) { %>
                                                <a class="list-group-item list-group-item-action d-flex align-items-center gap-3" href="/freelancer/jobs/<%= job.slug %>">
                                                    <div class="job-thumb flex-shrink-0 position-relative rounded overflow-hidden border">
                                                        <% if (job.thumbnail_url) { %>
                                                            <img src="<%= job.thumbnail_url %>" alt="<%= job.title %>">
                                                        <% } else { %>
                                                            <div class="w-100 h-100 bg-light d-flex align-items-center justify-content-center">
                                                                <i class="bi bi-briefcase text-secondary"></i>
                                                            </div>
                                                        <% } %>
                                                    </div>
                                                    <div class="flex-grow-1">
                                                        <div class="fw-bold"><%= job.title %></div>
                                                        <div class="text-muted small">
                                                            <%= job.company_name ? job.company_name : 'Company' %>
                                                        </div>
                                                    </div>
                                                    <div class="text-muted small">
                                                        <%= job.created_at ? new Date(job.created_at).toLocaleDateString() : '' %>
                                                    </div>
                                                </a>
                                            <% }); %>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-lg-8">
                            <div class="card shadow mb-4">
                                <div class="card-header py-3">
                                    <h6 class="m-0 font-weight-bold text-primary">Recent Projects</h6>
                                </div>
                                <div class="card-body">
                                    <% const rp = (typeof recentProjects !== 'undefined') ? recentProjects : []; %>
                                    <% if (!rp.length) { %>
                                        <p class="text-muted small mb-0">No recent projects found.</p>
                                    <% } else { %>
                                        <div class="d-flex flex-column gap-3">
                                        <% rp.forEach(function(proj) { %>
                                            <%
                                                let statusBadge = 'bg-warning-subtle text-warning text-dark';
                                                let statusLabel = 'Pending';
                                                if (proj.is_deposited === 2) { statusBadge = 'bg-primary-subtle text-primary'; statusLabel = 'Completed'; }
                                                else if (proj.is_deposited === 1) { statusBadge = 'bg-success-subtle text-success'; statusLabel = 'Active'; }
                                                else if (proj.status === 'accepted') { statusBadge = 'bg-info-subtle text-info'; statusLabel = 'Accepted'; }
                                            %>
                                            <div class="d-flex align-items-center gap-3">
                                                <div class="flex-shrink-0 rounded overflow-hidden border" style="width:40px;height:40px;">
                                                    <% if (proj.thumbnail_url) { %>
                                                        <img src="<%= proj.thumbnail_url %>" alt="" style="width:100%;height:100%;object-fit:cover;">
                                                    <% } else { %>
                                                        <div class="w-100 h-100 bg-light d-flex align-items-center justify-content-center">
                                                            <i class="bi bi-briefcase text-secondary small"></i>
                                                        </div>
                                                    <% } %>
                                                </div>
                                                <div class="flex-grow-1 min-w-0">
                                                    <div class="fw-semibold text-truncate">
                                                        <a href="/freelancer/jobs/<%= proj.job_slug %>" class="text-decoration-none text-dark"><%= proj.job_title %></a>
                                                    </div>
                                                    <div class="text-muted small"><%= proj.company_name || proj.employer_name || 'Employer' %></div>
                                                </div>
                                                <span class="badge <%= statusBadge %> flex-shrink-0"><%= statusLabel %></span>
                                            </div>
                                        <% }); %>
                                        </div>
                                        <div class="mt-3">
                                            <a href="/freelancer/proposals" class="btn btn-sm btn-outline-primary">View all projects</a>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-4">
                            <div class="card shadow mb-4">
                                <div class="card-header py-3">
                                    <h6 class="m-0 font-weight-bold text-primary">Profile Summary</h6>
                                </div>
                                <div class="card-body">
                                    <p>Complete your profile to attract more clients.</p>
                                    <a href="/freelancer/profile" class="btn btn-primary btn-sm">Edit Profile</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </main>
            </div>
        </main>

        <%- include('../../public/footer') %>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>