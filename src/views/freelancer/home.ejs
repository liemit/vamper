<!DOCTYPE html>
<html lang="<%= (typeof lang !== 'undefined' && lang) ? String(lang) : 'en' %>">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vamper - Việc làm cho sinh viên IT</title>
    <!-- Bootstrap 5 CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/style.css">

</head>

<body>
    <%- include('../../public/header') %>

        <% const base = '/freelancer'; %>
        <% const qVal = (typeof query !== 'undefined' && query && query.q) ? String(query.q) : ''; %>

        <main>
            <!-- Hero Section -->
            <section class="hero-section text-center text-white d-flex align-items-center">
                <div class="container py-5">
                    <div class="row justify-content-center">
                        <div class="col-lg-8">
                            <h1 class="display-4 fw-bold mb-3"><%= (typeof t === 'function') ? t('bodycontent.hero_headline', 'Find IT Jobs - Internships - Freelance') : 'Find IT Jobs - Internships - Freelance' %></h1>
                            <p class="lead mb-4 opacity-75"><%= (typeof t === 'function') ? t('bodycontent.hero_subtitle', 'Connect talented IT students with real opportunities. Simple, fast, and trusted.') : 'Connect talented IT students with real opportunities. Simple, fast, and trusted.' %></p>

                            <div class="bg-white p-3 rounded-4 shadow-lg mx-auto" style="max-width: 700px;">
                                <form class="d-flex flex-column flex-md-row gap-2" method="get" action="/freelancer/jobs">
                                    <div class="input-group flex-grow-1">

                                        <span class="input-group-text bg-white border-end-0"><i
                                                class="bi bi-search text-muted"></i></span>
                                        <input type="text" class="form-control border-start-0 ps-0 form-control-lg"
                                            name="q" value="<%= qVal %>" placeholder="<%= (typeof t === 'function') ? t('home.search_placeholder', 'Search skills (Java, React, Python)...') : 'Search skills (Java, React, Python)...' %>">
                                    </div>
                                    <button type="submit" class="btn btn-primary btn-lg px-4 fw-bold"><%= (typeof t === 'function') ? t('home.search', 'Search') : 'Search' %></button>
                                </form>
                            </div>
                        </div>
                    </div>

                </div>
            </section>

            <!-- Banner Section: home_top -->
            <% const homeBanners = (typeof banners !== 'undefined') ? banners.filter(b => b.position === 'home_top') : []; %>
            <% if (homeBanners.length > 0) { %>
            <section class="py-3 bg-white">
                <div class="container">
                    <div class="row g-3">
                        <% homeBanners.forEach(b => { %>
                        <% if (b.ad_code) { %>
                        <div class="col-12 text-center">
                            <div style="min-height:50px;display:flex;align-items:center;justify-content:center;">
                                <%- b.ad_code %>
                            </div>
                        </div>
                        <% } else { %>
                        <div class="col-12 col-md-<%= homeBanners.filter(x=>!x.ad_code).length === 1 ? '12' : '6' %>">
                            <% if (b.link_url) { %><a href="<%= b.link_url %>" target="_blank" rel="noopener"><% } %>
                            <img src="<%= b.image_url %>" alt="<%= b.title %>" class="img-fluid rounded-4 w-100" style="max-height:200px;object-fit:cover;">
                            <% if (b.link_url) { %></a><% } %>
                        </div>
                        <% } %>
                        <% }); %>
                    </div>
                </div>
            </section>
            <% } %>

            <!-- Categories Section -->
            <section class="py-5 bg-light">
                <div class="container" data-categories-slider>
                    <div class="d-flex align-items-end justify-content-between gap-3 mb-4">
                        <div>
                            <h5 class="text-primary fw-bold text-uppercase mb-2"><%= (typeof t === 'function') ? t('bodycontent.categories_title', 'Popular Categories') : 'Popular Categories' %></h5>
                            <h2 class="fw-bold mb-0"><%= (typeof t === 'function') ? t('bodycontent.categories_subtitle', 'What are you good at?') : 'What are you good at?' %></h2>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-outline-primary btn-sm" data-categories-prev aria-label="Previous categories">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                            <button type="button" class="btn btn-outline-primary btn-sm" data-categories-next aria-label="Next categories">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </div>
                    </div>

                    <% const cats = (typeof categories !== 'undefined' && Array.isArray(categories)) ? categories : []; %>
                    <% if (cats.length === 0) { %>
                        <div class="text-muted"><%= (typeof t === 'function') ? t('home.no_categories_found', 'No categories found.') : 'No categories found.' %></div>
                    <% } else { %>
                        <div class="categories-slider">
                            <div class="categories-track" data-categories-track>
                                <% cats.forEach(function(cat, idx) { %>
                                    <% const palette = ['primary','success','warning','danger','info','secondary']; %>
                                    <% const color = palette[idx % palette.length]; %>
                                    <% const icons = ['bi-browser-chrome','bi-phone','bi-palette','bi-database','bi-code-slash','bi-lightning-charge']; %>
                                    <% const icon = icons[idx % icons.length]; %>

                                    <div class="category-slide">
                                        <div class="card h-100 border-0 shadow-sm hover-card text-center py-4">
                                            <div class="card-body">
                                                <div class="icon-box bg-<%= color %> bg-opacity-10 text-<%= color %> rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center"
                                                    style="width: 60px; height: 60px;">
                                                    <i class="bi <%= icon %> fs-3"></i>
                                                </div>
                                                <h5 class="card-title fw-bold"><%= cat.name %></h5>
                                                <p class="card-text text-muted small"><%= (typeof t === 'function') ? t('home.explore_jobs_in_category', 'Explore jobs in this category') : 'Explore jobs in this category' %></p>
                                                <% const catHref = `/freelancer/categories/${encodeURIComponent(cat.slug)}`; %>
                                                <a href="<%= catHref %>" class="stretched-link"></a>
                                            </div>
                                        </div>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    <% } %>
                </div>
            </section>

            <!-- Banner: home_middle -->
            <% const middleBanners = (typeof banners !== 'undefined') ? banners.filter(b => b.position === 'home_middle') : []; %>
            <% if (middleBanners.length > 0) { %>
            <section class="py-3">
                <div class="container">
                    <div class="row g-3">
                        <% middleBanners.forEach(b => { %>
                        <% if (b.ad_code) { %>
                        <div class="col-12 text-center">
                            <%- b.ad_code %>
                        </div>
                        <% } else { %>
                        <div class="col-12 col-md-<%= middleBanners.filter(x=>!x.ad_code).length === 1 ? '12' : '6' %>">
                            <% if (b.link_url) { %><a href="<%= b.link_url %>" target="_blank" rel="noopener"><% } %>
                            <img src="<%= b.image_url %>" alt="<%= b.title %>" class="img-fluid rounded-4 w-100" style="max-height:160px;object-fit:cover;">
                            <% if (b.link_url) { %></a><% } %>
                        </div>
                        <% } %>
                        <% }); %>
                    </div>
                </div>
            </section>
            <% } %>

            <!-- Recent Jobs Section -->
            <section class="py-5">
                <div class="container">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h2 class="fw-bold m-0"><%= (typeof t === 'function') ? t('bodycontent.latest_jobs_title', 'Latest Jobs') : 'Latest Jobs' %></h2>
                        <a href="/jobs" class="text-decoration-none fw-bold"><%= (typeof t === 'function') ? t('home.view_all', 'View all') : 'View all' %> <i class="bi bi-arrow-right"></i></a>
                    </div>

                    <div class="job-list d-flex flex-column gap-3">
                        <% const latestJobs=(typeof jobs !=='undefined' && Array.isArray(jobs)) ? jobs : []; %>
                        <% if (latestJobs.length===0) { %>
                            <div class="text-muted"><%= (typeof t === 'function') ? t('home.no_jobs_found', 'No jobs found.') : 'No jobs found.' %></div>
                        <% } %>

                        <% latestJobs.forEach(function(job) { %>
                            <% const companyName=job.company_name ? job.company_name : 'Company' ; %>
                            <% const budgetNum=(job.budget===undefined || job.budget===null) ? null :
                                Number(job.budget); %>
                            <% const budgetLabel=(budgetNum !==null && Number.isFinite(budgetNum)) ?
                                ('<i class="bi bi-gem text-primary"></i> ' + budgetNum.toLocaleString('en-US', { minimumFractionDigits: 0,
                                maximumFractionDigits: 2 })) : 'Negotiable' ; %>
                            <% const typeLabel=job.job_type==='hourly' ? 'Hourly' : 'Project' ;
                                %>
                            <% const typeBadgeClass=job.job_type==='hourly'
                                ? 'bg-warning-subtle text-warning text-dark'
                                : 'bg-success-subtle text-success' ; %>

                            <div
                                class="card border-0 shadow-sm hover-shadow transition-all">
                                <div
                                    class="card-body d-flex align-items-center gap-3 p-4">
                                    <a class="stretched-link" href="/freelancer/jobs/<%= job.slug %>"></a>
                                    <div class="job-thumb flex-shrink-0 position-relative rounded overflow-hidden border">
                                        <% if (job.thumbnail_url) { %>
                                            <img src="<%= job.thumbnail_url %>"
                                                alt="<%= job.title %>">
                                        <% } else { %>
                                            <div
                                                class="w-100 h-100 bg-light d-flex align-items-center justify-content-center">
                                                <i
                                                    class="bi bi-briefcase text-secondary"></i>
                                            </div>
                                        <% } %>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h5 class="card-title fw-bold mb-1">
                                            <%= job.title %>
                                        </h5>
                                        <div
                                            class="d-flex gap-3 text-muted small flex-wrap">
                                            <span><i class="bi bi-building me-1"></i>
                                                <%= companyName %>
                                            </span>
                                            <span><i class="bi bi-geo-alt me-1"></i>
                                                <%= (typeof t === 'function') ? t('home.remote', 'Remote') : 'Remote' %></span>
                                            <span><i class="bi bi-clock me-1"></i>
                                                <%= job.created_at ? new
                                                    Date(job.created_at).toLocaleDateString()
                                                    : '' %>
                                            </span>
                                            <span><i class="bi bi-eye me-1"></i><%= fmtViews(job.total_views) %></span>
                                        </div>
                                    </div>
                                    <div class="text-end d-none d-md-block">
                                        <span
                                            class="badge bg-light text-primary border border-primary-subtle fs-6 mb-2">
                                            <%- budgetLabel %>
                                        </span>
                                        <br>
                                        <span class="badge <%= typeBadgeClass %>">
                                            <%= typeLabel %>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    </div>

                    <% const pager=(typeof pagination !=='undefined' && pagination) ? pagination : null; %>
                    <% if (pager && pager.totalPages && pager.totalPages> 1) { %>
                        <nav class="mt-4" aria-label="Latest jobs pagination">
                            <ul class="pagination justify-content-center">
                                <% const qsBase = `?q=${encodeURIComponent(qVal)}&`; %>
                                <li class="page-item <%= pager.page <= 1 ? 'disabled' : '' %>">
                                    <a class="page-link" href="<%= base %><%= qsBase %>page=<%= pager.page - 1 %>"><%= (typeof t === 'function') ? t('home.previous', 'Previous') : 'Previous' %></a>
                                </li>

                                <% for (let p=1; p <=pager.totalPages; p++) { %>
                                    <li class="page-item <%= p === pager.page ? 'active' : '' %>">
                                        <a class="page-link" href="<%= base %><%= qsBase %>page=<%= p %>">
                                            <%= p %>
                                        </a>
                                    </li>
                                <% } %>

                                <li
                                    class="page-item <%= pager.page >= pager.totalPages ? 'disabled' : '' %>">
                                    <a class="page-link" href="<%= base %><%= qsBase %>page=<%= pager.page + 1 %>"><%= (typeof t === 'function') ? t('home.next', 'Next') : 'Next' %></a>
                                </li>
                            </ul>
                        </nav>
                    <% } %>
                </div>
            </section>

        </main>
        <%- include('../../public/footer') %>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
                integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
                crossorigin="anonymous"></script>
            <script src="/js/categories-slider.js"></script>
            <script>
                (function () {
                    const isDesktopHover = window.matchMedia("(hover: hover) and (pointer: fine)");

                    function bindHoverDropdowns() {
                        if (!isDesktopHover.matches || !window.bootstrap) {
                            return;
                        }

                        document.querySelectorAll(".dropdown-hover").forEach((dropdown) => {
                            const toggle = dropdown.querySelector('[data-bs-toggle="dropdown"]');
                            if (!toggle) {
                                return;
                            }

                            dropdown.addEventListener("mouseenter", () => {
                                const instance = window.bootstrap.Dropdown.getOrCreateInstance(toggle);
                                instance.show();
                            });

                            dropdown.addEventListener("mouseleave", () => {
                                const instance = window.bootstrap.Dropdown.getOrCreateInstance(toggle);
                                instance.hide();
                            });
                        });
                    }

                    bindHoverDropdowns();
                    isDesktopHover.addEventListener("change", bindHoverDropdowns);
                })();
            </script>
</body>

</html>