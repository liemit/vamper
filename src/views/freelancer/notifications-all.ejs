<!DOCTYPE html>
<html lang="<%= (typeof lang !== 'undefined' && lang) ? String(lang) : 'en' %>">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vamper - Notifications</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <%- include('../../public/header') %>

    <main class="container-fluid py-3 py-md-4">
        <div class="row">
            <%- include('./layouts/menu') %>

            <section class="col-md-9 ms-sm-auto col-lg-10 px-2 px-md-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h1 class="h4 mb-0">Notifications</h1>
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="markAllReadPageBtn">Mark all read</button>
                </div>

                <div class="card shadow-sm border-0">
                    <div class="list-group list-group-flush" id="allNotificationsList">
                        <% if (Array.isArray(notifications) && notifications.length) { %>
                            <% notifications.forEach(function(n) { %>
                                <% const href = (n && n.url) ? String(n.url) : '#'; %>
                                <a href="<%= href %>" class="list-group-item list-group-item-action d-flex gap-3 py-3 <%= n.is_read ? '' : 'bg-light' %>" data-notification-id="<%= n.id %>" data-notification-url="<%= href %>">
                                    <div class="pt-1">
                                        <% if (n.type === 'success') { %>
                                            <i class="bi bi-check-circle-fill text-success fs-5"></i>
                                        <% } else if (n.type === 'warning') { %>
                                            <i class="bi bi-exclamation-triangle-fill text-warning fs-5"></i>
                                        <% } else if (n.type === 'error') { %>
                                            <i class="bi bi-x-circle-fill text-danger fs-5"></i>
                                        <% } else { %>
                                            <i class="bi bi-info-circle-fill text-primary fs-5"></i>
                                        <% } %>
                                    </div>
                                    <div class="d-flex gap-2 w-100 justify-content-between">
                                        <div>
                                            <h6 class="mb-1"><%= n.title ? n.title : '' %></h6>
                                            <p class="mb-0 opacity-75"><%= n.body ? n.body : '' %></p>
                                            <p class="mb-0 small text-muted mt-1"><i class="bi bi-clock me-1"></i><span class="js-local-dt" data-utc="<%= n.created_at ? n.created_at : '' %>"></span></p>
                                        </div>
                                    </div>
                                </a>
                            <% }) %>
                        <% } else { %>
                            <div class="p-4 text-center text-muted">No notifications</div>
                        <% } %>
                    </div>
                </div>

                <nav class="mt-3 d-flex justify-content-between">
                    <div>
                        <% if (pagination && pagination.hasPrev) { %>
                            <a class="btn btn-outline-primary btn-sm" href="<%= (typeof basePath !== 'undefined' && basePath) ? basePath : '/freelancer/notifications' %>?page=<%= pagination.page - 1 %>">Previous</a>
                        <% } %>
                    </div>
                    <div>
                        <span class="small text-muted">Page <%= (pagination && pagination.page) ? pagination.page : 1 %></span>
                    </div>
                    <div>
                        <% if (pagination && pagination.hasNext) { %>
                            <a class="btn btn-outline-primary btn-sm" href="<%= (typeof basePath !== 'undefined' && basePath) ? basePath : '/freelancer/notifications' %>?page=<%= pagination.page + 1 %>">Next</a>
                        <% } %>
                    </div>
                </nav>
            </section>
        </div>
    </main>

    <%- include('../../public/footer') %>

    <script>
        const __csrfToken = <%- JSON.stringify((typeof csrfToken !== 'undefined' && csrfToken) ? String(csrfToken) : '') %>;
        function getCsrfHeaders() {
            if (!__csrfToken) return {};
            return {
                'CSRF-Token': __csrfToken,
                'X-CSRF-Token': __csrfToken,
                'csrf-token': __csrfToken,
                'x-csrf-token': __csrfToken
            };
        }

        document.addEventListener('DOMContentLoaded', function() {
            const btn = document.getElementById('markAllReadPageBtn');
            if (btn) {
                btn.addEventListener('click', async function() {
                    if (!confirm('Mark all notifications as read?')) return;
                    const r = await fetch('/notifications/read-all', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', ...getCsrfHeaders() },
                        body: JSON.stringify({ _csrf: __csrfToken })
                    });
                    if (!r.ok) {
                        const text = await r.text();
                        alert(text || 'Failed to mark all as read');
                        return;
                    }
                    window.location.reload();
                });
            }

            const list = document.getElementById('allNotificationsList');
            if (list) {
                list.addEventListener('click', function(e) {
                    const a = e.target && e.target.closest ? e.target.closest('a[data-notification-id]') : null;
                    if (!a) return;
                    const id = a.getAttribute('data-notification-id');
                    if (!id) return;
                    fetch('/notifications/read', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', ...getCsrfHeaders() },
                        body: JSON.stringify({ id, _csrf: __csrfToken })
                    }).catch(function() {});
                });
            }
        });
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
