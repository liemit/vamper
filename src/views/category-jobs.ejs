<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= category && category.name ? category.name : 'Category' %> - Jobs - Vamper</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <%- include('../public/header') %>

        <main>
            <section class="py-4 py-md-5">
                <div class="container">
                    <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center gap-3 mb-4">
                        <a href="/" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Back
                        </a>
                        <div>
                            <div class="text-muted small">Category</div>
                            <h2 class="fw-bold mb-0"><%= category && category.name ? category.name : '' %></h2>
                        </div>
                    </div>

                    <div class="job-list d-flex flex-column gap-3">
                        <% const list=(typeof jobs !== 'undefined' && Array.isArray(jobs)) ? jobs : []; %>
                        <% if (list.length === 0) { %>
                            <div class="text-muted">No jobs found in this category.</div>
                        <% } %>

                        <% list.forEach(function(job) { %>
                            <% const companyName = job.company_name ? job.company_name : 'Company'; %>
                            <% const budgetNum = (job.budget === undefined || job.budget === null) ? null : Number(job.budget); %>
                            <% const budgetLabel = (budgetNum !== null && Number.isFinite(budgetNum))
                                ? ('$' + budgetNum.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 2 }))
                                : 'Negotiable'; %>
                            <% const typeLabel = job.job_type === 'hourly' ? 'Hourly' : 'Project'; %>
                            <% const typeBadgeClass = job.job_type === 'hourly'
                                ? 'bg-warning-subtle text-warning text-dark'
                                : 'bg-success-subtle text-success'; %>

                            <div class="card border-0 shadow-sm hover-shadow transition-all">
                                <div class="card-body d-flex align-items-center gap-3 p-4">
                                    <a class="stretched-link" href="/jobs/<%= job.slug %>"></a>
                                    <div class="job-thumb flex-shrink-0 position-relative rounded overflow-hidden border">
                                        <% if (job.thumbnail_url) { %>
                                            <img src="<%= job.thumbnail_url %>" alt="<%= job.title %>">
                                        <% } else { %>
                                            <div class="w-100 h-100 bg-light d-flex align-items-center justify-content-center">
                                                <i class="bi bi-briefcase text-secondary"></i>
                                            </div>
                                        <% } %>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h5 class="card-title fw-bold mb-1"><%= job.title %></h5>
                                        <div class="d-flex gap-3 text-muted small flex-wrap">
                                            <span><i class="bi bi-building me-1"></i><%= companyName %></span>
                                            <span><i class="bi bi-geo-alt me-1"></i>Remote</span>
                                            <span><i class="bi bi-clock me-1"></i><%= job.created_at ? new Date(job.created_at).toLocaleDateString() : '' %></span>
                                            <span><i class="bi bi-eye me-1"></i><%= fmtViews(job.total_views) %></span>
                                        </div>
                                    </div>
                                    <div class="text-end d-none d-md-block">
                                        <span class="badge bg-light text-primary border border-primary-subtle fs-6 mb-2"><%= budgetLabel %></span>
                                        <br>
                                        <span class="badge <%= typeBadgeClass %>"><%= typeLabel %></span>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    </div>

                    <% const pager = (typeof pagination !== 'undefined' && pagination) ? pagination : null; %>
                    <% if (pager && pager.totalPages && pager.totalPages > 1) { %>
                        <nav class="mt-4" aria-label="Category jobs pagination">
                            <ul class="pagination justify-content-center">
                                <li class="page-item <%= pager.page <= 1 ? 'disabled' : '' %>">
                                    <a class="page-link" href="/categories/<%= category.slug %>?page=<%= pager.page - 1 %>">Previous</a>
                                </li>

                                <% for (let p = 1; p <= pager.totalPages; p++) { %>
                                    <li class="page-item <%= p === pager.page ? 'active' : '' %>">
                                        <a class="page-link" href="/categories/<%= category.slug %>?page=<%= p %>"><%= p %></a>
                                    </li>
                                <% } %>

                                <li class="page-item <%= pager.page >= pager.totalPages ? 'disabled' : '' %>">
                                    <a class="page-link" href="/categories/<%= category.slug %>?page=<%= pager.page + 1 %>">Next</a>
                                </li>
                            </ul>
                        </nav>
                    <% } %>
                </div>
            </section>
        </main>

        <%- include('../public/footer') %>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
</body>

</html>
