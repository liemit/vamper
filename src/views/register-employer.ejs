<!DOCTYPE html>
<html lang="<%= (typeof lang !== 'undefined' && lang) ? String(lang) : 'en' %>">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= (typeof t === 'function') ? t('auth.employer_signup_page_title', 'Vamper - Sign Up (Employer / Client)') : 'Vamper - Sign Up (Employer / Client)' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="style.css">
</head>

<body>
    <%- include('../public/header') %>

    <main>
        <section class="py-5">
            <div class="container">
                <div class="row justify-content-center">
                    <div class="col-12 col-md-10 col-lg-6">
                        <div class="card border-0 shadow-sm rounded-4">
                            <div class="card-body p-4 p-md-5">
                                <div class="d-flex align-items-center justify-content-between mb-4">
                                    <div>
                                        <h3 class="fw-bold mb-1"><%= (typeof t === 'function') ? t('auth.create_account', 'Create account') : 'Create account' %></h3>
                                        <div class="text-muted"><%= (typeof t === 'function') ? t('auth.employer_client', 'Employer / Client') : 'Employer / Client' %></div>
                                    </div>

                                    <div class="bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center"
                                        style="width: 44px; height: 44px;">
                                        <i class="bi bi-building-add fs-4"></i>
                                    </div>
                                </div>

                                <% 
                                    const pageQuery = (typeof query !== 'undefined' && query) ? query : {}; 
                                    const rawError = (pageQuery && pageQuery.error) ? String(pageQuery.error) : ''; 
                                    let errorMessage = '';

                                    if (rawError) {
                                        if (rawError === 'invalid_email_format') { errorMessage = (typeof t === 'function') ? t('auth.errors.invalid_email_format', 'Invalid email format.') : 'Invalid email format.'; }
                                        else if (rawError === 'password_too_short') { errorMessage = (typeof t === 'function') ? t('auth.errors.password_too_short', 'Password must be at least 6 characters.') : 'Password must be at least 6 characters.'; }
                                        else if (rawError === 'password_mismatch') { errorMessage = (typeof t === 'function') ? t('auth.errors.password_mismatch', 'Passwords do not match.') : 'Passwords do not match.'; }
                                        else if (rawError === 'email_exists') { errorMessage = (typeof t === 'function') ? t('auth.errors.email_exists', 'This email is already registered.') : 'This email is already registered.'; }
                                        else if (rawError === 'company_name_required') { errorMessage = (typeof t === 'function') ? t('auth.errors.company_name_required', 'Company name is required.') : 'Company name is required.'; }
                                        else if (rawError === 'invalid_role') { errorMessage = (typeof t === 'function') ? t('auth.errors.invalid_role_generic', 'Invalid role.') : 'Invalid role.'; }
                                        else if (rawError === 'captcha_required') { errorMessage = 'Please complete the captcha.'; }
                                        else if (rawError === 'captcha_failed') { errorMessage = 'Captcha verification failed. Please try again.'; }
                                        else if (rawError === 'captcha_error') { errorMessage = 'Captcha error. Please try again.'; }
                                        else { errorMessage = rawError; }
                                    }
                                %>

                                <% if (errorMessage) { %>
                                    <div class="alert alert-danger" role="alert">
                                        <%= errorMessage %>
                                    </div>
                                <% } %>

                                <form method="post" action="/register">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <input type="hidden" name="role" value="employer">

                                    <div class="mb-3">
                                        <label class="form-label fw-semibold"><%= (typeof t === 'function') ? t('auth.company_name', 'Company name') : 'Company name' %></label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-white"><i
                                                    class="bi bi-building"></i></span>
                                            <input type="text" class="form-control" name="company_name"
                                                placeholder="<%= (typeof t === 'function') ? t('auth.company_name_placeholder', 'Your company') : 'Your company' %>" required>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-semibold"><%= (typeof t === 'function') ? t('auth.company_email', 'Company email') : 'Company email' %></label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-white"><i
                                                    class="bi bi-envelope"></i></span>
                                            <input type="email" class="form-control" name="email"
                                                placeholder="<%= (typeof t === 'function') ? t('auth.company_email_placeholder', 'hr@company.com') : 'hr@company.com' %>" required>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-semibold"><%= (typeof t === 'function') ? t('auth.password', 'Password') : 'Password' %></label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-white"><i
                                                    class="bi bi-lock"></i></span>
                                            <input type="password" class="form-control" name="password"
                                                placeholder="<%= (typeof t === 'function') ? t('auth.password_placeholder', '••••••••') : '••••••••' %>" required>
                                        </div>
                                    </div>

                                    <div class="mb-4">
                                        <label class="form-label fw-semibold"><%= (typeof t === 'function') ? t('auth.confirm_password', 'Confirm password') : 'Confirm password' %></label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-white"><i
                                                    class="bi bi-shield-lock"></i></span>
                                            <input type="password" class="form-control" name="password_confirmation"
                                                placeholder="<%= (typeof t === 'function') ? t('auth.password_placeholder', '••••••••') : '••••••••' %>" required>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <div class="h-captcha" data-sitekey="<%= hcaptchaSiteKey %>"></div>
                                    </div>

                                    <button type="submit" class="btn btn-primary w-100 fw-semibold py-2"><%= (typeof t === 'function') ? t('auth.sign_up', 'Sign up') : 'Sign up' %></button>

                                    <div class="text-center mt-4">
                                        <span class="text-muted"><%= (typeof t === 'function') ? t('auth.already_have_account', 'Already have an account?') : 'Already have an account?' %></span>
                                        <a class="text-decoration-none fw-semibold" href="/login?role=employer"><%= (typeof t === 'function') ? t('auth.sign_in', 'Sign in') : 'Sign in' %></a>
                                    </div>

                                    <div class="text-center mt-2">
                                        <span class="text-muted"><%= (typeof t === 'function') ? t('auth.are_you_freelancer', 'Are you a Freelancer?') : 'Are you a Freelancer?' %></span>
                                        <a class="text-decoration-none fw-semibold"
                                            href="/register?role=freelancer"><%= (typeof t === 'function') ? t('auth.create_freelancer_account', 'Create Freelancer account') : 'Create Freelancer account' %></a>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <%- include('../public/footer') %>
    <script src="https://js.hcaptcha.com/1/api.js" async defer></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
        crossorigin="anonymous"></script>
</body>

</html>