
<!DOCTYPE html>
<html lang="<%= (typeof lang !== 'undefined' && lang) ? String(lang) : 'en' %>">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact - Vamper</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/style.css">
    <style>
        .contact-hero {
            background: radial-gradient(1000px circle at 15% 10%, rgba(13, 110, 253, 0.14), transparent 60%),
                radial-gradient(900px circle at 85% 0%, rgba(214, 51, 132, 0.10), transparent 60%),
                linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
            border-bottom: 1px solid rgba(15, 23, 42, 0.08);
        }

        .contact-card {
            border: 1px solid rgba(15, 23, 42, 0.08);
        }

        .contact-icon {
            width: 44px;
            height: 44px;
            border-radius: 14px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: rgba(13, 110, 253, 0.10);
            color: #0d6efd;
        }
    </style>
</head>

<body>
    <%- include('../public/header') %>

    <section class="contact-hero py-4 py-lg-5">
        <div class="container">
            <div class="row g-3 align-items-end">
                <div class="col-lg-8">
                    <div class="d-flex align-items-center gap-2 text-primary fw-semibold mb-2">
                        <i class="bi bi-envelope"></i>
                        <span><%= (typeof t === 'function') ? t('contact.hero_label', 'Contact') : 'Contact' %></span>
                    </div>
                    <h1 class="display-6 fw-bold mb-2"><%= (typeof t === 'function') ? t('contact.hero_title', 'Contact') : 'Contact' %></h1>
                    <div class="text-muted"><%= (typeof t === 'function') ? t('contact.hero_desc', 'Send questions or feedback, and the Vamper team will respond as soon as possible.') : 'Send questions or feedback, and the Vamper team will respond as soon as possible.' %></div>
                </div>
                <div class="col-lg-4">
                    <div class="text-lg-end">
                        <a href="/policy" class="btn btn-outline-primary"><%= (typeof t === 'function') ? t('contact.view_policy', 'View Policy') : 'View Policy' %></a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <main class="py-4 bg-light">
        <div class="container">
            <div class="row g-3 g-lg-4">
                <div class="col-12 col-lg-5">
                    <div class="d-grid gap-3">
                        <div class="card contact-card border-0 shadow-sm">
                            <div class="card-body p-3 p-lg-4">
                                <div class="d-flex align-items-start gap-3">
                                    <div class="contact-icon"><i class="bi bi-envelope"></i></div>
                                    <div>
                                        <div class="fw-bold"><%= (typeof t === 'function') ? t('contact.email_label', 'Email') : 'Email' %></div>
                                        <div class="text-muted">support@vamper.com</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card contact-card border-0 shadow-sm">
                            <div class="card-body p-3 p-lg-4">
                                <div class="d-flex align-items-start gap-3">
                                    <div class="contact-icon"><i class="bi bi-telephone"></i></div>
                                    <div>
                                        <div class="fw-bold"><%= (typeof t === 'function') ? t('contact.hotline_label', 'Hotline') : 'Hotline' %></div>
                                        <div class="text-muted">0900 000 000</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card contact-card border-0 shadow-sm">
                            <div class="card-body p-3 p-lg-4">
                                <div class="d-flex align-items-start gap-3">
                                    <div class="contact-icon"><i class="bi bi-geo-alt"></i></div>
                                    <div>
                                        <div class="fw-bold"><%= (typeof t === 'function') ? t('contact.address_label', 'Address') : 'Address' %></div>
                                        <div class="text-muted">Ho Chi Minh City, Vietnam</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-lg-7">
                    <div class="card contact-card border-0 shadow-sm">
                        <div class="card-body p-3 p-lg-4">
                            <div class="fw-bold mb-1"><%= (typeof t === 'function') ? t('contact.form_title', 'Send a message') : 'Send a message' %></div>
                            <div class="text-muted mb-3"><%= (typeof t === 'function') ? t('contact.form_subtitle', 'We usually reply within 24–48 hours.') : 'We usually reply within 24–48 hours.' %></div>

                            <% if (success_msg && success_msg.length) { %>
                                <div class="alert alert-success" role="alert"><%= success_msg[0] %></div>
                            <% } %>
                            <% if (error_msg && error_msg.length) { %>
                                <div class="alert alert-danger" role="alert"><%= error_msg[0] %></div>
                            <% } %>

                            <form method="POST" action="/contact">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label"><%= (typeof t === 'function') ? t('contact.full_name', 'Full name') : 'Full name' %></label>
                                        <input name="full_name" type="text" class="form-control" placeholder="<%= (typeof t === 'function') ? t('contact.full_name_placeholder', 'Your name') : 'Your name' %>">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label"><%= (typeof t === 'function') ? t('contact.email', 'Email') : 'Email' %></label>
                                        <input name="email" type="email" class="form-control" placeholder="<%= (typeof t === 'function') ? t('contact.email_placeholder', 'name@example.com') : 'name@example.com' %>">
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label"><%= (typeof t === 'function') ? t('contact.subject', 'Subject') : 'Subject' %></label>
                                        <input name="subject" type="text" class="form-control" placeholder="<%= (typeof t === 'function') ? t('contact.subject_placeholder', 'How can we help?') : 'How can we help?' %>">
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label"><%= (typeof t === 'function') ? t('contact.message', 'Message') : 'Message' %></label>
                                        <textarea name="message" class="form-control" rows="6" placeholder="<%= (typeof t === 'function') ? t('contact.message_placeholder', 'Write your message...') : 'Write your message...' %>"></textarea>
                                    </div>
                                    <div class="col-12">
                                        <button type="submit" class="btn btn-primary fw-semibold"><%= (typeof t === 'function') ? t('contact.send', 'Send') : 'Send' %></button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <%- include('../public/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
        crossorigin="anonymous"></script>
</body>

</html>
