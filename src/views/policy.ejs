
<!DOCTYPE html>
<html lang="<%= (typeof lang !== 'undefined' && lang) ? String(lang) : 'en' %>">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Platform Policy - Vamper</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/style.css">
    <style>
        .policy-hero {
            background: radial-gradient(1000px circle at 15% 10%, rgba(13, 110, 253, 0.14), transparent 60%),
                radial-gradient(900px circle at 80% 0%, rgba(25, 135, 84, 0.10), transparent 60%),
                linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
            border-bottom: 1px solid rgba(15, 23, 42, 0.08);
        }

        .policy-toc {
            position: sticky;
            top: 84px;
        }

        .policy-toc a {
            text-decoration: none;
        }

        .policy-section {
            scroll-margin-top: 96px;
        }
    </style>
</head>

<body>
    <%- include('../public/header') %>

    <section class="policy-hero py-4 py-lg-5">
        <div class="container">
            <div class="row g-3 align-items-end">
                <div class="col-lg-8">
                    <div class="d-flex align-items-center gap-2 text-primary fw-semibold mb-2">
                        <i class="bi bi-shield-check"></i>
                        <span><%= (typeof t === 'function') ? t('policy.hero_label', 'Platform Policy') : 'Platform Policy' %></span>
                    </div>
                    <h1 class="display-6 fw-bold mb-2"><%= (typeof t === 'function') ? t('policy.hero_title', 'Platform Policy') : 'Platform Policy' %></h1>
                    <div class="text-muted"><%= (typeof t === 'function') ? t('policy.hero_desc', 'Core principles to keep Vamper safe, transparent, and fair for all users.') : 'Core principles to keep Vamper safe, transparent, and fair for all users.' %></div>
                </div>
                <div class="col-lg-4">
                    <div class="text-lg-end text-muted small">
                        <%= (typeof t === 'function') ? t('policy.last_updated_label', 'Last updated:') : 'Last updated:' %> <span class="fw-semibold text-dark">2026-02-15</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <main class="py-4 bg-light">
        <div class="container">
            <div class="row g-3 g-lg-4">
                <aside class="col-12 col-lg-4 col-xl-3">
                    <div class="card border-0 shadow-sm policy-toc">
                        <div class="card-body p-3 p-lg-4">
                            <div class="fw-bold mb-3"><%= (typeof t === 'function') ? t('policy.toc_title', 'Table of contents') : 'Table of contents' %></div>
                            <div class="list-group list-group-flush">
                                <a class="list-group-item list-group-item-action" href="#terms">
                                    <i class="bi bi-file-earmark-text me-2"></i><%= (typeof t === 'function') ? t('policy.toc_terms', 'Terms of use') : 'Terms of use' %>
                                </a>
                                <a class="list-group-item list-group-item-action" href="#privacy">
                                    <i class="bi bi-lock me-2"></i><%= (typeof t === 'function') ? t('policy.toc_privacy', 'Privacy & data') : 'Privacy & data' %>
                                </a>
                                <a class="list-group-item list-group-item-action" href="#payments">
                                    <i class="bi bi-credit-card me-2"></i><%= (typeof t === 'function') ? t('policy.toc_payments', 'Payments & refunds') : 'Payments & refunds' %>
                                </a>
                                <a class="list-group-item list-group-item-action" href="#content">
                                    <i class="bi bi-exclamation-triangle me-2"></i><%= (typeof t === 'function') ? t('policy.toc_content', 'Prohibited content') : 'Prohibited content' %>
                                </a>
                                <a class="list-group-item list-group-item-action" href="#disputes">
                                    <i class="bi bi-chat-dots me-2"></i><%= (typeof t === 'function') ? t('policy.toc_disputes', 'Disputes & reports') : 'Disputes & reports' %>
                                </a>
                                <a class="list-group-item list-group-item-action" href="#contact">
                                    <i class="bi bi-envelope me-2"></i><%= (typeof t === 'function') ? t('policy.toc_contact', 'Support contact') : 'Support contact' %>
                                </a>
                            </div>
                        </div>
                    </div>
                </aside>

                <section class="col-12 col-lg-8 col-xl-9">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body p-3 p-lg-4">
                            <div class="alert alert-info mb-4">
                                <div class="fw-semibold mb-1"><%= (typeof t === 'function') ? t('policy.hint_title', 'Editing tip') : 'Editing tip' %></div>
                                <div class="small"><%= (typeof t === 'function') ? t('policy.hint_desc', 'You can adjust each section below to match the platform’s actual policy.') : 'You can adjust each section below to match the platform’s actual policy.' %></div>
                            </div>

                            <section id="terms" class="policy-section mb-4">
                                <h2 class="h5 fw-bold"><%= (typeof t === 'function') ? t('policy.s1_title', '1) Terms of use') : '1) Terms of use' %></h2>
                                <div class="text-muted">
                                    <%= (typeof t === 'function') ? t('policy.s1_desc', 'Vamper provides a platform connecting employers and freelancers/IT students. By using the platform, you agree to comply with the following rules:') : 'Vamper provides a platform connecting employers and freelancers/IT students. By using the platform, you agree to comply with the following rules:' %>
                                </div>
                                <ul class="mt-2 mb-0">
                                    <li><%= (typeof t === 'function') ? t('policy.s1_li1', 'Accounts must provide accurate information and must not impersonate others.') : 'Accounts must provide accurate information and must not impersonate others.' %></li>
                                    <li><%= (typeof t === 'function') ? t('policy.s1_li2', 'Do not use the platform for scams or to harm others.') : 'Do not use the platform for scams or to harm others.' %></li>
                                    <li><%= (typeof t === 'function') ? t('policy.s1_li3', 'Vamper may suspend or terminate accounts if violations are detected.') : 'Vamper may suspend or terminate accounts if violations are detected.' %></li>
                                </ul>
                            </section>

                            <section id="privacy" class="policy-section mb-4">
                                <h2 class="h5 fw-bold"><%= (typeof t === 'function') ? t('policy.s2_title', '2) Privacy & data') : '2) Privacy & data' %></h2>
                                <div class="text-muted"><%= (typeof t === 'function') ? t('policy.s2_desc', 'We collect only the necessary data to operate the service and improve user experience.') : 'We collect only the necessary data to operate the service and improve user experience.' %></div>
                                <ul class="mt-2 mb-0">
                                    <li><%= (typeof t === 'function') ? t('policy.s2_li1', 'Personal data (email, profile) is stored for verification and to support transactions.') : 'Personal data (email, profile) is stored for verification and to support transactions.' %></li>
                                    <li><%= (typeof t === 'function') ? t('policy.s2_li2', 'We do not share personal information with third parties unless legally required.') : 'We do not share personal information with third parties unless legally required.' %></li>
                                    <li><%= (typeof t === 'function') ? t('policy.s2_li3', 'You may request data correction or deletion in accordance with regulations.') : 'You may request data correction or deletion in accordance with regulations.' %></li>
                                </ul>
                            </section>

                            <section id="payments" class="policy-section mb-4">
                                <h2 class="h5 fw-bold"><%= (typeof t === 'function') ? t('policy.s3_title', '3) Payments & refunds') : '3) Payments & refunds' %></h2>
                                <div class="text-muted"><%= (typeof t === 'function') ? t('policy.s3_desc', 'Payments/refunds depend on contract status and the confirmation process of the parties involved.') : 'Payments/refunds depend on contract status and the confirmation process of the parties involved.' %></div>
                                <ul class="mt-2 mb-0">
                                    <li><%= (typeof t === 'function') ? t('policy.s3_li1', 'Service fees (if any) will be clearly displayed before payment.') : 'Service fees (if any) will be clearly displayed before payment.' %></li>
                                    <li><%= (typeof t === 'function') ? t('policy.s3_li2', 'Refunds apply only when a transaction qualifies under the policy.') : 'Refunds apply only when a transaction qualifies under the policy.' %></li>
                                    <li><%= (typeof t === 'function') ? t('policy.s3_li3', 'Transactions may be delayed if fraud risks are detected.') : 'Transactions may be delayed if fraud risks are detected.' %></li>
                                </ul>
                            </section>

                            <section id="content" class="policy-section mb-4">
                                <h2 class="h5 fw-bold"><%= (typeof t === 'function') ? t('policy.s4_title', '4) Prohibited content') : '4) Prohibited content' %></h2>
                                <div class="text-muted"><%= (typeof t === 'function') ? t('policy.s4_desc', 'It is strictly prohibited to post or exchange the following content on Vamper:') : 'It is strictly prohibited to post or exchange the following content on Vamper:' %></div>
                                <ul class="mt-2 mb-0">
                                    <li><%= (typeof t === 'function') ? t('policy.s4_li1', 'Illegal content, hate incitement, or violence.') : 'Illegal content, hate incitement, or violence.' %></li>
                                    <li><%= (typeof t === 'function') ? t('policy.s4_li2', '18+ or sensitive content that is not suitable for a learning/working environment.') : '18+ or sensitive content that is not suitable for a learning/working environment.' %></li>
                                    <li><%= (typeof t === 'function') ? t('policy.s4_li3', 'Scam/phishing links, malware, or instructions for unauthorized intrusion.') : 'Scam/phishing links, malware, or instructions for unauthorized intrusion.' %></li>
                                </ul>
                            </section>

                            <section id="disputes" class="policy-section mb-4">
                                <h2 class="h5 fw-bold"><%= (typeof t === 'function') ? t('policy.s5_title', '5) Disputes & reports') : '5) Disputes & reports' %></h2>
                                <div class="text-muted"><%= (typeof t === 'function') ? t('policy.s5_desc', 'If issues arise, prioritize communication between parties. If unresolved, you can submit a report for Vamper to assist.') : 'If issues arise, prioritize communication between parties. If unresolved, you can submit a report for Vamper to assist.' %></div>
                                <ul class="mt-2 mb-0">
                                    <li><%= (typeof t === 'function') ? t('policy.s5_li1', 'Provide evidence (messages, files, timestamps) for faster handling.') : 'Provide evidence (messages, files, timestamps) for faster handling.' %></li>
                                    <li><%= (typeof t === 'function') ? t('policy.s5_li2', 'Vamper may restrict accounts if fraudulent behavior is detected.') : 'Vamper may restrict accounts if fraudulent behavior is detected.' %></li>
                                </ul>
                            </section>

                            <section id="contact" class="policy-section">
                                <h2 class="h5 fw-bold"><%= (typeof t === 'function') ? t('policy.s6_title', '6) Support contact') : '6) Support contact' %></h2>
                                <div class="text-muted"><%= (typeof t === 'function') ? t('policy.s6_desc', 'If you need support, please contact:') : 'If you need support, please contact:' %></div>
                                <div class="mt-2">
                                    <div><span class="fw-semibold"><%= (typeof t === 'function') ? t('policy.email_label', 'Email:') : 'Email:' %></span> support@vamper.com</div>
                                    <div><span class="fw-semibold"><%= (typeof t === 'function') ? t('policy.hotline_label', 'Hotline:') : 'Hotline:' %></span> 0900 000 000</div>
                                </div>
                            </section>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </main>

    <%- include('../public/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
        crossorigin="anonymous"></script>
</body>

</html>
