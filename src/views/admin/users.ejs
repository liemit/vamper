<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vamper - User Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/style.css">

    <style>
                .admin-page main { background: linear-gradient(180deg, #f6f8fc 0%, #f0f7ff 100%); }
        .admin-page .card { border: 1px solid #eef2f7; }
        .admin-page .admin-sidebar { background-color: #ffffff !important; }
        /* Add other common admin styles if necessary */
    </style>
</head>
<body class="admin-page">
    <%- include('../../public/header') %>

    <main class="container-fluid py-3 py-md-4">
        <div class="row g-0">
            <aside class="col-12 col-md-3 col-lg-2 pe-md-3 mb-3 mb-md-0">
                <%- include('layouts/menu') %>
            </aside>

            <section class="col-12 col-md-9 col-lg-10 ps-md-0">
                <div class="card border-0 shadow-sm rounded-4 mb-3">
                    <div class="card-body py-3 px-3 px-md-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-2">
                                <button class="btn btn-sm btn-outline-secondary d-md-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#adminSidebar">
                                    <i class="bi bi-list"></i>
                                </button>
                                <div class="rounded-3 d-flex align-items-center justify-content-center" style="width: 34px; height: 34px; background: #e7f1ff; color: #0d6efd;">
                                    <i class="bi bi-people"></i>
                                </div>
                                <div>
                                    <div class="fw-bold">User Management</div>
                                    <div class="text-muted small">Manage system users</div>
                                </div>
                            </div>
                            <a href="/admin/users/create" class="btn btn-primary btn-sm"><i class="bi bi-plus"></i> Add User</a>
                        </div>
                    </div>
                </div>

                <% if(success_msg && success_msg.length > 0){ %>
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <%= success_msg %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>
                <% if(error_msg && error_msg.length > 0){ %>
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <%= error_msg %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>

                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-body px-3 px-md-4">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Name</th>
                                        <th>Email</th>
                                        <th>Role</th>
                                        <th>Balance</th>
                                        <th>Status</th>
                                        <th>Joined</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (users && users.length > 0) { %>
                                        <% users.forEach(u => { %>
                                            <tr>
                                                <td><%= u.id %></td>
                                                <td><%= u.full_name || 'N/A' %></td>
                                                <td><%= u.email %></td>
                                                <td><span class="badge bg-secondary text-capitalize"><%= u.role %></span></td>
                                                <td><i class="bi bi-gem text-primary"></i> <%= parseFloat(u.balance || 0).toFixed(2) %></td>
                                                <td>
                                                    <% if (u.is_active) { %>
                                                        <span class="badge bg-success">Active</span>
                                                    <% } else { %>
                                                        <span class="badge bg-danger">Blocked</span>
                                                    <% } %>
                                                </td>
                                                <td><%= new Date(u.created_at).toLocaleDateString() %></td>
                                                <td>
                                                    <div class="d-flex gap-2">
                                                        <a href="/admin/users/edit/<%= u.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                                        <% if (u.is_active) { %>
                                                            <form action="/admin/users/block/<%= u.id %>" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to block this user?');">
                                                                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                                                                <button type="submit" class="btn btn-sm btn-outline-warning" title="Block User"><i class="bi bi-ban"></i></button>
                                                            </form>
                                                        <% } else { %>
                                                            <form action="/admin/users/unblock/<%= u.id %>" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to unblock this user?');">
                                                                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                                                                <button type="submit" class="btn btn-sm btn-outline-success" title="Unblock User"><i class="bi bi-check-circle"></i></button>
                                                            </form>
                                                        <% } %>
                                                        <form action="/admin/users/delete/<%= u.id %>" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this user completely? This cannot be undone.');">
                                                            <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete User"><i class="bi bi-trash"></i></button>
                                                        </form>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr><td colspan="8" class="text-center text-muted">No users found.</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>

                        <% if (pagination && pagination.totalPages > 1) { %>
                        <div class="d-flex justify-content-between align-items-center px-3 py-3 border-top">
                            <div class="text-muted small">Total: <%= pagination.total %> users</div>
                            <nav>
                                <ul class="pagination pagination-sm mb-0">
                                    <li class="page-item <%= pagination.page <= 1 ? 'disabled' : '' %>">
                                        <a class="page-link" href="/admin/users?page=<%= pagination.page - 1 %>">Previous</a>
                                    </li>
                                    <% for (let i = 1; i <= pagination.totalPages; i++) { %>
                                        <li class="page-item <%= i === pagination.page ? 'active' : '' %>">
                                            <a class="page-link" href="/admin/users?page=<%= i %>"><%= i %></a>
                                        </li>
                                    <% } %>
                                    <li class="page-item <%= pagination.page >= pagination.totalPages ? 'disabled' : '' %>">
                                        <a class="page-link" href="/admin/users?page=<%= pagination.page + 1 %>">Next</a>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                        <% } %>

                    </div>
                </div>
            </section>
        </div>
    </main>
    <%- include('../../public/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>