<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Categories - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/style.css">
    <style>
        .admin-page main { background: linear-gradient(180deg, #f6f8fc 0%, #f0f7ff 100%); }
        .admin-sidebar { background-color: #ffffff !important; }
    </style>
</head>
<body class="admin-page bg-light">
    <%- include('../../public/header') %>
    <main class="container-fluid py-3 py-md-4">
        <div class="row g-0">
            <aside class="col-12 col-md-3 col-lg-2 pe-md-3 mb-3 mb-md-0">
                <%- include('layouts/menu') %>
            </aside>
            <section class="col-12 col-md-9 col-lg-10 ps-md-0">
                <div class="d-flex align-items-center justify-content-between pt-2 pb-3 mb-3 border-bottom">
                    <h4 class="fw-bold mb-0">Categories</h4>
                </div>

                <% if (success_msg && success_msg.length > 0) { %>
                    <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle-fill me-2"></i><%= success_msg %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
                <% } %>
                <% if (error_msg && error_msg.length > 0) { %>
                    <div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-triangle-fill me-2"></i><%= error_msg %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
                <% } %>

                <div class="row g-4">
                    <!-- Add new category -->
                    <div class="col-12 col-lg-4">
                        <div class="card border-0 shadow-sm rounded-4">
                            <div class="card-body p-4">
                                <h6 class="fw-bold mb-3">Add New Category</h6>
                                <form method="POST" action="/admin/categories/store">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <div class="mb-3">
                                        <label class="form-label small fw-semibold">Name</label>
                                        <input type="text" name="name" class="form-control" placeholder="e.g. Web Development" required>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label small fw-semibold">Slug</label>
                                        <input type="text" name="slug" id="slugInput" class="form-control" placeholder="e.g. web-development" required>
                                        <div class="form-text">Auto-generated from name, or enter manually.</div>
                                    </div>
                                    <button type="submit" class="btn btn-primary w-100"><i class="bi bi-plus-circle me-1"></i>Add Category</button>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Category list -->
                    <div class="col-12 col-lg-8">
                        <div class="card border-0 shadow-sm rounded-4">
                            <div class="card-body p-0">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="ps-4">ID</th>
                                            <th>Name</th>
                                            <th>Slug</th>
                                            <th>Jobs</th>
                                            <th class="pe-4">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (!categories.length) { %>
                                            <tr><td colspan="5" class="text-center text-muted py-4">No categories found.</td></tr>
                                        <% } %>
                                        <% categories.forEach(cat => { %>
                                        <tr>
                                            <td class="ps-4 text-muted small">#<%= cat.id %></td>
                                            <td>
                                                <% if (editId == cat.id) { %>
                                                    <form method="POST" action="/admin/categories/<%= cat.id %>/update" class="d-flex gap-2">
                                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                        <input type="text" name="name" class="form-control form-control-sm" value="<%= cat.name %>" required style="width:140px;">
                                                        <input type="text" name="slug" class="form-control form-control-sm" value="<%= cat.slug %>" required style="width:140px;">
                                                        <button type="submit" class="btn btn-sm btn-success py-0 px-2"><i class="bi bi-check"></i></button>
                                                        <a href="/admin/categories" class="btn btn-sm btn-outline-secondary py-0 px-2"><i class="bi bi-x"></i></a>
                                                    </form>
                                                <% } else { %>
                                                    <span class="fw-semibold"><%= cat.name %></span>
                                                <% } %>
                                            </td>
                                            <td class="text-muted small font-monospace"><%= cat.slug %></td>
                                            <td><span class="badge bg-light text-dark border"><%= cat.job_count || 0 %></span></td>
                                            <td class="pe-4">
                                                <div class="d-flex gap-1">
                                                    <a href="/admin/categories?edit=<%= cat.id %>" class="btn btn-sm btn-outline-primary py-0 px-2"><i class="bi bi-pencil"></i></a>
                                                    <form method="POST" action="/admin/categories/<%= cat.id %>/delete" class="d-inline">
                                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-2"
                                                            onclick="return confirm('Delete category? Jobs in this category will lose their category.')"
                                                            <%= cat.job_count > 0 ? 'title="Has jobs — will unlink them"' : '' %>>
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </main>
    <%- include('../../public/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Auto-generate slug from name
        const nameInput = document.querySelector('input[name="name"]');
        const slugInput = document.getElementById('slugInput');
        if (nameInput && slugInput) {
            nameInput.addEventListener('input', function() {
                slugInput.value = this.value.toLowerCase()
                    .replace(/[^a-z0-9\s-]/g, '')
                    .trim().replace(/\s+/g, '-');
            });
        }
    </script>
</body>
</html>
