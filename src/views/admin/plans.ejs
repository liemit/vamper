<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Plans Management - Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/style.css">
    <style>
        .admin-page main {
            background: linear-gradient(180deg, #f6f8fc 0%, #f0f7ff 100%);
        }
        .admin-sidebar {
            background-color: #ffffff !important;
        }
        .kind-badge {
            width: 70px;
            display: inline-block;
        }
    </style>
</head>
<body class="admin-page bg-light">
    <%- include('../../public/header') %>

    <main class="container-fluid py-3 py-md-4">
        <div class="row g-0">
            <aside class="col-12 col-md-3 col-lg-2 pe-md-3 mb-3 mb-md-0">
                <%- include('layouts/menu') %>
            </aside>

            <section class="col-12 col-md-9 col-lg-10 ps-md-0">
                <nav aria-label="breadcrumb" class="mb-3">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
                        <li class="breadcrumb-item active">Plans</li>
                    </ol>
                </nav>

                <div class="d-flex align-items-center mb-4">
                    <div class="bg-success-subtle text-success rounded-circle p-3 me-3">
                        <i class="bi bi-layers fs-4"></i>
                    </div>
                    <h4 class="fw-bold mb-0">Plans Management</h4>
                </div>

                <% if (success_msg && success_msg.length > 0) { %>
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i><%= success_msg %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>
                <% if (error_msg && error_msg.length > 0) { %>
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error_msg %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>

                <div class="row g-4">
                    <% plans.forEach(function(plan) { %>
                        <%
                            const kinds = ['image', 'video', 'file'];
                            const kindIcons = { image: 'bi-image', video: 'bi-camera-video', file: 'bi-file-earmark' };
                            const kindColors = { image: 'primary', video: 'danger', file: 'warning' };
                        %>
                        <div class="col-12 col-xl-6">
                            <div class="card border-0 shadow-sm rounded-4 h-100">
                                <div class="card-header bg-transparent border-0 pt-4 pb-0 px-4">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="badge bg-secondary-subtle text-secondary font-monospace"><%= plan.code %></span>
                                            <% if (plan.is_active) { %>
                                                <span class="badge bg-success-subtle text-success">Active</span>
                                            <% } else { %>
                                                <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-body px-4 pb-4">
                                    <form action="/admin/plans/<%= plan.id %>/update" method="POST">
                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                                        <div class="row g-3 mb-4">
                                            <div class="col-7">
                                                <label class="form-label fw-semibold small text-muted">Plan Name</label>
                                                <input type="text" name="name" class="form-control" value="<%= plan.name %>" required>
                                            </div>
                                            <div class="col-5">
                                                <label class="form-label fw-semibold small text-muted">Price / Month ($)</label>
                                                <input type="number" name="price_monthly" class="form-control" value="<%= plan.price_monthly %>" min="0" step="0.01" required>
                                            </div>
                                        </div>

                                        <p class="fw-semibold small text-muted mb-2">Storage Limits</p>
                                        <div class="table-responsive mb-3">
                                            <table class="table table-sm align-middle mb-0">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th class="fw-semibold small">Kind</th>
                                                        <th class="fw-semibold small">Max File (MB)</th>
                                                        <th class="fw-semibold small">Monthly Quota (MB)</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% kinds.forEach(function(kind) { %>
                                                        <%
                                                            const limit = (plan.limits || []).find(l => l.kind === kind) || {};
                                                        %>
                                                        <tr>
                                                            <td>
                                                                <span class="badge bg-<%= kindColors[kind] %>-subtle text-<%= kindColors[kind] %> kind-badge">
                                                                    <i class="bi <%= kindIcons[kind] %> me-1"></i><%= kind %>
                                                                </span>
                                                            </td>
                                                            <td>
                                                                <input type="number"
                                                                    name="limit_<%= kind %>_max_file_mb"
                                                                    class="form-control form-control-sm"
                                                                    value="<%= limit.max_file_mb !== undefined ? limit.max_file_mb : '' %>"
                                                                    min="0" step="1" placeholder="0">
                                                            </td>
                                                            <td>
                                                                <input type="number"
                                                                    name="limit_<%= kind %>_monthly_quota_mb"
                                                                    class="form-control form-control-sm"
                                                                    value="<%= limit.monthly_quota_mb !== undefined ? limit.monthly_quota_mb : '' %>"
                                                                    min="0" step="1" placeholder="0">
                                                            </td>
                                                        </tr>
                                                    <% }); %>
                                                </tbody>
                                            </table>
                                        </div>

                                        <div class="d-flex justify-content-end">
                                            <button type="submit" class="btn btn-primary btn-sm px-4 fw-semibold">
                                                <i class="bi bi-save me-1"></i>Save
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>

            </section>
        </div>
    </main>

    <%- include('../../public/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
