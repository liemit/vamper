<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Transactions - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/style.css">
    <style>.admin-page main{background:linear-gradient(180deg,#f6f8fc 0%,#f0f7ff 100%)}.admin-sidebar{background-color:#fff!important}</style>
</head>
<body class="admin-page bg-light">
    <%- include('../../public/header') %>
    <main class="container-fluid py-3 py-md-4">
        <div class="row g-0">
            <aside class="col-12 col-md-3 col-lg-2 pe-md-3 mb-3 mb-md-0"><%- include('layouts/menu') %></aside>
            <section class="col-12 col-md-9 col-lg-10 ps-md-0">
                <div class="d-flex align-items-center justify-content-between pt-2 pb-3 mb-3 border-bottom">
                    <h4 class="fw-bold mb-0">Transactions</h4>
                    <span class="text-muted small">Total: <%= pagination.total %></span>
                </div>

                <!-- Summary cards -->
                <div class="row g-3 mb-3">
                    <div class="col-12"><div class="text-muted small">Completed transactions only</div></div>
                    <% const typeColors = {deposit:'success',withdrawal:'danger',payment:'primary',service_fee:'warning',refund:'info'}; %>
                    <% Object.entries(summary).forEach(([type, amount]) => { %>
                    <div class="col-6 col-lg-2">
                        <div class="card border-0 shadow-sm rounded-4 h-100">
                            <div class="card-body p-3">
                                <div class="text-muted small text-capitalize"><%= type.replace('_',' ') %></div>
                                <div class="fw-bold"><i class="bi bi-gem text-primary" style="font-size:0.75rem;"></i> <%= Number(amount||0).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2}) %></div>
                            </div>
                        </div>
                    </div>
                    <% }); %>
                </div>

                <!-- Filter -->
                <div class="card border-0 shadow-sm rounded-4 mb-3">
                    <div class="card-body py-2 px-3">
                        <form method="GET" action="/admin/transactions" class="d-flex gap-2 flex-wrap align-items-end">
                            <div>
                                <label class="form-label small mb-1">Type</label>
                                <select name="type" class="form-select form-select-sm" style="width:140px;">
                                    <option value="">All</option>
                                    <% ['deposit','withdrawal','payment','service_fee','refund'].forEach(t => { %>
                                        <option value="<%= t %>" <%= query.type === t ? 'selected' : '' %>><%= t.replace('_',' ') %></option>
                                    <% }); %>
                                </select>
                            </div>
                            <div>
                                <label class="form-label small mb-1">Status</label>
                                <select name="status" class="form-select form-select-sm" style="width:130px;">
                                    <option value="">All</option>
                                    <% ['completed','pending','failed','refunded'].forEach(s => { %>
                                        <option value="<%= s %>" <%= query.status === s ? 'selected' : '' %>><%= s %></option>
                                    <% }); %>
                                </select>
                            </div>
                            <div>
                                <label class="form-label small mb-1">Month</label>
                                <select name="month" class="form-select form-select-sm" style="width:110px;">
                                    <option value="">All</option>
                                    <% ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'].forEach((m,i) => { %>
                                        <option value="<%= i+1 %>" <%= query.month == i+1 ? 'selected' : '' %>><%= m %></option>
                                    <% }); %>
                                </select>
                            </div>
                            <div>
                                <label class="form-label small mb-1">Year</label>
                                <select name="year" class="form-select form-select-sm" style="width:90px;">
                                    <option value="">All</option>
                                    <% const cy = new Date().getFullYear(); for(let y=cy;y>=cy-3;y--){ %>
                                        <option value="<%= y %>" <%= query.year == y ? 'selected' : '' %>><%= y %></option>
                                    <% } %>
                                </select>
                            </div>
                            <div>
                                <label class="form-label small mb-1">Search user</label>
                                <input type="text" name="q" class="form-control form-control-sm" placeholder="Name or email..." value="<%= query.q || '' %>" style="width:180px;">
                            </div>
                            <button type="submit" class="btn btn-sm btn-primary">Filter</button>
                            <a href="/admin/transactions" class="btn btn-sm btn-outline-secondary">Reset</a>
                        </form>
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">ID</th>
                                        <th>User</th>
                                        <th>Type</th>
                                        <th>Amount</th>
                                        <th>Status</th>
                                        <th>Description</th>
                                        <th class="pe-4">Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (!transactions.length) { %><tr><td colspan="7" class="text-center text-muted py-4">No transactions found.</td></tr><% } %>
                                    <% transactions.forEach(tx => { %>
                                    <%
                                        const tc = {deposit:'success',withdrawal:'danger',payment:'primary',service_fee:'warning',refund:'info'}[tx.type] || 'secondary';
                                        const sc = {completed:'success',pending:'warning',failed:'danger',refunded:'secondary'}[tx.status] || 'secondary';
                                    %>
                                    <tr>
                                        <td class="ps-4 text-muted small">#<%= tx.id %></td>
                                        <td class="small">
                                            <div class="fw-semibold"><%= tx.full_name || 'N/A' %></div>
                                            <div class="text-muted" style="font-size:0.75rem;"><%= tx.email %></div>
                                        </td>
                                        <td><span class="badge bg-<%= tc %>-subtle text-<%= tc %>"><%= tx.type.replace('_',' ') %></span></td>
                                        <td class="fw-semibold small"><i class="bi bi-gem text-primary" style="font-size:0.7rem;"></i> <%= Number(tx.amount).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2}) %></td>
                                        <td><span class="badge bg-<%= sc %>-subtle text-<%= sc %>"><%= tx.status %></span></td>
                                        <td style="max-width:200px;"><div class="text-truncate small text-muted"><%= tx.description || '—' %></div></td>
                                        <td class="pe-4 text-muted small"><%= tx.created_at ? new Date(tx.created_at).toLocaleDateString() : '' %></td>
                                    </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                        <% if (pagination.totalPages > 1) { %>
                        <div class="d-flex justify-content-between align-items-center px-4 py-3 border-top">
                            <div class="text-muted small">Page <%= pagination.page %> of <%= pagination.totalPages %></div>
                            <nav><ul class="pagination pagination-sm mb-0">
                                <li class="page-item <%= pagination.page<=1?'disabled':'' %>"><a class="page-link" href="?type=<%= query.type %>&status=<%= query.status %>&month=<%= query.month %>&year=<%= query.year %>&q=<%= query.q %>&page=<%= pagination.page-1 %>">Prev</a></li>
                                <% for(let i=Math.max(1,pagination.page-2);i<=Math.min(pagination.totalPages,pagination.page+2);i++){%>
                                    <li class="page-item <%=i===pagination.page?'active':''%>"><a class="page-link" href="?type=<%= query.type %>&status=<%= query.status %>&month=<%= query.month %>&year=<%= query.year %>&q=<%= query.q %>&page=<%= i %>"><%= i %></a></li>
                                <%}%>
                                <li class="page-item <%= pagination.page>=pagination.totalPages?'disabled':'' %>"><a class="page-link" href="?type=<%= query.type %>&status=<%= query.status %>&month=<%= query.month %>&year=<%= query.year %>&q=<%= query.q %>&page=<%= pagination.page+1 %>">Next</a></li>
                            </ul></nav>
                        </div>
                        <% } %>
                    </div>
                </div>
            </section>
        </div>
    </main>
    <%- include('../../public/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
