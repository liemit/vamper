<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vamper - Analytics Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/style.css">

    <style>
                .admin-page main { background: linear-gradient(180deg, #f6f8fc 0%, #f0f7ff 100%); }
        .admin-page .card { border: 1px solid #eef2f7; }
        .admin-page .admin-sidebar { background-color: #ffffff !important; }
        .stat-card { transition: transform 0.2s ease-in-out; }
        .stat-card:hover { transform: translateY(-5px); }
        .icon-box { width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; border-radius: 12px; }
    </style>
</head>
<body class="admin-page">
    <%- include('../../public/header') %>

    <main class="container-fluid py-3 py-md-4">
        <div class="row g-0">
            <aside class="col-12 col-md-3 col-lg-2 pe-md-3 mb-3 mb-md-0">
                <%- include('layouts/menu') %>
            </aside>

            <section class="col-12 col-md-9 col-lg-10 ps-md-0">
                <!-- Header -->
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-body py-3 px-3 px-md-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-2">
                                <button class="btn btn-sm btn-outline-secondary d-md-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#adminSidebar">
                                    <i class="bi bi-list"></i>
                                </button>
                                <div class="rounded-3 d-flex align-items-center justify-content-center" style="width: 34px; height: 34px; background: #e7f1ff; color: #0d6efd;">
                                    <i class="bi bi-graph-up"></i>
                                </div>
                                <div>
                                    <div class="fw-bold">Platform Analytics</div>
                                    <div class="text-muted small">Real-time statistics and platform overview</div>
                                </div>
                            </div>
                            <button class="btn btn-primary btn-sm" onclick="window.location.reload()"><i class="bi bi-arrow-clockwise"></i> Refresh</button>
                        </div>
                    </div>
                </div>

                <!-- Month/Year Filter -->
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-body py-2 px-3">
                        <form method="GET" action="/admin/analytics" class="d-flex align-items-center gap-2 flex-wrap">
                            <span class="text-muted small fw-semibold">Filter Finance by:</span>
                            <select name="month" class="form-select form-select-sm" style="width:130px;">
                                <% const months = ['January','February','March','April','May','June','July','August','September','October','November','December']; %>
                                <% months.forEach((m, i) => { %>
                                    <option value="<%= i+1 %>" <%= (typeof selectedMonth !== 'undefined' && selectedMonth === i+1) ? 'selected' : '' %>><%= m %></option>
                                <% }); %>
                            </select>
                            <select name="year" class="form-select form-select-sm" style="width:100px;">
                                <% const curYear = new Date().getFullYear(); %>
                                <% for (let y = curYear; y >= curYear - 3; y--) { %>
                                    <option value="<%= y %>" <%= (typeof selectedYear !== 'undefined' && selectedYear === y) ? 'selected' : '' %>><%= y %></option>
                                <% } %>
                            </select>
                            <button type="submit" class="btn btn-sm btn-primary">Apply</button>
                            <a href="/admin/analytics" class="btn btn-sm btn-outline-secondary">All-time</a>
                            <% if (typeof isFiltered !== 'undefined' && isFiltered) { %>
                                <span class="badge bg-info-subtle text-info">
                                    Showing: <%= months[(selectedMonth||1)-1] %> <%= selectedYear %>
                                </span>
                            <% } %>
                        </form>
                    </div>
                </div>
                <div class="row g-3 mb-4">
                    <!-- Total Users -->
                    <div class="col-12 col-md-6 col-xl-3">
                        <div class="card stat-card border-0 shadow-sm rounded-4 h-100">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div class="text-muted fw-semibold">Total Users</div>
                                    <div class="icon-box bg-primary bg-opacity-10 text-primary">
                                        <i class="bi bi-people fs-4"></i>
                                    </div>
                                </div>
                                <h3 class="fw-bold mb-1"><%= stats.totalUsers %></h3>
                                <div class="small text-muted">
                                    <span class="text-success"><i class="bi bi-arrow-up-short"></i> Active accounts</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Total Jobs -->
                    <div class="col-12 col-md-6 col-xl-3">
                        <div class="card stat-card border-0 shadow-sm rounded-4 h-100">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div class="text-muted fw-semibold">Total Jobs</div>
                                    <div class="icon-box bg-success bg-opacity-10 text-success">
                                        <i class="bi bi-briefcase fs-4"></i>
                                    </div>
                                </div>
                                <h3 class="fw-bold mb-1"><%= stats.totalJobs %></h3>
                                <div class="small text-muted">
                                    <span class="text-success"><%= stats.jobs.open || 0 %> open</span> | <span class="text-warning"><%= stats.jobs.in_progress || 0 %> in progress</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Total Deposits -->
                    <div class="col-12 col-md-6 col-xl-3">
                        <div class="card stat-card border-0 shadow-sm rounded-4 h-100">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div class="text-muted fw-semibold">Total Deposits</div>
                                    <div class="icon-box bg-info bg-opacity-10 text-info">
                                        <i class="bi bi-wallet2 fs-4"></i>
                                    </div>
                                </div>
                                <h3 class="fw-bold mb-1"><i class="bi bi-gem text-primary fs-5"></i> <%= parseFloat(stats.finance.deposit || 0).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></h3>
                                <div class="small text-muted">
                                    <% if (typeof isFiltered !== 'undefined' && isFiltered) { %>
                                        <%= ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][selectedMonth-1] %> <%= selectedYear %>
                                    <% } else { %>
                                        All-time platform deposits
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Service Fees (Revenue) -->
                    <div class="col-12 col-md-6 col-xl-3">
                        <div class="card stat-card border-0 shadow-sm rounded-4 h-100">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div class="text-muted fw-semibold">Platform Revenue</div>
                                    <div class="icon-box bg-warning bg-opacity-10 text-warning">
                                        <i class="bi bi-cash-coin fs-4"></i>
                                    </div>
                                </div>
                                <h3 class="fw-bold mb-1"><i class="bi bi-gem text-primary fs-5"></i> <%= parseFloat(stats.finance.service_fee || 0).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></h3>
                                <div class="small text-muted">
                                    <% if (typeof isFiltered !== 'undefined' && isFiltered) { %>
                                        <%= ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][selectedMonth-1] %> <%= selectedYear %>
                                    <% } else { %>
                                        From service fees & plans
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Charts & Details Row -->
                <div class="row g-3">
                    <!-- User Distribution -->
                    <div class="col-12 col-lg-6">
                        <div class="card border-0 shadow-sm rounded-4 h-100">
                            <div class="card-header bg-white border-0 pt-4 pb-0 px-4">
                                <h5 class="fw-bold mb-0">User Distribution</h5>
                            </div>
                            <div class="card-body p-4 d-flex align-items-center justify-content-center">
                                <div style="width: 100%; max-width: 300px;">
                                    <canvas id="userRoleChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Recent Users Table -->
                    <div class="col-12 col-lg-6">
                        <div class="card border-0 shadow-sm rounded-4 h-100">
                            <div class="card-header bg-white border-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-center">
                                <h5 class="fw-bold mb-0">Recent Signups</h5>
                                <a href="/admin/users" class="btn btn-sm btn-light">View All</a>
                            </div>
                            <div class="card-body p-4">
                                <div class="table-responsive">
                                    <table class="table table-borderless align-middle mb-0">
                                        <tbody>
                                            <% if(stats.recentUsers && stats.recentUsers.length > 0) { %>
                                                <% stats.recentUsers.forEach(u => { %>
                                                    <tr class="border-bottom">
                                                        <td class="ps-0 py-3">
                                                            <div class="d-flex align-items-center gap-3">
                                                                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center text-secondary fw-bold" style="width: 40px; height: 40px;">
                                                                    <%= u.email.charAt(0).toUpperCase() %>
                                                                </div>
                                                                <div>
                                                                    <div class="fw-semibold"><%= u.full_name || 'N/A' %></div>
                                                                    <div class="small text-muted"><%= u.email %></div>
                                                                </div>
                                                            </div>
                                                        </td>
                                                        <td class="py-3">
                                                            <span class="badge bg-secondary bg-opacity-10 text-secondary text-capitalize"><%= u.role %></span>
                                                        </td>
                                                        <td class="text-end pe-0 py-3 text-muted small">
                                                            <%= new Date(u.created_at).toLocaleDateString() %>
                                                        </td>
                                                    </tr>
                                                <% }) %>
                                            <% } else { %>
                                                <tr><td colspan="3" class="text-center text-muted">No recent signups.</td></tr>
                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </section>
        </div>
    </main>

    <%- include('../../public/footer') %>
    
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const ctx = document.getElementById('userRoleChart').getContext('2d');
            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['Freelancers', 'Employers', 'Admins'],
                    datasets: [{
                        data: [
                            <%= stats.roles.freelancer || 0 %>, 
                            <%= stats.roles.employer || 0 %>, 
                            <%= stats.roles.admin || 0 %>
                        ],
                        backgroundColor: [
                            '#0d6efd', // Primary blue
                            '#198754', // Success green
                            '#ffc107'  // Warning yellow
                        ],
                        borderWidth: 0,
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                padding: 20,
                                usePointStyle: true,
                                pointStyle: 'circle'
                            }
                        }
                    },
                    cutout: '75%'
                }
            });
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>