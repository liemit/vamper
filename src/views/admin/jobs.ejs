<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jobs Moderation - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/style.css">
    <style>
        .admin-page main { background: linear-gradient(180deg, #f6f8fc 0%, #f0f7ff 100%); }
        .admin-sidebar { background-color: #ffffff !important; }
    </style>
</head>
<body class="admin-page bg-light">
    <%- include('../../public/header') %>
    <main class="container-fluid py-3 py-md-4">
        <div class="row g-0">
            <aside class="col-12 col-md-3 col-lg-2 pe-md-3 mb-3 mb-md-0">
                <%- include('layouts/menu') %>
            </aside>
            <section class="col-12 col-md-9 col-lg-10 ps-md-0">
                <div class="d-flex align-items-center justify-content-between pt-2 pb-3 mb-3 border-bottom">
                    <h4 class="fw-bold mb-0">Jobs Moderation</h4>
                    <span class="text-muted small">Total: <%= pagination.total %></span>
                </div>

                <% if (success_msg && success_msg.length > 0) { %>
                    <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle-fill me-2"></i><%= success_msg %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
                <% } %>
                <% if (error_msg && error_msg.length > 0) { %>
                    <div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-triangle-fill me-2"></i><%= error_msg %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
                <% } %>

                <!-- Filter -->
                <div class="card border-0 shadow-sm rounded-4 mb-3">
                    <div class="card-body py-2 px-3">
                        <form method="GET" action="/admin/jobs" class="d-flex gap-2 flex-wrap align-items-end">
                            <div>
                                <label class="form-label small mb-1">Status</label>
                                <select name="status" class="form-select form-select-sm" style="width:130px;">
                                    <option value="">All</option>
                                    <% ['open','in_progress','completed','cancelled','expired'].forEach(s => { %>
                                        <option value="<%= s %>" <%= query.status === s ? 'selected' : '' %>><%= s %></option>
                                    <% }); %>
                                </select>
                            </div>
                            <div>
                                <label class="form-label small mb-1">Category</label>
                                <select name="category" class="form-select form-select-sm" style="width:160px;">
                                    <option value="">All</option>
                                    <% categories.forEach(c => { %>
                                        <option value="<%= c.id %>" <%= query.category == c.id ? 'selected' : '' %>><%= c.name %></option>
                                    <% }); %>
                                </select>
                            </div>
                            <div>
                                <label class="form-label small mb-1">Search</label>
                                <input type="text" name="q" class="form-control form-control-sm" placeholder="Job title..." value="<%= query.q || '' %>" style="width:200px;">
                            </div>
                            <button type="submit" class="btn btn-sm btn-primary">Filter</button>
                            <a href="/admin/jobs" class="btn btn-sm btn-outline-secondary">Reset</a>
                        </form>
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">ID</th>
                                        <th>Title</th>
                                        <th>Employer</th>
                                        <th>Category</th>
                                        <th>Budget</th>
                                        <th>Type</th>
                                        <th>Status</th>
                                        <th>Created</th>
                                        <th class="pe-4">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (!jobs.length) { %>
                                        <tr><td colspan="9" class="text-center text-muted py-4">No jobs found.</td></tr>
                                    <% } %>
                                    <% jobs.forEach(j => { %>
                                    <%
                                        const statusColors = { open: 'success', in_progress: 'primary', completed: 'secondary', cancelled: 'danger', expired: 'warning' };
                                        const sc = statusColors[j.status] || 'secondary';
                                    %>
                                    <tr>
                                        <td class="ps-4 text-muted small">#<%= j.id %></td>
                                        <td style="max-width:220px;">
                                            <div class="fw-semibold text-truncate"><%= j.title %></div>
                                            <div class="text-muted small text-truncate"><%= j.job_type %></div>
                                        </td>
                                        <td class="small"><%= j.employer_name || j.company_name || '#'+j.employer_id %></td>
                                        <td class="small"><%= j.category_name || '—' %></td>
                                        <td class="small"><i class="bi bi-gem text-primary"></i> <%= j.budget ? Number(j.budget).toLocaleString() : '—' %></td>
                                        <td><span class="badge bg-light text-dark border"><%= j.job_type === 'hourly' ? 'Hourly' : 'Project' %></span></td>
                                        <td><span class="badge bg-<%= sc %>-subtle text-<%= sc %>"><%= j.status %></span></td>
                                        <td class="small text-muted"><%= j.created_at ? new Date(j.created_at).toLocaleDateString() : '' %></td>
                                        <td class="pe-4">
                                            <div class="d-flex gap-1">
                                                <a href="/freelancer/jobs/<%= j.slug %>" target="_blank" class="btn btn-sm btn-outline-primary py-0 px-2" title="View"><i class="bi bi-eye"></i></a>
                                                <form method="POST" action="/admin/jobs/<%= j.id %>/toggle-status?_csrf=<%= csrfToken %>" class="d-inline">
                                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                    <button type="submit" class="btn btn-sm <%= j.status === 'cancelled' ? 'btn-outline-success' : 'btn-outline-warning' %> py-0 px-2"
                                                        title="<%= j.status === 'cancelled' ? 'Reopen' : 'Cancel' %>"
                                                        onclick="return confirm('Are you sure?')">
                                                        <i class="bi <%= j.status === 'cancelled' ? 'bi-arrow-counterclockwise' : 'bi-slash-circle' %>"></i>
                                                    </button>
                                                </form>
                                                <form method="POST" action="/admin/jobs/<%= j.id %>/delete?_csrf=<%= csrfToken %>" class="d-inline">
                                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-2" title="Delete" onclick="return confirm('Delete this job permanently?')">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>

                        <% if (pagination.totalPages > 1) { %>
                        <div class="d-flex justify-content-between align-items-center px-4 py-3 border-top">
                            <div class="text-muted small">Page <%= pagination.page %> of <%= pagination.totalPages %></div>
                            <nav>
                                <ul class="pagination pagination-sm mb-0">
                                    <li class="page-item <%= pagination.page <= 1 ? 'disabled' : '' %>">
                                        <a class="page-link" href="?status=<%= query.status %>&category=<%= query.category %>&q=<%= query.q %>&page=<%= pagination.page-1 %>">Prev</a>
                                    </li>
                                    <% for (let i = 1; i <= pagination.totalPages; i++) { %>
                                        <li class="page-item <%= i === pagination.page ? 'active' : '' %>">
                                            <a class="page-link" href="?status=<%= query.status %>&category=<%= query.category %>&q=<%= query.q %>&page=<%= i %>"><%= i %></a>
                                        </li>
                                    <% } %>
                                    <li class="page-item <%= pagination.page >= pagination.totalPages ? 'disabled' : '' %>">
                                        <a class="page-link" href="?status=<%= query.status %>&category=<%= query.category %>&q=<%= query.q %>&page=<%= pagination.page+1 %>">Next</a>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                        <% } %>
                    </div>
                </div>
            </section>
        </div>
    </main>
    <%- include('../../public/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
