<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vamper - Create Menu</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/style.css">
    <style>
        
        .admin-page main {
            background: linear-gradient(180deg, #f6f8fc 0%, #f0f7ff 100%);
        }

        .admin-page .card {
            border: 1px solid #eef2f7;
        }

        .admin-page .accordion-button::after {
            filter: none;
        }

        .admin-page .admin-sidebar {
            background-color: #ffffff !important;
        }

        .admin-page .admin-sidebar .accordion,
        .admin-page .admin-sidebar .accordion-item,
        .admin-page .admin-sidebar .accordion-header,
        .admin-page .admin-sidebar .accordion-collapse,
        .admin-page .admin-sidebar .accordion-body {
            background-color: #ffffff !important;
        }

        .admin-page .admin-sidebar .accordion-item {
            border: 0 !important;
        }

        .admin-page .admin-sidebar .input-group-text,
        .admin-page .admin-sidebar .form-control {
            border-color: #dee2e6 !important;
        }

        .admin-page .admin-sidebar .form-control::placeholder {
            color: #6c757d !important;
        }

        .admin-page .admin-sidebar .accordion-button {
            color: #0d1b2a !important;
            background: #ffffff !important;
            box-shadow: none !important;
            border-radius: 0.75rem !important;
            padding: 0.65rem 0.75rem !important;
            font-weight: 600;
        }

        .admin-page .admin-sidebar .accordion-button:hover {
            background: #f1f5ff !important;
        }

        .admin-page .admin-sidebar .accordion-button:not(.collapsed) {
            background: #e7f1ff !important;
            color: #0d6efd !important;
        }

        .admin-page .admin-sidebar .accordion-button.collapsed {
            background: #ffffff !important;
        }

        .admin-page .admin-sidebar .accordion-button i {
            color: #0d6efd !important;
        }

        .admin-page .admin-sidebar a {
            color: #0d1b2a !important;
        }

        .admin-page .admin-sidebar a:hover {
            background: #f1f5ff !important;
            color: #0d6efd !important;
        }

        .admin-page .admin-sidebar a,
        .admin-page .admin-sidebar a span,
        .admin-page .admin-sidebar a i {
            color: #0d1b2a !important;
        }

        .admin-page .admin-sidebar .accordion-body {
            padding: 0.35rem 0.25rem;
        }

        .admin-page .admin-sidebar .accordion-body a {
            padding: 0.5rem 0.6rem;
            border-radius: 0.6rem;
        }

        .admin-page .admin-sidebar .accordion-body a[style*="background"] {
            background: #e7f1ff !important;
            color: #0d6efd !important;
        }

        .admin-page .admin-sidebar-head {
            background: linear-gradient(135deg, #e7f1ff 0%, #ffe8f0 50%, #e6fbff 100%) !important;
        }

        .admin-page .admin-sidebar-head,
        .admin-page .admin-sidebar-head * {
            color: #0d1b2a !important;
        }
    </style>
</head>

<body class="admin-page">
    <%- include('../../public/header') %>

        <main class="container-fluid py-3 py-md-4">
            <div class="row g-0">
                <aside class="col-12 col-md-3 col-lg-2 pe-md-3 mb-3 mb-md-0">
                    <%- include('layouts/menu') %>
                </aside>

                <section class="col-12 col-md-9 col-lg-10 ps-md-0">
                    <div class="card border-0 shadow-sm rounded-4 mb-3">
                        <div class="card-body py-3 px-3 px-md-4">
                            <div class="d-flex align-items-center justify-content-between">
                                <div class="d-flex align-items-center gap-2">
                                    <button class="btn btn-sm btn-outline-secondary d-md-none" type="button"
                                        data-bs-toggle="offcanvas" data-bs-target="#adminSidebar"
                                        aria-controls="adminSidebar">
                                        <i class="bi bi-list"></i>
                                    </button>
                                    <a href="/admin/menus" class="btn btn-outline-secondary me-3">
                                        <i class="bi bi-arrow-left"></i>
                                    </a>
                                    <div>
                                        <h1 class="h3 mb-0 fw-bold">Create New Menu</h1>
                                        <div class="text-muted small">Add a new navigation group</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm rounded-4">
                        <div class="card-body p-4">
                            <form action="/admin/menus/store?_csrf=<%= csrfToken %>" method="POST">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label for="name" class="form-label fw-bold">Menu Name</label>
                                        <input type="text" class="form-control" id="name" name="name"
                                            placeholder="e.g. Main Navigation" required>
                                        <div class="form-text">Friendly name for display in admin panel.</div>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="code" class="form-label fw-bold">Menu Code</label>
                                        <input type="text" class="form-control" id="code" name="code"
                                            placeholder="e.g. main_nav" required>
                                        <div class="form-text">Unique identifier for developer use (snake_case).</div>
                                    </div>
                                    <div class="col-12">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="is_active"
                                                name="is_active" checked>
                                            <label class="form-check-label" for="is_active">Active (Visible)</label>
                                        </div>
                                    </div>
                                    <div class="col-12 mt-4">
                                        <div class="d-flex gap-2">
                                            <a href="/admin/menus" class="btn btn-outline-secondary px-4">Cancel</a>
                                            <button type="submit" class="btn btn-primary px-4">Create Menu</button>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </section>
            </div>
        </main>

        <%- include('../../public/footer') %>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>