<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Roles - Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/style.css">
    <style>
        .admin-page main { background: linear-gradient(180deg, #f6f8fc 0%, #f0f7ff 100%); }
        .admin-sidebar { background-color: #ffffff !important; }
        .role-badge-admin    { background: #6f42c1; color: #fff; }
        .role-badge-employer { background: #0d6efd; color: #fff; }
        .role-badge-freelancer { background: #198754; color: #fff; }
        .role-badge-publisher  { background: #fd7e14; color: #fff; }
    </style>
</head>
<body class="admin-page bg-light">
    <%- include('../../public/header') %>

    <main class="container-fluid py-3 py-md-4">
        <div class="row g-0">
            <aside class="col-12 col-md-3 col-lg-2 pe-md-3 mb-3 mb-md-0">
                <%- include('layouts/menu') %>
            </aside>

            <section class="col-12 col-md-9 col-lg-10 ps-md-0">
                <div class="d-flex align-items-center justify-content-between pt-2 pb-3 mb-3 border-bottom">
                    <h4 class="fw-bold mb-0">Roles & Permissions</h4>
                </div>

                <!-- Role Stats Cards -->
                <div class="row g-3 mb-4">
                    <% const roleCards = [
                        { key: 'admin',      label: 'Admin',      icon: 'bi-shield-lock',   color: 'purple' },
                        { key: 'employer',   label: 'Employer',   icon: 'bi-building',      color: 'primary' },
                        { key: 'freelancer', label: 'Freelancer', icon: 'bi-person-badge',  color: 'success' },
                    ]; %>
                    <% roleCards.forEach(rc => { %>
                    <div class="col-12 col-md-4">
                        <a href="/admin/roles?role=<%= rc.key %>" class="text-decoration-none">
                            <div class="card border-0 shadow-sm rounded-4 h-100 <%= filterRole === rc.key ? 'border border-primary' : '' %>">
                                <div class="card-body d-flex align-items-center gap-3 p-3">
                                    <div class="rounded-3 p-2 bg-<%= rc.color %>-subtle text-<%= rc.color %>">
                                        <i class="bi <%= rc.icon %> fs-4"></i>
                                    </div>
                                    <div>
                                        <div class="text-muted small"><%= rc.label %></div>
                                        <div class="fw-bold fs-5"><%= stats[rc.key] || 0 %></div>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                    <% }); %>
                </div>

                <!-- Filter bar -->
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-header bg-transparent border-0 px-4 pt-3 pb-0 d-flex align-items-center gap-3 flex-wrap">
                        <span class="fw-semibold">Filter:</span>
                        <% ['all','admin','employer','freelancer'].forEach(r => { %>
                            <a href="/admin/roles?role=<%= r %>"
                               class="btn btn-sm <%= filterRole === r ? 'btn-primary' : 'btn-outline-secondary' %>">
                                <%= r.charAt(0).toUpperCase() + r.slice(1) %>
                            </a>
                        <% }); %>
                        <span class="ms-auto text-muted small">Total: <%= pagination.total %></span>
                    </div>

                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">ID</th>
                                        <th>Name</th>
                                        <th>Email</th>
                                        <th>Current Role</th>
                                        <th>Status</th>
                                        <th>Joined</th>
                                        <th>Change Role</th>
                                        <th class="pe-4">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (!users.length) { %>
                                        <tr><td colspan="7" class="text-center text-muted py-4">No users found.</td></tr>
                                    <% } %>
                                    <% users.forEach(u => { %>
                                    <tr>
                                        <td class="ps-4 text-muted small">#<%= u.id %></td>
                                        <td>
                                            <div class="fw-semibold"><%= u.full_name || u.company_name || 'N/A' %></div>
                                        </td>
                                        <td class="text-muted small"><%= u.email %></td>
                                        <td>
                                            <span class="badge role-badge-<%= u.role %>"><%= u.role %></span>
                                        </td>
                                        <td>
                                            <span class="badge <%= u.is_active ? 'bg-success-subtle text-success' : 'bg-danger-subtle text-danger' %>">
                                                <%= u.is_active ? 'Active' : 'Inactive' %>
                                            </span>
                                        </td>
                                        <td class="text-muted small"><%= u.created_at ? new Date(u.created_at).toLocaleDateString() : '' %></td>
                                        <td class="pe-4">
                                            <select id="role-select-<%= u.id %>" class="form-select form-select-sm" style="width:130px;">
                                                <% ['admin','employer','freelancer'].forEach(r => { %>
                                                    <option value="<%= r %>" <%= u.role === r ? 'selected' : '' %>><%= r %></option>
                                                <% }); %>
                                            </select>
                                        </td>
                                        <td class="pe-4">
                                            <button type="button" class="btn btn-sm btn-primary save-role-btn"
                                                data-user-id="<%= u.id %>">
                                                Save
                                            </button>
                                        </td>
                                    </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>

                        <% if (pagination.totalPages > 1) { %>
                        <div class="d-flex justify-content-between align-items-center px-4 py-3 border-top">
                            <div class="text-muted small">Page <%= pagination.page %> of <%= pagination.totalPages %></div>
                            <nav>
                                <ul class="pagination pagination-sm mb-0">
                                    <li class="page-item <%= pagination.page <= 1 ? 'disabled' : '' %>">
                                        <a class="page-link" href="/admin/roles?role=<%= filterRole %>&page=<%= pagination.page - 1 %>">Previous</a>
                                    </li>
                                    <% for (let i = 1; i <= pagination.totalPages; i++) { %>
                                        <li class="page-item <%= i === pagination.page ? 'active' : '' %>">
                                            <a class="page-link" href="/admin/roles?role=<%= filterRole %>&page=<%= i %>"><%= i %></a>
                                        </li>
                                    <% } %>
                                    <li class="page-item <%= pagination.page >= pagination.totalPages ? 'disabled' : '' %>">
                                        <a class="page-link" href="/admin/roles?role=<%= filterRole %>&page=<%= pagination.page + 1 %>">Next</a>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                        <% } %>
                    </div>
                </div>
            </section>
        </div>
    </main>

    <%- include('../../public/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const CSRF_TOKEN = '<%- csrfToken %>';

        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.save-role-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    saveRole(this.dataset.userId, this);
                });
            });
        });

        async function saveRole(userId, btn) {
            const select = document.getElementById(`role-select-${userId}`);
            const newRole = select.value;
            const originalText = btn.textContent;

            btn.disabled = true;
            btn.textContent = '...';

            try {
                const res = await fetch(`/admin/users/${userId}/role`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'CSRF-Token': CSRF_TOKEN,
                        'X-CSRF-Token': CSRF_TOKEN
                    },
                    body: JSON.stringify({ role: newRole, _csrf: CSRF_TOKEN })
                });
                const data = await res.json();
                if (data.ok) {
                    // Update badge
                    const badge = btn.closest('tr').querySelector('td:nth-child(4) .badge');
                    badge.className = `badge role-badge-${newRole}`;
                    badge.textContent = newRole;
                    btn.textContent = '✓ Saved';
                    btn.classList.replace('btn-primary', 'btn-success');
                    setTimeout(() => {
                        btn.textContent = 'Save';
                        btn.classList.replace('btn-success', 'btn-primary');
                        btn.disabled = false;
                    }, 2000);
                } else {
                    alert(data.error || 'Failed to update role');
                    btn.textContent = originalText;
                    btn.disabled = false;
                }
            } catch (e) {
                alert('Error updating role');
                btn.textContent = originalText;
                btn.disabled = false;
            }
        }
    </script>
</body>
</html>
