<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Boost Views - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/style.css">
    <style>
        .admin-page main { background: linear-gradient(180deg, #f6f8fc 0%, #f0f7ff 100%); }
        .admin-sidebar { background-color: #ffffff !important; }
    </style>
</head>
<body class="admin-page bg-light">
    <%- include('../../public/header') %>
    <main class="container-fluid py-3 py-md-4">
        <div class="row g-0">
            <aside class="col-12 col-md-3 col-lg-2 pe-md-3 mb-3 mb-md-0">
                <%- include('layouts/menu') %>
            </aside>
            <section class="col-12 col-md-9 col-lg-10 ps-md-0">
                <div class="card border-0 shadow-sm rounded-4 mb-3">
                    <div class="card-body py-3 px-3 px-md-4">
                        <div class="d-flex align-items-center gap-2">
                            <button class="btn btn-sm btn-outline-secondary d-md-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#adminSidebar">
                                <i class="bi bi-list"></i>
                            </button>
                            <div class="rounded-3 d-flex align-items-center justify-content-center" style="width:34px;height:34px;background:#e7f1ff;color:#0d6efd;">
                                <i class="bi bi-eye"></i>
                            </div>
                            <div>
                                <div class="fw-bold">Boost Views</div>
                                <div class="text-muted small">Manually add view counts to job listings</div>
                            </div>
                        </div>
                    </div>
                </div>

                <% if (success_msg && success_msg.length) { %>
                    <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle-fill me-2"></i><%= success_msg %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
                <% } %>
                <% if (error_msg && error_msg.length) { %>
                    <div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-triangle-fill me-2"></i><%= error_msg %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
                <% } %>

                <!-- Filter -->
                <div class="card border-0 shadow-sm rounded-4 mb-3">
                    <div class="card-body py-2 px-3">
                        <form method="GET" action="/admin/boost-views" class="d-flex gap-2 flex-wrap align-items-end">
                            <div>
                                <label class="form-label small mb-1">Search</label>
                                <input type="text" name="q" class="form-control form-control-sm" placeholder="Job title or employer..." value="<%= q || '' %>" style="width:220px;">
                            </div>
                            <button type="submit" class="btn btn-sm btn-primary">Filter</button>
                            <a href="/admin/boost-views" class="btn btn-sm btn-outline-secondary">Reset</a>
                        </form>
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">ID</th>
                                        <th>Job Title</th>
                                        <th>Employer</th>
                                        <th>Posted</th>
                                        <th>Status</th>
                                        <th class="text-center"><i class="bi bi-eye me-1"></i>Views</th>
                                        <th class="pe-4 text-center">Boost</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (!jobs.length) { %>
                                        <tr><td colspan="7" class="text-center text-muted py-4">No jobs found.</td></tr>
                                    <% } %>
                                    <% jobs.forEach(j => { %>
                                    <%
                                        const sc = { open:'success', in_progress:'primary', completed:'secondary', cancelled:'danger', expired:'warning' }[j.status] || 'secondary';
                                    %>
                                    <tr>
                                        <td class="ps-4 text-muted small">#<%= j.id %></td>
                                        <td style="max-width:240px;">
                                            <div class="fw-semibold text-truncate"><%= j.title %></div>
                                            <div class="text-muted small"><%= j.job_type === 'hourly' ? 'Hourly' : 'Project' %> · <i class="bi bi-gem text-primary"></i> <%= Number(j.budget||0).toLocaleString() %></div>
                                        </td>
                                        <td>
                                            <div class="small fw-semibold"><%= j.employer_name || '—' %></div>
                                            <div class="text-muted small"><%= j.employer_email || '' %></div>
                                        </td>
                                        <td class="small text-muted"><%= j.created_at ? new Date(j.created_at).toLocaleDateString('vi-VN') : '—' %></td>
                                        <td><span class="badge bg-<%= sc %>-subtle text-<%= sc %>"><%= j.status %></span></td>
                                        <td class="text-center">
                                            <span class="fw-bold text-primary"><%= Number(j.total_views||0).toLocaleString() %></span>
                                        </td>
                                        <td class="pe-4 text-center">
                                            <button class="btn btn-sm btn-outline-primary py-0 px-2"
                                                data-bs-toggle="modal" data-bs-target="#boostModal"
                                                data-job-id="<%= j.id %>"
                                                data-job-title="<%= j.title %>"
                                                data-current-views="<%= j.total_views || 0 %>">
                                                <i class="bi bi-plus-circle me-1"></i> Boost
                                            </button>
                                        </td>
                                    </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>

                        <div class="d-flex justify-content-between align-items-center px-4 py-3 border-top flex-wrap gap-2">
                            <div class="text-muted small">
                                Showing <%= (pagination.page - 1) * pagination.perPage + 1 %>–<%= Math.min(pagination.page * pagination.perPage, pagination.total) %> of <strong><%= pagination.total %></strong> jobs
                            </div>
                            <% if (pagination.totalPages > 1) { %>
                            <nav>
                                <ul class="pagination pagination-sm mb-0">
                                    <li class="page-item <%= pagination.page <= 1 ? 'disabled' : '' %>">
                                        <a class="page-link" href="?q=<%= q %>&page=<%= pagination.page-1 %>">Prev</a>
                                    </li>
                                    <% for (let i = Math.max(1, pagination.page-2); i <= Math.min(pagination.totalPages, pagination.page+2); i++) { %>
                                        <li class="page-item <%= i === pagination.page ? 'active' : '' %>">
                                            <a class="page-link" href="?q=<%= q %>&page=<%= i %>"><%= i %></a>
                                        </li>
                                    <% } %>
                                    <li class="page-item <%= pagination.page >= pagination.totalPages ? 'disabled' : '' %>">
                                        <a class="page-link" href="?q=<%= q %>&page=<%= pagination.page+1 %>">Next</a>
                                    </li>
                                </ul>
                            </nav>
                            <% } %>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </main>

    <!-- Boost Modal -->
    <div class="modal fade" id="boostModal" tabindex="-1">
        <div class="modal-dialog modal-sm">
            <div class="modal-content rounded-4">
                <div class="modal-header border-0 pb-0">
                    <h6 class="modal-title fw-bold">Boost Views</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="POST" action="/admin/boost-views/apply">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="job_id" id="modalJobId">
                    <div class="modal-body">
                        <div class="text-muted small mb-3" id="modalJobTitle"></div>
                        <div class="mb-3">
                            <label class="form-label small">Current Views</label>
                            <div class="fw-bold text-primary fs-5" id="modalCurrentViews"></div>
                        </div>
                        <div class="mb-2">
                            <label class="form-label small">Add Views</label>
                            <input type="number" name="add_views" class="form-control" min="1" max="10000" value="100" required>
                            <div class="form-text">Will be spread across the past 7 days.</div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-eye me-1"></i> Apply Boost</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <%- include('../../public/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('boostModal').addEventListener('show.bs.modal', function(e) {
            const btn = e.relatedTarget;
            document.getElementById('modalJobId').value = btn.dataset.jobId;
            document.getElementById('modalJobTitle').textContent = btn.dataset.jobTitle;
            document.getElementById('modalCurrentViews').textContent = Number(btn.dataset.currentViews).toLocaleString();
        });
    </script>
</body>
</html>
