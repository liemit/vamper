<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vamper - Disputes</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/style.css">
</head>

<body class="admin-page">
    <%- include('../../public/header') %>

    <main class="container-fluid py-3 py-md-4">
        <div class="row g-3">
            <aside class="col-12 col-md-3 col-lg-2">
                <%- include('./layouts/menu') %>
            </aside>

            <section class="col-12 col-md-9 col-lg-10">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                    <div>
                        <h4 class="mb-1">Disputes</h4>
                        <div class="text-muted small">Scam / dispute reports submitted from Messenger</div>
                    </div>
                </div>

                <div class="card shadow-sm rounded-4 mb-3">
                    <div class="card-body">
                        <form method="GET" action="<%= basePath || '/admin/disputes' %>" class="row g-2 align-items-end">
                            <div class="col-12 col-md-3">
                                <label class="form-label small">Status</label>
                                <select name="status" class="form-select form-select-sm">
                                    <% const st = (query && query.status) ? String(query.status) : ''; %>
                                    <option value="" <%= !st ? 'selected' : '' %>>All</option>
                                    <option value="open" <%= st === 'open' ? 'selected' : '' %>>Open</option>
                                    <option value="under_review" <%= st === 'under_review' ? 'selected' : '' %>>Under review</option>
                                    <option value="resolved" <%= st === 'resolved' ? 'selected' : '' %>>Resolved</option>
                                    <option value="rejected" <%= st === 'rejected' ? 'selected' : '' %>>Rejected</option>
                                </select>
                            </div>
                            <div class="col-12 col-md-3">
                                <button class="btn btn-sm btn-primary">Filter</button>
                                <a class="btn btn-sm btn-outline-secondary" href="<%= basePath || '/admin/disputes' %>">Reset</a>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="card shadow-sm rounded-4">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 90px;">ID</th>
                                        <th>Job</th>
                                        <th>Category</th>
                                        <th>Status</th>
                                        <th>Created</th>
                                        <th style="width: 120px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (disputes && disputes.length) { %>
                                        <% disputes.forEach((d) => { %>
                                            <tr>
                                                <td class="fw-semibold">#<%= d.id %></td>
                                                <td>
                                                    <div class="fw-semibold"><%= d.job_title || ('Job #' + d.job_id) %></div>
                                                    <div class="small text-muted">Job ID: <%= d.job_id %></div>
                                                </td>
                                                <td><%= d.category || 'scam' %></td>
                                                <td>
                                                    <% const s = (d.status || '').toLowerCase(); %>
                                                    <% const badge = s === 'open' ? 'bg-warning text-dark'
                                                        : (s === 'under_review' ? 'bg-info'
                                                        : (s === 'resolved' ? 'bg-success'
                                                        : (s === 'rejected' ? 'bg-secondary' : 'bg-light text-dark'))); %>
                                                    <span class="badge <%= badge %>"><%= s || 'open' %></span>
                                                </td>
                                                <td>
                                                    <span class="js-local-dt" data-kind="datetime" data-utc="<%= d.created_at || '' %>"></span>
                                                </td>
                                                <td class="text-end">
                                                    <a class="btn btn-sm btn-outline-primary" href="<%= (basePath || '/admin/disputes') + '/' + d.id %>">View</a>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="6" class="text-center text-muted py-4">No disputes found.</td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <% if (pagination) { %>
                    <nav class="mt-3">
                        <ul class="pagination pagination-sm">
                            <% const buildQuery = (p) => {
                                const qs = new URLSearchParams();
                                if (query && query.status) qs.set('status', query.status);
                                qs.set('page', String(p));
                                return (basePath || '/admin/disputes') + '?' + qs.toString();
                            }; %>
                            <li class="page-item <%= (pagination.page <= 1) ? 'disabled' : '' %>">
                                <a class="page-link" href="<%= buildQuery(pagination.page - 1) %>">Prev</a>
                            </li>
                            <li class="page-item disabled">
                                <span class="page-link">Page <%= pagination.page %> / <%= pagination.totalPages %></span>
                            </li>
                            <li class="page-item <%= (pagination.page >= pagination.totalPages) ? 'disabled' : '' %>">
                                <a class="page-link" href="<%= buildQuery(pagination.page + 1) %>">Next</a>
                            </li>
                        </ul>
                    </nav>
                <% } %>
            </section>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
</body>

</html>
