<div class="offcanvas-md offcanvas-start" tabindex="-1" id="adminSidebar" aria-labelledby="adminSidebarLabel">
    <div class="offcanvas-header d-md-none border-bottom">
        <h5 class="offcanvas-title fw-bold text-primary" id="adminSidebarLabel">
            <i class="bi bi-shield-lock me-2"></i>Admin Panel
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" data-bs-target="#adminSidebar" aria-label="Close" onclick="var el=document.getElementById('adminSidebar');if(el&&window.bootstrap){bootstrap.Offcanvas.getInstance(el)&&bootstrap.Offcanvas.getInstance(el).hide();}"></button>
    </div>
    <div class="offcanvas-body p-0">
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden" style="min-height: calc(100vh - 160px);">
        <div class="p-3 admin-sidebar-head">
            <div class="d-flex align-items-center gap-2">
                <div class="rounded-3 d-flex align-items-center justify-content-center" style="width: 36px; height: 36px; background: rgba(255,255,255,0.12);">
                    <i class="bi bi-shield-lock"></i>
                </div>
                <div>
                    <div class="fw-bold">System Console</div>
                    <div class="small" style="opacity: 0.8;">
                        <%= (user && (user.full_name || user.email)) ? (user.full_name || user.email) : 'Administrator' %>
                    </div>
                </div>
            </div>
        </div>

        <div class="p-2 admin-sidebar" style="background-color: #ffffff;">
            <div class="px-2 pt-2 pb-2">
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-transparent border-secondary" style="border-right: 0;">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text" class="form-control bg-transparent border-secondary" placeholder="Search admin tools..." style="border-left: 0;" aria-label="Search">
                </div>
            </div>

            <div class="accordion accordion-flush" id="adminMenu" style="--bs-accordion-bg: transparent; --bs-accordion-border-color: rgba(255,255,255,0.08);">
                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingOverview">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOverview" aria-expanded="false" aria-controls="collapseOverview">
                            <i class="bi bi-speedometer2 me-2"></i> Overview
                        </button>
                    </h2>
                    <div id="collapseOverview" class="accordion-collapse collapse show" aria-labelledby="headingOverview" data-bs-parent="#adminMenu">
                        <div class="accordion-body pt-0 pb-2">
                            <a class="d-flex align-items-center gap-2 text-decoration-none px-2 py-2 rounded-3" href="/admin" style="background: rgba(255,255,255,0.06);">
                                <i class="bi bi-grid-1x2"></i>
                                <span class="small fw-semibold">Dashboard</span>
                            </a>
                            <a class="d-flex align-items-center gap-2 text-decoration-none px-2 py-2 rounded-3" href="/admin/analytics" style="opacity:0.9;">
                                <i class="bi bi-graph-up"></i>
                                <span class="small">Analytics</span>
                            </a>
                            <a class="d-flex align-items-center gap-2 text-decoration-none px-2 py-2 rounded-3" href="/admin/activity" style="opacity:0.9;">
                                <i class="bi bi-clock-history"></i>
                                <span class="small">Activity Log</span>
                            </a>
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingUsers">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseUsers" aria-expanded="false" aria-controls="collapseUsers">
                            <i class="bi bi-people me-2"></i> Users & Permissions
                        </button>
                    </h2>
                    <div id="collapseUsers" class="accordion-collapse collapse" aria-labelledby="headingUsers" data-bs-parent="#adminMenu">
                        <div class="accordion-body pt-0 pb-2">
                            <a class="d-flex align-items-center gap-2 text-decoration-none px-2 py-2 rounded-3" href="/admin/users" style="opacity:0.9;">
                                <i class="bi bi-person-badge"></i>
                                <span class="small">Manage Users</span>
                            </a>
                            <a class="d-flex align-items-center gap-2 text-decoration-none px-2 py-2 rounded-3" href="/admin/roles" style="opacity:0.9;">
                                <i class="bi bi-shield-check"></i>
                                <span class="small">Roles</span>
                            </a>
                            <a class="d-flex align-items-center gap-2 text-decoration-none px-2 py-2 rounded-3" href="/admin/reports" style="opacity:0.9;">
                                <i class="bi bi-flag"></i>
                                <span class="small">Reports</span>
                            </a>
                            <a class="d-flex align-items-center gap-2 text-decoration-none px-2 py-2 rounded-3" href="/admin/kyc" style="opacity:0.9;">
                                <i class="bi bi-patch-check"></i>
                                <span class="small">KYC / Verification</span>
                            </a>
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingMarketplace">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseMarketplace" aria-expanded="false" aria-controls="collapseMarketplace">
                            <i class="bi bi-briefcase me-2"></i> Marketplace
                        </button>
                    </h2>
                    <div id="collapseMarketplace" class="accordion-collapse collapse" aria-labelledby="headingMarketplace" data-bs-parent="#adminMenu">
                        <div class="accordion-body pt-0 pb-2">
                            <a class="d-flex align-items-center gap-2 text-decoration-none px-2 py-2 rounded-3" href="/admin/jobs" style="opacity:0.9;">
                                <i class="bi bi-card-checklist"></i>
                                <span class="small">Jobs Moderation</span>
                            </a>
                            <a class="d-flex align-items-center gap-2 text-decoration-none px-2 py-2 rounded-3" href="/admin/boost-views" style="opacity:0.9;">
                                <i class="bi bi-eye"></i>
                                <span class="small">Boost Views</span>
                            </a>
                            <a class="d-flex align-items-center gap-2 text-decoration-none px-2 py-2 rounded-3" href="/admin/categories" style="opacity:0.9;">
                                <i class="bi bi-tags"></i>
                                <span class="small">Categories</span>
                            </a>
                            <a class="d-flex align-items-center gap-2 text-decoration-none px-2 py-2 rounded-3" href="/admin/skills" style="opacity:0.9;">
                                <i class="bi bi-stars"></i>
                                <span class="small">Skills</span>
                            </a>
                            <a class="d-flex align-items-center gap-2 text-decoration-none px-2 py-2 rounded-3" href="/admin/proposals" style="opacity:0.9;">
                                <i class="bi bi-send"></i>
                                <span class="small">Proposals</span>
                            </a>
                            <a class="d-flex align-items-center gap-2 text-decoration-none px-2 py-2 rounded-3" href="/admin/contracts" style="opacity:0.9;">
                                <i class="bi bi-file-earmark-text"></i>
                                <span class="small">Contracts</span>
                            </a>
                            <a class="d-flex align-items-center gap-2 text-decoration-none px-2 py-2 rounded-3" href="/admin/reviews" style="opacity:0.9;">
                                <i class="bi bi-star"></i>
                                <span class="small">Reviews</span>
                            </a>
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingFinance">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFinance" aria-expanded="false" aria-controls="collapseFinance">
                            <i class="bi bi-cash-coin me-2"></i> Finance
                        </button>
                    </h2>
                    <div id="collapseFinance" class="accordion-collapse collapse" aria-labelledby="headingFinance" data-bs-parent="#adminMenu">
                        <div class="accordion-body pt-0 pb-2">
                            <a class="d-flex align-items-center gap-2 text-decoration-none px-2 py-2 rounded-3" href="/admin/transactions" style="opacity:0.9;">
                                <i class="bi bi-receipt"></i>
                                <span class="small">Transactions</span>
                            </a>
                            <a class="d-flex align-items-center gap-2 text-decoration-none px-2 py-2 rounded-3" href="/admin/withdrawals" style="opacity:0.9;">
                                <i class="bi bi-box-arrow-up-right"></i>
                                <span class="small">Withdrawals</span>
                            </a>
                            <a class="d-flex align-items-center gap-2 text-decoration-none px-2 py-2 rounded-3" href="/admin/paypal-settings" style="opacity:0.9;">
                                <i class="bi bi-paypal"></i>
                                <span class="small">PayPal Settings</span>
                            </a>
                            <a class="d-flex align-items-center gap-2 text-decoration-none px-2 py-2 rounded-3" href="/admin/plans" style="opacity:0.9;">
                                <i class="bi bi-layers"></i>
                                <span class="small">Plans</span>
                            </a>
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingCms">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseCms" aria-expanded="false" aria-controls="collapseCms">
                            <i class="bi bi-layout-text-window-reverse me-2"></i> CMS & UI
                        </button>
                    </h2>
                    <div id="collapseCms" class="accordion-collapse collapse" aria-labelledby="headingCms" data-bs-parent="#adminMenu">
                        <div class="accordion-body pt-0 pb-2">
                            <a class="d-flex align-items-center gap-2 text-decoration-none px-2 py-2 rounded-3" href="/admin/menus" style="opacity:0.9;">
                                <i class="bi bi-diagram-3"></i>
                                <span class="small">Menus (Multi-level)</span>
                            </a>
                            <a class="d-flex align-items-center gap-2 text-decoration-none px-2 py-2 rounded-3" href="/admin/pages" style="opacity:0.9;">
                                <i class="bi bi-file-earmark"></i>
                                <span class="small">Pages</span>
                            </a>
                            <a class="d-flex align-items-center gap-2 text-decoration-none px-2 py-2 rounded-3" href="/admin/banners" style="opacity:0.9;">
                                <i class="bi bi-image"></i>
                                <span class="small">Banners</span>
                            </a>
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingSystem">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSystem" aria-expanded="false" aria-controls="collapseSystem">
                            <i class="bi bi-gear me-2"></i> System
                        </button>
                    </h2>
                    <div id="collapseSystem" class="accordion-collapse collapse" aria-labelledby="headingSystem" data-bs-parent="#adminMenu">
                        <div class="accordion-body pt-0 pb-2">
                            <a class="d-flex align-items-center gap-2 text-decoration-none px-2 py-2 rounded-3" href="/admin/settings" style="opacity:0.9;">
                                <i class="bi bi-sliders"></i>
                                <span class="small">System Settings</span>
                            </a>
                            <a class="d-flex align-items-center gap-2 text-decoration-none px-2 py-2 rounded-3" href="/admin/security" style="opacity:0.9;">
                                <i class="bi bi-shield-lock"></i>
                                <span class="small">Security</span>
                            </a>
                            <a class="d-flex align-items-center gap-2 text-decoration-none px-2 py-2 rounded-3" href="/admin/captcha-settings" style="opacity:0.9;">
                                <i class="bi bi-shield-check"></i>
                                <span class="small">Captcha Settings</span>
                            </a>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    </div>
</div>
