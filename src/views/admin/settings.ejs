<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vamper - System Settings</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/style.css">
    <style>
        .admin-page main { background: linear-gradient(180deg, #f6f8fc 0%, #f0f7ff 100%); }
        .admin-page .card { border: 1px solid #eef2f7; }
        .admin-page .admin-sidebar { background-color: #ffffff !important; }
        .admin-page .admin-sidebar .accordion,
        .admin-page .admin-sidebar .accordion-item,
        .admin-page .admin-sidebar .accordion-header,
        .admin-page .admin-sidebar .accordion-collapse,
        .admin-page .admin-sidebar .accordion-body { background-color: #ffffff !important; }
        .admin-page .admin-sidebar .accordion-item { border: 0 !important; }
        .admin-page .admin-sidebar .accordion-button {
            color: #0d1b2a !important; background: #ffffff !important;
            box-shadow: none !important; border-radius: 0.75rem !important;
            padding: 0.65rem 0.75rem !important; font-weight: 600;
        }
        .admin-page .admin-sidebar .accordion-button:hover { background: #f1f5ff !important; }
        .admin-page .admin-sidebar .accordion-button:not(.collapsed) { background: #e7f1ff !important; color: #0d6efd !important; }
        .admin-page .admin-sidebar .accordion-button i { color: #0d6efd !important; }
        .admin-page .admin-sidebar a { color: #0d1b2a !important; }
        .admin-page .admin-sidebar a:hover { background: #f1f5ff !important; color: #0d6efd !important; }
        .admin-page .admin-sidebar a, .admin-page .admin-sidebar a span, .admin-page .admin-sidebar a i { color: #0d1b2a !important; }
        .admin-page .admin-sidebar .accordion-body { padding: 0.35rem 0.25rem; }
        .admin-page .admin-sidebar .accordion-body a { padding: 0.5rem 0.6rem; border-radius: 0.6rem; }
        .admin-page .admin-sidebar-head { background: linear-gradient(135deg, #e7f1ff 0%, #ffe8f0 50%, #e6fbff 100%) !important; }
        .admin-page .admin-sidebar-head, .admin-page .admin-sidebar-head * { color: #0d1b2a !important; }
    </style>
</head>
<body class="admin-page">
    <%- include('../../public/header') %>

    <main class="container-fluid py-3 py-md-4">
        <div class="row g-0">
            <aside class="col-12 col-md-3 col-lg-2 pe-md-3 mb-3 mb-md-0">
                <%- include('layouts/menu') %>
            </aside>

            <section class="col-12 col-md-9 col-lg-10 ps-md-0">
                <div class="card border-0 shadow-sm rounded-4 mb-3">
                    <div class="card-body py-3 px-3 px-md-4">
                        <div class="d-flex align-items-center gap-2">
                            <button class="btn btn-sm btn-outline-secondary d-md-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#adminSidebar" aria-controls="adminSidebar">
                                <i class="bi bi-list"></i>
                            </button>
                            <div class="rounded-3 d-flex align-items-center justify-content-center" style="width:34px;height:34px;background:#e7f1ff;color:#0d6efd;">
                                <i class="bi bi-sliders"></i>
                            </div>
                            <div>
                                <div class="fw-bold">System Settings</div>
                                <div class="text-muted small">Configure platform-wide settings</div>
                            </div>
                        </div>
                    </div>
                </div>

                <% if (typeof success_msg !== 'undefined' && success_msg && success_msg.length) { %>
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i><%= success_msg %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>
                <% if (typeof error_msg !== 'undefined' && error_msg && error_msg.length) { %>
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error_msg %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>

                <ul class="nav nav-pills flex-nowrap overflow-auto mb-3" id="settingsTab" role="tablist" style="gap:.5rem;">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" data-bs-toggle="pill" data-bs-target="#pane-general" type="button">
                            <i class="bi bi-globe me-1"></i> General
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" data-bs-toggle="pill" data-bs-target="#pane-finance" type="button">
                            <i class="bi bi-cash-coin me-1"></i> Finance
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" data-bs-toggle="pill" data-bs-target="#pane-registration" type="button">
                            <i class="bi bi-person-plus me-1"></i> Registration
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" data-bs-toggle="pill" data-bs-target="#pane-email" type="button">
                            <i class="bi bi-envelope me-1"></i> Email / SMTP
                        </button>
                    </li>
                </ul>

                <div class="tab-content" id="settingsTabContent">

                    <!-- General -->
                    <div class="tab-pane fade show active" id="pane-general" role="tabpanel">
                        <div class="card border-0 shadow-sm rounded-4">
                            <div class="card-body p-3 p-md-4">
                                <div class="fw-bold mb-1">General</div>
                                <div class="text-muted small mb-4">Basic information about your platform</div>
                                <form method="POST" action="/admin/settings/update">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <input type="hidden" name="group" value="general">
                                    <div class="row g-3">
                                        <div class="col-12 col-md-6">
                                            <label class="form-label">Site Name</label>
                                            <input type="text" name="site_name" class="form-control" value="<%= s.site_name || 'Vamper' %>" required>
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <label class="form-label">Site URL</label>
                                            <input type="url" name="site_url" class="form-control" value="<%= s.site_url || '' %>" placeholder="https://vamper.xyz">
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label">Site Description</label>
                                            <textarea name="site_description" class="form-control" rows="2"><%= s.site_description || '' %></textarea>
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <label class="form-label">Timezone</label>
                                            <select name="site_timezone" class="form-select">
                                                <% const timezones = ['Asia/Ho_Chi_Minh','Asia/Bangkok','Asia/Singapore','Asia/Tokyo','UTC','America/New_York','America/Los_Angeles','Europe/London','Europe/Paris']; %>
                                                <% timezones.forEach(tz => { %>
                                                    <option value="<%= tz %>" <%= (s.site_timezone || 'Asia/Ho_Chi_Minh') === tz ? 'selected' : '' %>><%= tz %></option>
                                                <% }); %>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="mt-4">
                                        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Save General</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Finance -->
                    <div class="tab-pane fade" id="pane-finance" role="tabpanel">
                        <div class="card border-0 shadow-sm rounded-4">
                            <div class="card-body p-3 p-md-4">
                                <div class="fw-bold mb-1">Finance</div>
                                <div class="text-muted small mb-4">Commission rates and withdrawal rules</div>
                                <form method="POST" action="/admin/settings/update">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <input type="hidden" name="group" value="finance">
                                    <div class="row g-3">
                                        <div class="col-12 col-md-4">
                                            <label class="form-label">Platform Commission (%)</label>
                                            <div class="input-group">
                                                <input type="number" name="platform_commission_percent" class="form-control" value="<%= s.platform_commission_percent || '10' %>" min="0" max="100" step="0.1">
                                                <span class="input-group-text">%</span>
                                            </div>
                                            <div class="form-text">Fee deducted from each completed contract payment.</div>
                                        </div>
                                        <div class="col-12 col-md-4">
                                            <label class="form-label">Min Withdrawal (Credits)</label>
                                            <input type="number" name="min_withdrawal_credits" class="form-control" value="<%= s.min_withdrawal_credits || '100' %>" min="1">
                                            <div class="form-text">Minimum credits required to request a withdrawal.</div>
                                        </div>
                                        <div class="col-12 col-md-4">
                                            <label class="form-label">Credits → USD Rate</label>
                                            <div class="input-group">
                                                <span class="input-group-text">1 Credit =</span>
                                                <input type="number" name="credits_to_usd_rate" class="form-control" value="<%= s.credits_to_usd_rate || '0.01' %>" min="0.001" step="0.001">
                                                <span class="input-group-text">USD</span>
                                            </div>
                                            <div class="form-text">Exchange rate used for withdrawals.</div>
                                        </div>
                                    </div>
                                    <div class="mt-4">
                                        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Save Finance</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Registration -->
                    <div class="tab-pane fade" id="pane-registration" role="tabpanel">
                        <div class="card border-0 shadow-sm rounded-4">
                            <div class="card-body p-3 p-md-4">
                                <div class="fw-bold mb-1">Registration</div>
                                <div class="text-muted small mb-4">Control who can sign up on the platform</div>
                                <form method="POST" action="/admin/settings/update">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <input type="hidden" name="group" value="registration">
                                    <div class="d-flex flex-column gap-3">
                                        <div class="card border rounded-3 p-3">
                                            <div class="d-flex align-items-center justify-content-between">
                                                <div>
                                                    <div class="fw-semibold">Allow New Registrations</div>
                                                    <div class="text-muted small">When disabled, no new accounts can be created.</div>
                                                </div>
                                                <div class="form-check form-switch ms-3">
                                                    <input class="form-check-input" type="checkbox" name="registration_enabled" value="1" id="regEnabled" style="transform:scale(1.4);" <%= s.registration_enabled === '1' ? 'checked' : '' %>>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="card border rounded-3 p-3">
                                            <div class="d-flex align-items-center justify-content-between">
                                                <div>
                                                    <div class="fw-semibold">Require Email Verification</div>
                                                    <div class="text-muted small">Users must verify their email before accessing the platform.</div>
                                                </div>
                                                <div class="form-check form-switch ms-3">
                                                    <input class="form-check-input" type="checkbox" name="email_verification_required" value="1" id="emailVerify" style="transform:scale(1.4);" <%= s.email_verification_required === '1' ? 'checked' : '' %>>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="mt-4">
                                        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Save Registration</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Email / SMTP -->
                    <div class="tab-pane fade" id="pane-email" role="tabpanel">
                        <div class="card border-0 shadow-sm rounded-4">
                            <div class="card-body p-3 p-md-4">
                                <div class="fw-bold mb-1">Email / SMTP</div>
                                <div class="text-muted small mb-4">Configure outgoing email settings</div>
                                <form method="POST" action="/admin/settings/update">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <input type="hidden" name="group" value="email">
                                    <div class="row g-3">
                                        <div class="col-12 col-md-8">
                                            <label class="form-label">SMTP Host</label>
                                            <input type="text" name="mail_host" class="form-control" value="<%= s.mail_host || 'smtp.gmail.com' %>" placeholder="smtp.gmail.com">
                                        </div>
                                        <div class="col-12 col-md-4">
                                            <label class="form-label">SMTP Port</label>
                                            <input type="number" name="mail_port" class="form-control" value="<%= s.mail_port || '587' %>">
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <label class="form-label">SMTP Username</label>
                                            <input type="text" name="mail_user" class="form-control" value="<%= s.mail_user || '' %>" placeholder="your@gmail.com">
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <label class="form-label">SMTP Password</label>
                                            <div class="input-group">
                                                <input type="password" name="mail_pass" class="form-control" id="smtpPass" value="<%= s.mail_pass || '' %>" placeholder="App password">
                                                <button class="btn btn-outline-secondary" type="button" onclick="var i=document.getElementById('smtpPass');i.type=i.type==='password'?'text':'password';">
                                                    <i class="bi bi-eye"></i>
                                                </button>
                                            </div>
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <label class="form-label">From Name</label>
                                            <input type="text" name="mail_from_name" class="form-control" value="<%= s.mail_from_name || 'Vamper' %>">
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <label class="form-label">From Address</label>
                                            <input type="email" name="mail_from_address" class="form-control" value="<%= s.mail_from_address || '' %>" placeholder="noreply@vamper.xyz">
                                        </div>
                                    </div>
                                    <div class="mt-4 d-flex gap-2 flex-wrap">
                                        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Save Email</button>
                                        <button type="button" class="btn btn-outline-secondary" id="testMailBtn">
                                            <i class="bi bi-send me-1"></i> Send Test Email
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                </div>
            </section>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Restore active tab from hash
        (function() {
            const hash = window.location.hash;
            if (hash) {
                const btn = document.querySelector('[data-bs-target="' + hash + '"]');
                if (btn) bootstrap.Tab.getOrCreateInstance(btn).show();
            }
        })();

        // Test mail button
        document.getElementById('testMailBtn').addEventListener('click', function() {
            const btn = this;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Sending...';
            fetch('/admin/settings/test-email', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= csrfToken %>' },
                body: JSON.stringify({})
            })
            .then(r => r.json())
            .then(d => {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-send me-1"></i> Send Test Email';
                alert(d.success ? 'Test email sent to ' + d.to : 'Failed: ' + d.message);
            })
            .catch(() => {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-send me-1"></i> Send Test Email';
                alert('Request failed.');
            });
        });
    </script>
</body>
</html>
