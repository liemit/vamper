<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vamper - Security</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/style.css">

    <style>
        
        .admin-page main {
            background: linear-gradient(180deg, #f6f8fc 0%, #f0f7ff 100%);
        }

        .admin-page .card {
            border: 1px solid #eef2f7;
        }

        .admin-page .accordion-button::after {
            filter: none;
        }

        .admin-page .admin-sidebar {
            background-color: #ffffff !important;
        }

        .admin-page .admin-sidebar .accordion,
        .admin-page .admin-sidebar .accordion-item,
        .admin-page .admin-sidebar .accordion-header,
        .admin-page .admin-sidebar .accordion-collapse,
        .admin-page .admin-sidebar .accordion-body {
            background-color: #ffffff !important;
        }

        .admin-page .admin-sidebar .accordion-item {
            border: 0 !important;
        }

        .admin-page .admin-sidebar .input-group-text,
        .admin-page .admin-sidebar .form-control {
            border-color: #dee2e6 !important;
        }

        .admin-page .admin-sidebar .form-control::placeholder {
            color: #6c757d !important;
        }

        .admin-page .admin-sidebar .accordion-button {
            color: #0d1b2a !important;
            background: #ffffff !important;
            box-shadow: none !important;
            border-radius: 0.75rem !important;
            padding: 0.65rem 0.75rem !important;
            font-weight: 600;
        }

        .admin-page .admin-sidebar .accordion-button:hover {
            background: #f1f5ff !important;
        }

        .admin-page .admin-sidebar .accordion-button:not(.collapsed) {
            background: #e7f1ff !important;
            color: #0d6efd !important;
        }

        .admin-page .admin-sidebar .accordion-button.collapsed {
            background: #ffffff !important;
        }

        .admin-page .admin-sidebar .accordion-button i {
            color: #0d6efd !important;
        }

        .admin-page .admin-sidebar a {
            color: #0d1b2a !important;
        }

        .admin-page .admin-sidebar a:hover {
            background: #f1f5ff !important;
            color: #0d6efd !important;
        }

        .admin-page .admin-sidebar a,
        .admin-page .admin-sidebar a span,
        .admin-page .admin-sidebar a i {
            color: #0d1b2a !important;
        }

        .admin-page .admin-sidebar .accordion-body {
            padding: 0.35rem 0.25rem;
        }

        .admin-page .admin-sidebar .accordion-body a {
            padding: 0.5rem 0.6rem;
            border-radius: 0.6rem;
        }

        .admin-page .admin-sidebar a[style*="background"] {
            background: #e7f1ff !important;
            color: #0d6efd !important;
        }

        .admin-page .admin-sidebar-head {
            background: linear-gradient(135deg, #e7f1ff 0%, #ffe8f0 50%, #e6fbff 100%) !important;
        }

        .admin-page .admin-sidebar-head,
        .admin-page .admin-sidebar-head * {
            color: #0d1b2a !important;
        }
    </style>
</head>

<body class="admin-page">
    <%- include('../../public/header') %>

    <main class="container-fluid py-3 py-md-4">
        <div class="row g-0">
            <aside class="col-12 col-md-3 col-lg-2 pe-md-3 mb-3 mb-md-0">
                <%- include('layouts/menu') %>
            </aside>

            <section class="col-12 col-md-9 col-lg-10 ps-md-0">
                <div class="card border-0 shadow-sm rounded-4 mb-3">
                    <div class="card-body py-3 px-3 px-md-4">
                        <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between gap-3">
                            <div>
                                <div class="d-flex align-items-center gap-2">
                                    <button class="btn btn-sm btn-outline-secondary d-md-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#adminSidebar" aria-controls="adminSidebar">
                                        <i class="bi bi-list"></i>
                                    </button>
                                    <div class="rounded-3 d-flex align-items-center justify-content-center" style="width: 34px; height: 34px; background: #e7f1ff; color: #0d6efd;">
                                        <i class="bi bi-shield-lock"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold">Security</div>
                                        <div class="text-muted small">Security modules & platform protection tools</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <% if (typeof success_msg !== 'undefined' && success_msg && success_msg.length) { %>
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i><%= success_msg %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>

                <% if (typeof error_msg !== 'undefined' && error_msg && error_msg.length) { %>
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error_msg %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>

                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-3 p-md-4">
                        <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between gap-2 mb-3">
                            <div>
                                <div class="fw-bold">Security Modules</div>
                                <div class="text-muted small">Manage multiple security features in one place</div>
                            </div>
                        </div>

                        <ul class="nav nav-pills flex-nowrap overflow-auto" id="securityTab" role="tablist" style="gap: .5rem;">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active" id="tab-content-filter" data-bs-toggle="pill" data-bs-target="#pane-content-filter" type="button" role="tab" aria-controls="pane-content-filter" aria-selected="true">
                                    <i class="bi bi-funnel me-1"></i> Content Filter
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="tab-account-limits" data-bs-toggle="pill" data-bs-target="#pane-account-limits" type="button" role="tab" aria-controls="pane-account-limits" aria-selected="false">
                                    <i class="bi bi-person-lock me-1"></i> Account Limits
                                </button>
                            </li>

                        </ul>

                        <div class="tab-content pt-3" id="securityTabContent">
                            <div class="tab-pane fade show active" id="pane-content-filter" role="tabpanel" aria-labelledby="tab-content-filter" tabindex="0">
                                <div class="row g-3">
                                    <div class="col-12 col-lg-4">
                                        <div class="card border-0 shadow-sm rounded-4">
                                            <div class="card-body p-3 p-md-4">
                                                <div class="d-flex align-items-center justify-content-between mb-3">
                                                    <div>
                                                        <div class="fw-bold">Add rule</div>
                                                        <div class="text-muted small">Mask sensitive info with <span class="fw-semibold">***</span></div>
                                                    </div>
                                                </div>

                                                <form method="POST" action="/admin/security/rules">
                                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                                                    <div class="mb-3">
                                                        <label class="form-label">Preset</label>
                                                        <select class="form-select" id="contentFilterPreset">
                                                            <option value="" selected>Custom</option>
                                                            <option value="phone_vn">Phone number (VN)</option>
                                                            <option value="phone_international_plus">Phone number (International +)</option>
                                                            <option value="phone_us">Phone number (US/Canada)</option>
                                                            <option value="phone_uk_basic">Phone number (UK - basic)</option>
                                                            <option value="phone_aggressive">Phone number (Aggressive)</option>
                                                            <option value="email">Email</option>
                                                            <option value="url">Link / URL</option>
                                                            <option value="facebook">Facebook link</option>
                                                            <option value="zalo">Zalo</option>
                                                        </select>
                                                        <div class="form-text">Pick a preset to auto-fill pattern and match type.</div>
                                                    </div>

                                                    <div class="mb-3">
                                                        <label class="form-label">Pattern</label>
                                                        <input type="text" name="pattern" class="form-control" id="contentFilterPattern" placeholder="e.g. zalo, facebook.com, http" required>
                                                    </div>

                                                    <div class="mb-3">
                                                        <label class="form-label">Match type</label>
                                                        <select name="match_type" class="form-select" id="contentFilterMatchType">
                                                            <option value="keyword" selected>Keyword</option>
                                                            <option value="regex">Regex</option>
                                                        </select>
                                                    </div>

                                                    <div class="mb-3">
                                                        <label class="form-label">Mask with</label>
                                                        <input type="text" name="mask_with" class="form-control" id="contentFilterMaskWith" value="***">
                                                    </div>

                                                    <div class="mb-3">
                                                        <div class="form-check">
                                                            <input class="form-check-input" type="checkbox" value="1" id="apply_globally" name="apply_globally">
                                                            <label class="form-check-label" for="apply_globally">Apply globally (all pages)</label>
                                                        </div>
                                                        <div class="form-check">
                                                            <input class="form-check-input" type="checkbox" value="1" id="apply_selected_pages" name="apply_selected_pages" checked>
                                                            <label class="form-check-label" for="apply_selected_pages">Apply selected pages</label>
                                                        </div>
                                                        <div class="form-text">Enable only one mode (global or selected pages) for clearer behavior.</div>
                                                    </div>

                                                    <div class="mb-3">
                                                        <label class="form-label">Pages</label>
                                                        <div class="d-flex flex-column gap-2">
                                                            <% (availablePages || []).forEach(function(p){ %>
                                                                <div class="form-check">
                                                                    <input class="form-check-input" type="checkbox" name="pages" value="<%= p.key %>" id="page_add_<%= p.key %>">
                                                                    <label class="form-check-label" for="page_add_<%= p.key %>"><%= p.label %></label>
                                                                </div>
                                                            <% }); %>
                                                        </div>
                                                    </div>

                                                    <div class="mb-3">
                                                        <div class="form-check">
                                                            <input class="form-check-input" type="checkbox" value="1" id="is_active" name="is_active" checked>
                                                            <label class="form-check-label" for="is_active">Active</label>
                                                        </div>
                                                    </div>

                                                    <div class="d-grid">
                                                        <button type="submit" class="btn btn-primary">
                                                            <i class="bi bi-plus-lg me-1"></i> Add rule
                                                        </button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-12 col-lg-8">
                                        <div class="card border-0 shadow-sm rounded-4">
                                            <div class="card-header bg-transparent border-0 px-3 px-md-4 pt-4 pb-0 d-flex align-items-center justify-content-between flex-wrap gap-2">
                                                <div>
                                                    <div class="fw-bold">Rules</div>
                                                    <div class="text-muted small">Edit, activate/deactivate, or delete rules</div>
                                                </div>
                                                <div class="text-muted small">Total: <span class="fw-semibold text-dark"><%= Array.isArray(rules) ? rules.length : 0 %></span></div>
                                            </div>

                                            <div class="card-body px-3 px-md-4 pb-4">
                                                <% const list = Array.isArray(rules) ? rules : []; %>
                                                <% if (!list.length) { %>
                                                    <div class="p-4 border rounded-4 bg-light">
                                                        <div class="fw-bold">No rules yet</div>
                                                        <div class="text-muted">Add your first rule on the left.</div>
                                                    </div>
                                                <% } else { %>
                                                    <div class="d-flex flex-column gap-3">
                                                        <% list.forEach(function(r){ %>
                                                            <% const pages = (rulePagesMap && rulePagesMap[String(r.id)]) ? rulePagesMap[String(r.id)] : []; %>
                                                            <div class="border rounded-4 p-3">
                                                                <div class="d-flex flex-wrap align-items-start justify-content-between gap-2 mb-2">
                                                                    <div>
                                                                        <div class="fw-bold"><span class="text-muted">#<%= r.id %></span> <%= r.pattern %></div>
                                                                        <div class="text-muted small">
                                                                            match: <span class="fw-semibold"><%= r.match_type %></span>
                                                                            · mask: <span class="fw-semibold"><%= r.mask_with || '***' %></span>
                                                                        </div>
                                                                    </div>
                                                                    <form method="POST" action="/admin/security/rules/<%= r.id %>/delete" onsubmit="return confirm('Delete this rule?');">
                                                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                                                            <i class="bi bi-trash"></i>
                                                                        </button>
                                                                    </form>
                                                                </div>

                                                                <form method="POST" action="/admin/security/rules/<%= r.id %>/update">
                                                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                                                                    <div class="row g-2">
                                                                        <div class="col-12 col-md-6">
                                                                            <label class="form-label small text-muted mb-1">Pattern</label>
                                                                            <input type="text" name="pattern" class="form-control form-control-sm" value="<%= r.pattern %>" required>
                                                                        </div>
                                                                        <div class="col-6 col-md-3">
                                                                            <label class="form-label small text-muted mb-1">Match</label>
                                                                            <select name="match_type" class="form-select form-select-sm">
                                                                                <option value="keyword" <%= r.match_type === 'keyword' ? 'selected' : '' %>>keyword</option>
                                                                                <option value="regex" <%= r.match_type === 'regex' ? 'selected' : '' %>>regex</option>
                                                                            </select>
                                                                        </div>
                                                                        <div class="col-6 col-md-3">
                                                                            <label class="form-label small text-muted mb-1">Mask</label>
                                                                            <input type="text" name="mask_with" class="form-control form-control-sm" value="<%= r.mask_with || '***' %>">
                                                                        </div>

                                                                        <div class="col-12">
                                                                            <div class="d-flex flex-wrap gap-3">
                                                                                <div class="form-check">
                                                                                    <input class="form-check-input" type="checkbox" name="apply_globally" id="global_<%= r.id %>" value="1" <%= r.apply_globally ? 'checked' : '' %>>
                                                                                    <label class="form-check-label" for="global_<%= r.id %>">Apply globally</label>
                                                                                </div>
                                                                                <div class="form-check">
                                                                                    <input class="form-check-input" type="checkbox" name="apply_selected_pages" id="selected_<%= r.id %>" value="1" <%= r.apply_selected_pages ? 'checked' : '' %>>
                                                                                    <label class="form-check-label" for="selected_<%= r.id %>">Apply selected pages</label>
                                                                                </div>
                                                                                <div class="form-check">
                                                                                    <input class="form-check-input" type="checkbox" name="is_active" id="active_<%= r.id %>" value="1" <%= r.is_active ? 'checked' : '' %>>
                                                                                    <label class="form-check-label" for="active_<%= r.id %>">Active</label>
                                                                                </div>
                                                                            </div>
                                                                        </div>

                                                                        <div class="col-12">
                                                                            <div class="small text-muted mb-2">Pages</div>
                                                                            <div class="d-flex flex-wrap gap-3">
                                                                                <% (availablePages || []).forEach(function(p){ %>
                                                                                    <% const checked = pages.includes(p.key); %>
                                                                                    <div class="form-check">
                                                                                        <input class="form-check-input" type="checkbox" name="pages" value="<%= p.key %>" id="page_<%= r.id %>_<%= p.key %>" <%= checked ? 'checked' : '' %>>
                                                                                        <label class="form-check-label" for="page_<%= r.id %>_<%= p.key %>"><%= p.label %></label>
                                                                                    </div>
                                                                                <% }); %>
                                                                            </div>
                                                                        </div>

                                                                        <div class="col-12 d-flex justify-content-end">
                                                                            <button type="submit" class="btn btn-sm btn-primary">
                                                                                <i class="bi bi-save me-1"></i> Save
                                                                            </button>
                                                                        </div>
                                                                    </div>
                                                                </form>
                                                            </div>
                                                        <% }); %>
                                                    </div>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="tab-pane fade" id="pane-account-limits" role="tabpanel" aria-labelledby="tab-account-limits" tabindex="0">
                                <div class="row g-3">
                                    <!-- Maintenance Mode Control -->
                                    <div class="col-12">
                                        <div class="card border-0 shadow-sm rounded-4 border-warning border-start border-4">
                                            <div class="card-body p-3 p-md-4 d-flex justify-content-between align-items-center">
                                                <div>
                                                    <div class="fw-bold fs-5 text-dark"><i class="bi bi-tools text-warning me-2"></i> System Maintenance Mode</div>
                                                    <div class="text-muted small mt-1">When enabled, the entire site will be inaccessible to users except for Admin accounts. Use this when updating the platform.</div>
                                                </div>
                                                <div class="form-check form-switch ms-3">
                                                    <input class="form-check-input" type="checkbox" role="switch" id="maintenanceToggle" style="transform: scale(1.5);">
                                                    <label class="form-check-label ms-2 d-none d-md-block" for="maintenanceToggle">Toggle Mode</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-12 col-lg-8">
                                        <div class="card border-0 shadow-sm rounded-4">
                                            <div class="card-body p-3 p-md-4">
                                                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                                                    <div>
                                                        <div class="fw-bold">Account Limits</div>
                                                        <div class="text-muted small">Limit accounts per device/IP, prevent spam registrations</div>
                                                    </div>
                                                    <span class="badge <%= accountLimits.enabled ? 'bg-success-subtle text-success' : 'bg-secondary-subtle text-secondary' %>">
                                                        <%= accountLimits.enabled ? 'Active' : 'Disabled' %>
                                                    </span>
                                                </div>
                                                <form method="POST" action="/admin/security/account-limits/save?_csrf=<%= csrfToken %>">
                                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                    <div class="mb-3 form-check form-switch">
                                                        <input class="form-check-input" type="checkbox" role="switch" id="accountLimitEnabled" name="account_limit_enabled" value="1" <%= accountLimits.enabled ? 'checked' : '' %>>
                                                        <label class="form-check-label fw-semibold" for="accountLimitEnabled">Enable Account Limit Enforcement</label>
                                                    </div>
                                                    <div class="row g-3 mb-3">
                                                        <div class="col-12 col-md-4">
                                                            <label class="form-label small fw-semibold">Max accounts per device</label>
                                                            <input type="number" name="max_accounts_per_device" class="form-control" min="1" max="99" value="<%= accountLimits.max_per_device %>">
                                                            <div class="form-text">Tracked via browser cookie</div>
                                                        </div>
                                                        <div class="col-12 col-md-4">
                                                            <label class="form-label small fw-semibold">Max accounts per IP</label>
                                                            <input type="number" name="max_accounts_per_ip" class="form-control" min="1" max="999" value="<%= accountLimits.max_per_ip %>">
                                                            <div class="form-text">Total from same IP address</div>
                                                        </div>
                                                        <div class="col-12 col-md-4">
                                                            <label class="form-label small fw-semibold">Max signups per IP / 24h</label>
                                                            <input type="number" name="max_signups_per_ip_per_day" class="form-control" min="1" max="999" value="<%= accountLimits.max_per_ip_per_day %>">
                                                            <div class="form-text">Rate limit per day</div>
                                                        </div>
                                                    </div>
                                                    <div class="mb-3">
                                                        <label class="form-label small fw-semibold">Error message shown to blocked users</label>
                                                        <textarea name="account_limit_message" class="form-control" rows="3"><%= accountLimits.message %></textarea>
                                                        <div class="form-text">Displayed when registration is blocked</div>
                                                    </div>
                                                    <button type="submit" class="btn btn-primary">
                                                        <i class="bi bi-save me-1"></i> Save Settings
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-12 col-lg-4">
                                        <div class="card border-0 shadow-sm rounded-4">
                                            <div class="card-body p-3 p-md-4">
                                                <div class="fw-bold mb-1"><i class="bi bi-info-circle text-primary me-1"></i> How it works</div>
                                                <div class="text-muted small mb-3">When a user tries to register, the system checks:</div>
                                                <div class="d-flex flex-column gap-2">
                                                    <div class="border rounded-3 p-2 bg-light small"><i class="bi bi-phone me-1 text-primary"></i> <strong>Device</strong> — counts accounts from same browser/cookie</div>
                                                    <div class="border rounded-3 p-2 bg-light small"><i class="bi bi-globe me-1 text-warning"></i> <strong>IP total</strong> — counts all accounts from this IP</div>
                                                    <div class="border rounded-3 p-2 bg-light small"><i class="bi bi-clock me-1 text-danger"></i> <strong>IP daily rate</strong> — registrations from this IP in last 24h</div>
                                                    <div class="border rounded-3 p-2 bg-light small"><i class="bi bi-x-circle me-1 text-danger"></i> If any limit exceeded → registration blocked</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>


                        </div>
                    </div>
                </div>
            </section>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script>
        (function () {
            const presetEl = document.getElementById('contentFilterPreset');
            const patternEl = document.getElementById('contentFilterPattern');
            const matchTypeEl = document.getElementById('contentFilterMatchType');
            const maskWithEl = document.getElementById('contentFilterMaskWith');

            if (!presetEl || !patternEl || !matchTypeEl || !maskWithEl) return;

            const presets = {
                phone_vn: {
                    pattern: '(\\+?84|0)(\\s|\\.|-)?\\d{2,3}(\\s|\\.|-)?\\d{3}(\\s|\\.|-)?\\d{3,4}',
                    match_type: 'regex',
                    mask_with: '***'
                },
                phone_international_plus: {
                    pattern: '\\+\\d{1,3}[\\s.\\-]?\\d[\\d\\s.\\-]{6,}\\d',
                    match_type: 'regex',
                    mask_with: '***'
                },
                phone_us: {
                    pattern: '(\\+?1[\\s.\\-]?)?\\(?\\d{3}\\)?[\\s.\\-]?\\d{3}[\\s.\\-]?\\d{4}',
                    match_type: 'regex',
                    mask_with: '***'
                },
                phone_uk_basic: {
                    pattern: '(\\+?44[\\s.\\-]?)?\\d[\\d\\s.\\-]{8,}\\d',
                    match_type: 'regex',
                    mask_with: '***'
                },
                phone_aggressive: {
                    pattern: '\\b\\d[\\d\\s.\\-]{7,}\\d\\b',
                    match_type: 'regex',
                    mask_with: '***'
                },
                email: {
                    pattern: '[A-Z0-9._%+-]+@[A-Z0-9.-]+\\.[A-Z]{2,}',
                    match_type: 'regex',
                    mask_with: '***'
                },
                url: {
                    pattern: 'https',
                    match_type: 'keyword',
                    mask_with: '***'
                },
                facebook: {
                    pattern: 'facebook.com',
                    match_type: 'keyword',
                    mask_with: '***'
                },
                zalo: {
                    pattern: 'zalo',
                    match_type: 'keyword',
                    mask_with: '***'
                }
            };

            presetEl.addEventListener('change', function () {
                const key = String(presetEl.value || '');
                const preset = presets[key];
                if (!preset) return;

                patternEl.value = preset.pattern;
                matchTypeEl.value = preset.match_type;
                maskWithEl.value = preset.mask_with;
            });
        })();
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const maintenanceToggle = document.getElementById('maintenanceToggle');
            const csrfToken = document.querySelector('input[name="_csrf"]').value;

            // Fetch current maintenance status
            fetch('/admin/maintenance/status')
                .then(res => res.json())
                .then(data => {
                    maintenanceToggle.checked = data.maintenance;
                })
                .catch(err => console.error('Failed to load maintenance status', err));

            // Handle toggle
            maintenanceToggle.addEventListener('change', () => {
                fetch('/admin/maintenance/toggle', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'CSRF-Token': csrfToken
                    },
                    body: JSON.stringify({ _csrf: csrfToken })
                })
                .then(res => res.json())
                .then(data => {
                    if(data.success) {
                        alert(data.maintenance ? 'Maintenance Mode is now ENABLED' : 'Maintenance Mode is now DISABLED');
                    } else {
                        alert('Failed to toggle maintenance mode.');
                        maintenanceToggle.checked = !maintenanceToggle.checked; // Revert
                    }
                })
                .catch(err => {
                    console.error(err);
                    alert('Error toggling maintenance mode.');
                    maintenanceToggle.checked = !maintenanceToggle.checked; // Revert
                });
            });
        });
    </script>
</body>

</html>
