<!DOCTYPE html>
<html lang="<%= (typeof lang !== 'undefined' && lang) ? String(lang) : 'en' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= (typeof t === 'function') ? t('freelancer.messages.title', 'Messages') : 'Messages' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <style>
        .employer-messages .chat-shell {
            height: calc(100vh - 160px);
            min-height: 560px;
            display: flex;
            flex-direction: column;
        }

        .employer-messages .chat-header {
            padding: 14px 16px;
            border-bottom: 1px solid rgba(15, 23, 42, 0.08);
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }

        .employer-messages .chat-header-user {
            display: flex;
            align-items: center;
            gap: 12px;
            min-width: 0;
        }

        .employer-messages .chat-header-avatar {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            object-fit: cover;
            border: 1px solid rgba(15, 23, 42, 0.08);
        }

        .employer-messages .chat-header-info {
            min-width: 0;
        }

        .employer-messages .chat-header-info h5 {
            margin: 0;
            font-size: 16px;
            font-weight: 700;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .employer-messages .chat-pane-body {
            flex: 1;
            overflow: auto;
            padding: 16px;
            background: #ffffff;
        }

        .employer-messages .chat-thread {
            width: 100%;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .employer-messages .chat-msg {
            display: flex;
            align-items: flex-end;
            gap: 8px;
            width: fit-content;
            max-width: 100%;
        }

        .employer-messages .chat-msg.from-other {
            justify-content: flex-start;
            align-self: flex-start;
            margin-right: auto;
        }

        .employer-messages .chat-msg.from-me {
            justify-content: flex-end;
            align-self: flex-end;
            margin-left: auto;
        }

        .employer-messages .chat-msg.from-me {
            gap: 0;
        }

        .employer-messages .chat-msg.from-me .msg-avatar {
            display: none;
        }

        .employer-messages .msg-avatar {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            object-fit: cover;
            border: 1px solid rgba(15, 23, 42, 0.08);
        }

        .employer-messages .bubble {
            max-width: min(72ch, 78%);
            padding: 10px 12px;
            border-radius: 16px;
            line-height: 1.35;
        }

        .employer-messages .chat-msg.from-other .bubble {
            background: #f1f5f9;
            color: #0f172a;
            border-top-left-radius: 6px;
        }

        .employer-messages .chat-msg.from-me .bubble {
            margin-left: auto;
            background: #0d6efd;
            color: #ffffff;
            border-top-right-radius: 6px;
        }

        .employer-messages .bubble .meta {
            display: block;
            margin-top: 4px;
            font-size: 12px;
            opacity: 0.85;
        }

        .employer-messages .chat-msg.from-me .bubble .meta {
            text-align: right;
        }

        .employer-messages .composer-area {
            border-top: 1px solid rgba(15, 23, 42, 0.08);
            padding: 12px 16px;
            background: #fff;
        }

        .employer-messages .input-wrapper {
            display: flex;
            gap: 10px;
            align-items: flex-end;
        }

        .employer-messages .composer-input {
            width: 100%;
            resize: none;
            border: 1px solid rgba(15, 23, 42, 0.12);
            border-radius: 14px;
            padding: 10px 12px;
            outline: none;
        }

        .employer-messages .send-btn {
            border: 0;
            background: #0d6efd;
            color: #fff;
            width: 40px;
            height: 40px;
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .employer-messages .composer-tools {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .employer-messages .tool-btn {
            border: 1px solid rgba(15, 23, 42, 0.12);
            background: #fff;
            width: 36px;
            height: 36px;
            border-radius: 10px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
    </style>
</head>
<body>
    <%- include('../../public/header') %>

    <main class="container-fluid py-3 py-md-4">
        <div class="row">
            <%- include('./layouts/menu') %>

            <section class="col-md-9 ms-sm-auto col-lg-10 px-2 px-md-4 employer-messages">
                <div class="d-flex align-items-center justify-content-between pt-3 pb-2 mb-3 border-bottom">
                    <h1 class="h2"><%= (typeof t === 'function') ? t('freelancer.messages.heading', 'Messages') : 'Messages' %></h1>
                </div>

                <% const fr = (typeof freelancer !== 'undefined' && freelancer) ? freelancer : {}; %>
                <% const j = (typeof job !== 'undefined' && job) ? job : {}; %>
                <% const list = (typeof messages !== 'undefined' && Array.isArray(messages)) ? messages : []; %>
                <% const meId = (user && user.id) ? Number(user.id) : null; %>
                <% const frName = fr.full_name || (typeof t === 'function' ? t('employer.messages.unknown_freelancer', 'Freelancer') : 'Freelancer'); %>
                <% const frAvatar = fr.avatar_url || 'https://via.placeholder.com/40'; %>
                <% const jobType = (j && j.job_type) ? String(j.job_type) : ''; %>

                <div class="card">
                    <div class="card-body p-0">
                        <div class="chat-shell">
                            <!-- Chat Area (Facebook Style) -->
                            <section class="col-12 chat-col">
                                <div class="chat-header">
                                    <div class="chat-header-user">
                                        <img src="<%= frAvatar %>" class="chat-header-avatar" alt="Avatar">
                                        <div class="chat-header-info">
                                            <h5><%= frName %></h5>
                                            <div class="text-muted small">
                                                <% if (j && j.title) { %>
                                                    <i class="bi bi-briefcase me-1"></i><%= j.title %>
                                                <% } else { %>
                                                    <%= (typeof t === 'function') ? t('freelancer.messages.active_now', 'Active now') : 'Active now' %>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="d-flex align-items-center">
                                        <% if (fr && fr.id && (typeof toId !== 'undefined' && toId) && (j && j.id)) { %>
                                            <button type="button" class="btn btn-outline-secondary btn-sm me-2" id="btnOpenDispute" title="Report / Dispute" data-bs-toggle="modal" data-bs-target="#disputeModal">
                                                <i class="bi bi-info-circle"></i>
                                            </button>
                                        <% } %>
                                        <% if (j && j.id && typeof isDeposited !== 'undefined') { %>
                                            <% const jobType = (j.job_type) ? String(j.job_type).toLowerCase() : 'fixed_price'; %>
                                            
                                            <% if (jobType === 'hourly' && (isDeposited === 1 || isDeposited === true)) { %>
                                                <!-- Hourly Timer Control -->
                                                <div id="hourlyTimerControl" class="d-flex align-items-center me-3 border rounded px-2 py-1 bg-light shadow-sm">
                                                    <div class="me-2 text-end" style="line-height: 1.1;">
                                                        <div class="small text-muted" style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.5px;">Time Worked</div>
                                                        <div id="timerDisplay" class="fw-bold font-monospace text-dark">00:00:00</div>
                                                    </div>
                                                    <!-- Hide Est. Cost, merged into Pending logic or just hidden to reduce clutter -->
                                                    <div class="me-2 text-end border-start ps-2 d-none" style="line-height: 1.1;" id="timerCostContainer">
                                                        <div class="small text-muted" style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.5px;">Est. Cost</div>
                                                        <div id="timerCost" class="fw-bold text-success"><i class="bi bi-gem"></i> 0.00</div>
                                                    </div>
                                                    <div class="ms-2 border-start ps-2 text-end" style="line-height: 1.1;">
                                                        <div class="small text-muted" style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.5px;">Pending</div>
                                                        <div id="timerPending" class="fw-bold text-warning" title="Waiting for approval"><i class="bi bi-gem"></i> 0.00</div>
                                                    </div>
                                                    <div class="ms-2">
                                                        <button id="btnReleasePending" class="btn btn-sm btn-outline-primary py-0" style="font-size: 0.75rem;" title="Approve & Release Pending Amount" hidden>
                                                            Approve
                                                        </button>
                                                        <button id="btnRefundPending" class="btn btn-sm btn-outline-secondary py-0 ms-1" style="font-size: 0.75rem;" title="Refund Pending Amount to Employer Balance" hidden>
                                                            Refund
                                                        </button>
                                                    </div>
                                                    <div class="btn-group btn-group-sm ms-2">
                                                        <button id="btnStartTimer" class="btn btn-outline-success" title="Start Timer"><i class="bi bi-play-fill"></i></button>
                                                        <button id="btnStopTimer" class="btn btn-outline-danger" title="Stop Timer"><i class="bi bi-stop-fill"></i></button>
                                                    </div>
                                                </div>
                                            <% } %>

                                            <% if (isDeposited === 0 || isDeposited === false) { %>
                                                <button class="btn btn-warning btn-sm me-2" id="btnDeposit" data-job-id="<%= j.id %>" data-to-id="<%= fr.id %>">
                                                    <i class="bi bi-cash-coin me-1"></i><%= (jobType === 'hourly') ? 'Activate Contract' : 'Deposit' %>
                                                </button>
                                            <% } else if (isDeposited === 1 || isDeposited === true) { %>
                                                <% if (jobType === 'hourly') { %>
                                                    <span class="badge bg-info me-2" title="Security Bond Active"><i class="bi bi-shield-lock me-1"></i>Active</span>
                                                <% } else { %>
                                                    <span class="badge bg-success me-2" title="Funds held in escrow"><i class="bi bi-shield-check me-1"></i>Deposited</span>
                                                <% } %>
                                                
                                                <% if (jobType === 'hourly') { %>
                                                    <!-- Hourly: End Contract Button Only -->
                                                    <button class="btn btn-outline-danger btn-sm me-2" id="btnRefund" data-job-id="<%= j.id %>" data-to-id="<%= fr.id %>" onclick="return confirm('End contract and refund security bond?');">
                                                        <i class="bi bi-stop-circle me-1"></i>End Contract
                                                    </button>
                                                <% } else { %>
                                                    <button class="btn btn-primary btn-sm me-2" id="btnRelease" data-job-id="<%= j.id %>" data-to-id="<%= fr.id %>">
                                                        <i class="bi bi-check2-circle me-1"></i>Release Payment
                                                    </button>
                                                    <button class="btn btn-outline-danger btn-sm me-2" id="btnRefund" data-job-id="<%= j.id %>" data-to-id="<%= fr.id %>">
                                                        <i class="bi bi-arrow-counterclockwise me-1"></i>Refund
                                                    </button>
                                                <% } %>

                                            <% } else if (isDeposited === 2) { %>
                                                <span class="badge bg-primary me-2"><i class="bi bi-check-all me-1"></i>Paid</span>
                                            <% } %>
                                        <% } %>
                                        <% if (j && j.slug) { %>
                                            <a class="btn btn-outline-secondary btn-sm" href="/employer/jobs/edit/<%= j.id %>">
                                                <i class="bi bi-box-arrow-up-right me-1"></i><%= (typeof t === 'function') ? t('freelancer.messages.view_job', 'View job') : 'View job' %>
                                            </a>
                                        <% } %>
                                    </div>
                                </div>

                                <div class="chat-pane-body">
                                    <div class="chat-thread" id="chatThreadEmployer"
                                         data-me-id="<%= (user && user.id) ? user.id : '' %>"
                                         data-to-id="<%= (typeof toId !== 'undefined' && toId) ? toId : (fr && fr.id ? fr.id : '') %>"
                                         data-job-id="<%= (typeof jobId !== 'undefined' && jobId) ? jobId : (j && j.id ? j.id : '') %>"
                                         data-is-deposited="<%= (typeof isDeposited !== 'undefined' && isDeposited !== null) ? isDeposited : 0 %>"
                                         data-job-type="<%= (j && j.job_type) ? String(j.job_type) : '' %>"
                                         data-me-avatar="<%= (user && user.logo_url) ? user.logo_url : '' %>"
                                         data-other-avatar="<%= (fr && fr.avatar_url) ? fr.avatar_url : '' %>">
                                        <% if (!list.length) { %>
                                            <div class="text-center text-muted py-5">
                                                No messages yet. Say hi to start the conversation!
                                            </div>
                                        <% } %>

                                        <% list.forEach(function(m) { %>
                                            <% const isMe = (meId !== null && Number(m.sender_id) === Number(meId)); %>
                                            <% const rowClass = isMe ? 'from-me' : 'from-other'; %>
                                            <% const avatar = isMe
                                                ? ((user && user.logo_url) ? user.logo_url : 'https://via.placeholder.com/28')
                                                : (fr.avatar_url || m.sender_avatar || 'https://via.placeholder.com/28'); %>
                                            <div class="chat-msg <%= rowClass %>" data-msg-id="<%= m.id %>">
                                                <% if (!isMe) { %>
                                                    <img src="<%= avatar %>" class="msg-avatar" alt="User">
                                                <% } %>

                                                <% if (isMe) { %>
                                                    <button class="reply-btn me-2 btn-reply-action"
                                                        data-id="<%= m.id %>"
                                                        data-sender="You"
                                                        data-content="<%= (m.content || '').replace(/"/g, '&quot;') %>"
                                                        data-type="<%= m.attachment_type %>">
                                                        <i class="bi bi-reply-fill"></i>
                                                    </button>
                                                    <button class="reply-btn me-2 btn-delete-action text-danger" 
                                                        data-id="<%= m.id %>"
                                                        title="Delete message">
                                                        <i class="bi bi-trash-fill"></i>
                                                    </button>
                                                <% } %>

                                                <div class="bubble">
                                                    <% if (m.reply_to_id) { %>
                                                        <div class="replied-msg p-2 mb-2 rounded bg-light small" style="border-left: 4px solid #0d6efd; cursor: pointer; opacity: 0.9;" onclick="document.querySelector('[data-msg-id=\'<%= m.reply_to_id %>\']')?.scrollIntoView({behavior: 'smooth', block: 'center'})">
                                                            <div class="fw-bold text-primary mb-1">
                                                                <% if (m.reply_sender_id && Number(m.reply_sender_id) === Number(meId)) { %>
                                                                    You
                                                                <% } else { %>
                                                                    <%= frName %>
                                                                <% } %>
                                                            </div>
                                                            <div class="text-truncate text-muted" style="max-width: 200px;">
                                                                <% if (m.reply_attachment_type === 'image') { %>
                                                                    <i class="bi bi-image"></i> Photo
                                                                <% } else if (m.reply_attachment_type === 'video') { %>
                                                                    <i class="bi bi-camera-video"></i> Video
                                                                <% } else if (m.reply_attachment_type === 'file') { %>
                                                                    <i class="bi bi-paperclip"></i> File
                                                                <% } else { %>
                                                                    <%= m.reply_content %>
                                                                <% } %>
                                                            </div>
                                                        </div>
                                                    <% } %>

                                                    <div><%= m.content || '' %></div>
                                                    <% if (m.attachment_url) { %>
                                                        <% if (m.attachment_type === 'image') { %>
                                                            <div class="mt-2">
                                                                <img src="<%= m.attachment_url %>" alt="attachment" style="max-width: 260px; width: 100%; height: auto; border-radius: 12px; display: block;">
                                                            </div>
                                                        <% } else if (m.attachment_type === 'video') { %>
                                                            <div class="mt-2">
                                                                <video src="<%= m.attachment_url %>" controls style="max-width: 320px; width: 100%; border-radius: 12px; display: block;"></video>
                                                            </div>
                                                        <% } else { %>
                                                            <div class="mt-2">
                                                                <a href="<%= m.attachment_url %>" target="_blank" rel="noopener noreferrer" style="color: inherit; text-decoration: underline;">Download file</a>
                                                            </div>
                                                        <% } %>
                                                    <% } %>
                                                    <div class="meta"><span class="js-local-dt" data-kind="time" data-utc="<%= m && m.created_at ? m.created_at : '' %>"></span></div>
                                                </div>

                                                <% if (!isMe) { %>
                                                    <button class="reply-btn ms-2 btn-reply-action"
                                                        data-id="<%= m.id %>"
                                                        data-sender="<%= frName %>"
                                                        data-content="<%= (m.content || '').replace(/"/g, '&quot;') %>"
                                                        data-type="<%= m.attachment_type %>">
                                                        <i class="bi bi-reply-fill"></i>
                                                    </button>
                                                <% } %>

                                                <% if (isMe) { %>
                                                    <img src="<%= avatar %>" class="msg-avatar" alt="Me">
                                                <% } %>
                                            </div>
                                        <% }) %>
                                    </div>
                                </div>

                                <div class="composer-area">
                                    <div id="reply-preview-area" class="reply-preview-area d-none mb-2 rounded border bg-light p-2 align-items-center justify-content-between">
                                        <div class="d-flex flex-column small overflow-hidden" style="max-width: 90%;">
                                            <strong class="text-primary mb-1">Replying to <span id="reply-to-name">...</span></strong>
                                            <span id="reply-to-content" class="text-truncate text-muted">...</span>
                                        </div>
                                        <button type="button" class="btn-close btn-sm" aria-label="Close" id="btn-cancel-reply"></button>
                                    </div>

                                    <div id="upload-progress-container" class="d-none mb-2">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <span class="small text-muted" id="upload-status-text">Uploading...</span>
                                            <span class="small fw-bold text-success d-none" id="upload-complete-text">Completed</span>
                                        </div>
                                        <div class="progress" style="height: 6px;">
                                            <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 0%" id="upload-progress-bar"></div>
                                        </div>
                                    </div>

                                    <form method="post" action="/employer/messages/send?_csrf=<%= encodeURIComponent((typeof csrfToken !== 'undefined' && csrfToken) ? csrfToken : '') %>" enctype="multipart/form-data" id="msgForm">
                                        <input type="hidden" name="_csrf" value="<%= (typeof csrfToken !== 'undefined' && csrfToken) ? csrfToken : '' %>">
                                        <input type="hidden" name="replyTo" id="replyToInput">
                                        <input type="hidden" name="to" value="<%= (typeof toId !== 'undefined' && toId) ? toId : (fr && fr.id ? fr.id : '') %>">
                                        <input type="hidden" name="job" value="<%= (typeof jobId !== 'undefined' && jobId) ? jobId : (j && j.id ? j.id : '') %>">
                                        <input type="hidden" name="attachmentUrl" id="attachmentUrl">
                                        <input type="hidden" name="attachmentType" id="attachmentType">
                                        <input type="file" class="d-none" id="chatAttachmentEmployer">
                                        <div class="input-wrapper mb-2">
                                            <textarea class="composer-input" name="content" rows="1" placeholder="<%= (typeof t === 'function') ? t('freelancer.messages.type_here', 'Type a message...') : 'Type a message...' %>"></textarea>
                                            <button class="send-btn" type="submit" id="btnSend"><i class="bi bi-send-fill"></i></button>
                                        </div>
                                        <div class="composer-tools">
                                            <button class="tool-btn" type="button" title="Image" data-pick="image"><i class="bi bi-image"></i></button>
                                            <button class="tool-btn" type="button" title="Video" data-pick="video"><i class="bi bi-camera-video"></i></button>
                                            <button class="tool-btn" type="button" title="File" data-pick="file"><i class="bi bi-paperclip"></i></button>
                                            <div class="emoji-wrap" data-emoji-wrap>
                                                <button class="tool-btn" type="button" title="Emoji" data-emoji-toggle><i class="bi bi-emoji-smile"></i></button>
                                                <div class="emoji-panel" data-emoji-panel hidden></div>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </section>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </main>

    <%- include('../../public/footer') %>

    <div class="modal fade" id="disputeModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Report / Dispute</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info small">
                        Please describe the issue clearly and attach images as evidence. Your report will be reviewed by admin.
                    </div>

                    <form id="disputeForm" enctype="multipart/form-data">
                        <input type="hidden" name="_csrf" value="<%= (typeof csrfToken !== 'undefined' && csrfToken) ? csrfToken : '' %>">
                        <input type="hidden" name="job_id" value="<%= (j && j.id) ? j.id : '' %>">
                        <input type="hidden" name="reported_user_id" value="<%= (fr && fr.id) ? fr.id : '' %>">
                        <input type="hidden" name="proposal_id" value="<%= (typeof proposalId !== 'undefined' && proposalId) ? proposalId : '' %>">

                        <div class="mb-3">
                            <label class="form-label">Category</label>
                            <select class="form-select" name="category" required>
                                <option value="scam">Scam / Fraud</option>
                                <option value="non_payment">Non-payment</option>
                                <option value="non_delivery">Non-delivery</option>
                                <option value="harassment">Harassment</option>
                                <option value="other">Other</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Details</label>
                            <textarea class="form-control" name="message" rows="4" maxlength="2000" required></textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Evidence images (jpg/png/webp)</label>
                            <input class="form-control" type="file" name="evidence" id="disputeEvidence" accept="image/jpeg,image/png,image/webp" multiple>
                            <div class="form-text">Up to 5 images.</div>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary" id="btnSubmitDispute">Submit</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script src="/js/emojis.js"></script>
    <script>
        const threadElInit = document.getElementById('chatThreadEmployer');
        const isDeposited = threadElInit && threadElInit.dataset && threadElInit.dataset.isDeposited !== undefined
            ? (Number(threadElInit.dataset.isDeposited) || 0)
            : 0;
        const jobType = threadElInit && threadElInit.dataset && threadElInit.dataset.jobType !== undefined
            ? String(threadElInit.dataset.jobType)
            : '';

        // Initialize Emoji Button
        document.addEventListener('DOMContentLoaded', () => {
            const csrf = document.querySelector('input[name="_csrf"]');
            
            const btnDeposit = document.getElementById('btnDeposit');
            if (btnDeposit) {
                btnDeposit.addEventListener('click', async () => {
                    // Check Job Type via dataset or label
                    const btnLabel = btnDeposit.textContent.trim().toLowerCase();
                    const isHourly = btnLabel.includes('activate');
                    
                    const confirmMsg = isHourly 
                        ? 'Activate contract? This will unlock messaging and timer features. Payments will be deducted as work progresses.'
                        : 'Deposit funds for this project? Amount will be deducted from your balance.';
                    
                    if (!confirm(confirmMsg)) return;
                    
                    try {
                        const jobId = btnDeposit.getAttribute('data-job-id');
                        const toId = btnDeposit.getAttribute('data-to-id');
                        
                        const res = await fetch('/employer/messages/make-deposit', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'CSRF-Token': csrf ? csrf.value : '',
                                'X-CSRF-Token': csrf ? csrf.value : ''
                            },
                            body: JSON.stringify({ job: jobId, to: toId })
                        });
                        
                        const data = await res.json();
                        if (data.ok) {
                            alert(isHourly ? 'Contract activated!' : 'Deposit successful! Funds are held in escrow.');
                            location.reload();
                        } else {
                            alert('Action failed: ' + (data.error || 'Unknown error'));
