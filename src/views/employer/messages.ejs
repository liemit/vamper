                    } catch (e) {
                        console.error(e);
                        alert('Action failed: Network error');
                    }
                });
            }

            const btnRelease = document.getElementById('btnRelease');
            if (btnRelease) {
                btnRelease.addEventListener('click', async () => {
                    if (!confirm('Release payment to freelancer? This action cannot be undone.')) return;

                    try {
                        const jobId = btnRelease.getAttribute('data-job-id');
                        const toId = btnRelease.getAttribute('data-to-id');

                        const res = await fetch('/employer/messages/release-payment', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'CSRF-Token': csrf ? csrf.value : '',
                                'X-CSRF-Token': csrf ? csrf.value : ''
                            },
                            body: JSON.stringify({ job: jobId, to: toId })
                        });

                        const data = await res.json();
                        if (data.ok) {
                            alert('Payment released successfully!');
                            location.reload();
                        } else {
                            alert('Release failed: ' + (data.error || 'Unknown error'));
                        }
                    } catch (e) {
                        console.error(e);
                        alert('Release failed: Network error');
                    }
                });
            }

            const btnRefund = document.getElementById('btnRefund');
            if (btnRefund) {
                btnRefund.addEventListener('click', async () => {
                    const threadEl = document.getElementById('chatThreadEmployer');
                    const jt = threadEl && threadEl.getAttribute ? String(threadEl.getAttribute('data-job-type') || '').toLowerCase() : '';
                    const isHourly = jt === 'hourly';
                    const promptMsg = isHourly
                        ? 'End contract? This will reset the hourly contract back to the initial state.'
                        : 'Request a refund? This will be submitted to admin for approval.';
                    if (!confirm(promptMsg)) return;

                    try {
                        const jobId = btnRefund.getAttribute('data-job-id');
                        const toId = btnRefund.getAttribute('data-to-id');

                        const endpoint = isHourly ? '/employer/messages/end-contract' : '/employer/messages/refund-deposit';
                        const res = await fetch(endpoint, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'CSRF-Token': csrf ? csrf.value : '',
                                'X-CSRF-Token': csrf ? csrf.value : ''
                            },
                            body: JSON.stringify({ job: jobId, to: toId })
                        });

                        const data = await res.json();
                        if (data.ok) {
                            alert(isHourly ? 'Contract ended.' : (data.message || 'Refund request submitted to admin.'));
                            location.reload();
                        } else {
                            alert('Action failed: ' + (data.error || 'Unknown error'));
                        }
                    } catch (e) {
                        console.error(e);
                        alert('Action failed: Network error');
                    }
                });
            }

            // Disable upload buttons if not deposited
            if (!Number.isFinite(isDeposited) || isDeposited <= 0) {
                const tools = document.querySelectorAll('.tool-btn[data-pick]');
                tools.forEach(btn => {
                    btn.disabled = true;
                    btn.title = 'Deposit required to unlock';
                    btn.style.opacity = '0.5';
                    btn.style.cursor = 'not-allowed';
                });
            }

            const initEmoji = () => {
                if (typeof EmojiButton !== 'undefined') {
                    try {
                        const picker = new EmojiButton({
                            position: 'auto',
                            style: 'native',
                            zIndex: 9999,
                            theme: 'auto',
                            autoHide: false
                        });
                        const trigger = document.getElementById('btn-emoji');
                        
                        if (trigger) {
                            picker.on('emoji', selection => {
                                const textarea = document.querySelector('.composer-input');
                                if (textarea) {
                                    const start = textarea.selectionStart;
                                    const end = textarea.selectionEnd;
                                    const text = textarea.value;
                                    const before = text.substring(0, start);
                                    const after  = text.substring(end, text.length);
                                    textarea.value = (before + selection.emoji + after);
                                    textarea.selectionStart = textarea.selectionEnd = start + selection.emoji.length;
                                    textarea.focus();
                                    // Trigger input event to resize
                                    const event = new Event('input', { bubbles: true });
                                    textarea.dispatchEvent(event);
                                }
                            });
                            trigger.addEventListener('click', (e) => {
                                e.preventDefault();
                                console.log('Emoji button clicked');
                                picker.togglePicker(trigger);
                            });
                            console.log('Emoji picker initialized');
                        }
                    } catch (e) {
                        console.error('EmojiButton initialization failed:', e);
