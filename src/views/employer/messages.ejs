            };
            
            initEmoji();
        });

        const tx = document.querySelector('.composer-input');
        if(tx) {
            tx.setAttribute('style', 'height:' + (tx.scrollHeight) + 'px;overflow-y:hidden;');
            tx.addEventListener("input", OnInput, false);
        }

        function OnInput() {
            this.style.height = 'auto';
            this.style.height = (this.scrollHeight) + 'px';
        }

        const fileInput = document.getElementById('chatAttachmentEmployer');
        const progressContainer = document.getElementById('upload-progress-container');
        const progressBar = document.getElementById('upload-progress-bar');
        const statusText = document.getElementById('upload-status-text');
        const completeText = document.getElementById('upload-complete-text');
        const btnSend = document.getElementById('btnSend');
        const attachmentUrlInput = document.getElementById('attachmentUrl');
        const attachmentTypeInput = document.getElementById('attachmentType');

        if (fileInput) {
            fileInput.addEventListener('change', function() {
                if (this.files && this.files.length > 0) {
                    const file = this.files[0];
                    uploadFile(file);
                }
            });
        }

        function uploadFile(file) {
            const isImage = file && file.type && file.type.startsWith('image/');
            const isVideo = file && file.type && file.type.startsWith('video/');
            const maxImageMB = 10;
            const maxVideoMB = 200;
            const maxFileMB = 200;
            let limitMB = maxFileMB;
            if (isImage) limitMB = maxImageMB;
            else if (isVideo) limitMB = maxVideoMB;
            const limitBytes = limitMB * 1024 * 1024;
            if (file && file.size && file.size > limitBytes) {
                openPlanModal(isImage ? 'image' : (isVideo ? 'video' : 'file'));
                resetUpload();
                return;
            }
            // Show progress
            if (progressContainer) progressContainer.classList.remove('d-none');
            if (progressBar) {
                progressBar.style.width = '0%';
                progressBar.classList.remove('bg-success');
                progressBar.classList.add('progress-bar-animated');
            }
            if (statusText) statusText.classList.remove('d-none');
            if (completeText) completeText.classList.add('d-none');
            
            // Disable send button
            if (btnSend) btnSend.disabled = true;

            const formData = new FormData();
            formData.append('attachment', file);
            // Get CSRF token from the hidden input in the form
            const csrfInput = document.querySelector('input[name="_csrf"]');
            if (csrfInput) {
                formData.append('_csrf', csrfInput.value);
            }

            const xhr = new XMLHttpRequest();
            xhr.open('POST', (window.__UPLOAD_BASE__ || '') + '/employer/messages/upload', true);

            // Set CSRF token in header to bypass multipart/form-data body parsing issues
            if (csrfInput) {
                xhr.setRequestHeader('CSRF-Token', csrfInput.value);
                xhr.setRequestHeader('X-CSRF-Token', csrfInput.value);
            }

            xhr.upload.onprogress = function(e) {
                if (e.lengthComputable) {
                    const percentComplete = (e.loaded / e.total) * 100;
                    if (progressBar) progressBar.style.width = percentComplete + '%';
                }
            };

            xhr.onload = function() {
                if (xhr.status === 200) {
                    try {
                        const res = JSON.parse(xhr.responseText);
                        if (res.ok) {
                            // Success
                            if (progressBar) {
                                progressBar.style.width = '100%';
                                progressBar.classList.remove('progress-bar-animated');
                                progressBar.classList.add('bg-success');
                            }
                            if (statusText) statusText.classList.add('d-none');
                            if (completeText) completeText.classList.remove('d-none');
                            
                            if (attachmentUrlInput) attachmentUrlInput.value = res.url;
                            if (attachmentTypeInput) attachmentTypeInput.value = res.type;
                            
                            // Enable send button
                            if (btnSend) btnSend.disabled = false;
                        } else {
                            const err = (res && res.error) ? String(res.error) : '';
                            if (err && (err.includes('limit') || err.includes('quota'))) {
                                openPlanModal(isImage ? 'image' : (isVideo ? 'video' : 'file'));
                            } else {
                                alert('Upload failed: ' + (res.error || 'Unknown error'));
                            }
                            resetUpload();
                        }
                    } catch (e) {
                        console.error('Error parsing response', e);
                        alert('Upload failed: Server returned invalid response');
                        resetUpload();
                    }
                } else {
                    alert('Upload failed with status ' + xhr.status);
                    resetUpload();
                }
            };

            xhr.onerror = function() {
                alert('Upload failed: Network error');
                resetUpload();
            };

            xhr.send(formData);
        }

        function resetUpload() {
            if (progressContainer) progressContainer.classList.add('d-none');
            if (fileInput) fileInput.value = '';
            if (attachmentUrlInput) attachmentUrlInput.value = '';
            if (attachmentTypeInput) attachmentTypeInput.value = '';
            if (btnSend) btnSend.disabled = false;
        }

        function ensurePlanModal() {
            let el = document.getElementById('planModal');
            if (el) return el;
            el = document.createElement('div');
            el.id = 'planModal';
            el.className = 'modal fade';
            el.tabIndex = -1;
            el.setAttribute('aria-hidden', 'true');
            el.innerHTML = '<div class="modal-dialog modal-dialog-centered"><div class="modal-content"><div class="modal-header"><h5 class="modal-title">Upgrade Plan</h5><button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button></div><div class="modal-body"><div id="planList" class="vstack gap-3"></div></div></div></div>';
            document.body.appendChild(el);
            return el;
        }

        async function openPlanModal(kind) {
            try {
                const modalEl = ensurePlanModal();
                const res = await fetch('/employer/plans', { credentials: 'same-origin' });
                if (!res.ok) return;
                const data = await res.json();
                const list = Array.isArray(data.items) ? data.items : [];
                const activeCode = data.active_plan_code || null;
                const byPlan = {};
                list.forEach(it => {
                    const pid = it.code || it.id;
                    if (!byPlan[pid]) byPlan[pid] = { code: it.code, name: it.name, price: it.price_monthly, currency: it.currency, limits: {} };
                    if (it.kind) byPlan[pid].limits[it.kind] = { max_file_mb: it.max_file_mb, monthly_quota_mb: it.monthly_quota_mb };
                });
                const wrap = modalEl.querySelector('#planList');
                if (!wrap) return;
                wrap.innerHTML = '';
                Object.values(byPlan).forEach(p => {
                    const div = document.createElement('div');
                    div.className = 'border rounded-3 p-3';
                    const title = document.createElement('div');
                    title.className = 'fw-bold mb-1';
                    title.textContent = p.name;
                    const price = document.createElement('div');
                    price.className = 'mb-1';
                    if (p.price !== undefined && p.price !== null) {
                        price.innerHTML = 'Price: <i class="bi bi-gem text-primary"></i> ' + (p.price) + '/' + 'month';
                    }
                    const detail = document.createElement('div');
                    detail.className = 'text-muted small mb-2';
                    const kinds = [
                        { key: 'image', label: 'Image' },
                        { key: 'video', label: 'Video' },
                        { key: 'file', label: 'File' }
                    ];
                    kinds.forEach(k => {
                        const lim = p.limits[k.key] || {};
                        const line = document.createElement('div');
                        line.textContent = k.label + ': Per-file ' + (lim.max_file_mb || '—') + 'MB · Monthly ' + (lim.monthly_quota_mb || '—') + 'MB';
                        if (k.key === kind) line.style.fontWeight = '600';
                        detail.appendChild(line);
                    });
                    const btn = document.createElement('button');
                    const isActivePlan = (p.code && p.code === activeCode);
                    if (isActivePlan) {
                        btn.className = 'btn btn-outline-secondary btn-sm';
                        btn.textContent = 'Free';
                        btn.onclick = () => {
                            const m = bootstrap.Modal.getOrCreateInstance(modalEl);
                            m.hide();
                        };
                    } else {
                        btn.className = 'btn btn-primary btn-sm';
                        btn.textContent = 'Activate';
                        btn.onclick = async () => {
                            const csrf = document.querySelector('input[name=\"_csrf\"]');
                            const params = new URLSearchParams();
                            params.set('plan_code', p.code);
                            if (csrf) params.set('_csrf', csrf.value);
                            const r = await fetch('/employer/plans/activate', {
                                method: 'POST',
                                headers: Object.assign(
                                    { 'Content-Type': 'application/x-www-form-urlencoded' },
                                    csrf ? { 'CSRF-Token': csrf.value, 'X-CSRF-Token': csrf.value } : {}
                                ),
                                body: params.toString(),
                                credentials: 'same-origin'
                            });
                            let ok = r.ok, msg = '';
                            try { const j = await r.json(); ok = j && j.ok; msg = j && j.error ? j.error : ''; } catch(_) {}
                            if (ok) {
                                const m = bootstrap.Modal.getOrCreateInstance(modalEl);
                                m.hide();
                                try {
                                    const j = await r.clone().json();
                                    if (j && j.new_balance !== undefined && j.new_balance !== null) {
                                        const valEl = document.getElementById('headerBalanceValue');
                                        if (valEl) {
                                            const num = Number(j.new_balance);
                                            valEl.textContent = Number.isFinite(num) ? num.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) : String(j.new_balance);
                                        }
                                    }
                                } catch(_) {}
                                alert('Plan activated');
                            } else {
                                alert(msg || 'Activation failed');
                            }
                        };
                    }
                    div.appendChild(title);
                    div.appendChild(price);
                    div.appendChild(detail);
                    div.appendChild(btn);
                    wrap.appendChild(div);
                });
                const m = bootstrap.Modal.getOrCreateInstance(modalEl);
                m.show();
            } catch (_) {}
        }

        document.querySelectorAll('[data-pick]').forEach((btn) => {
            btn.addEventListener('click', () => {
                if (!fileInput) return;
                const mode = btn.getAttribute('data-pick');
                if (mode === 'image') fileInput.setAttribute('accept', 'image/*');
                else if (mode === 'video') fileInput.setAttribute('accept', 'video/*');
                else fileInput.removeAttribute('accept');
                fileInput.click();
            });
        });

        // Event delegation for reply buttons
        document.addEventListener('click', function(e) {
            // Reply
            const btn = e.target.closest('.btn-reply-action');
            if (btn) {
                const id = btn.getAttribute('data-id');
                const sender = btn.getAttribute('data-sender');
                const content = btn.getAttribute('data-content');
                const type = btn.getAttribute('data-type');
                initReply(id, sender, content, type);
                return;
            }

            // Delete
            const delBtn = e.target.closest('.btn-delete-action');
            if (delBtn) {
                const id = delBtn.getAttribute('data-id');
                if (!id) {
                    console.error('Missing message ID for deletion');
                    return;
                }
                if (confirm('Are you sure you want to delete this message?')) {
                    deleteMessage(id, delBtn);
                }
            }
        });

        function deleteMessage(id, btnElement) {
            if (!id) return;
            const xhr = new XMLHttpRequest();
            xhr.open('POST', '/employer/messages/delete-msg/' + id, true);
            
            // CSRF
            const csrfInput = document.querySelector('input[name="_csrf"]');
            if (csrfInput) {
                xhr.setRequestHeader('CSRF-Token', csrfInput.value);
                xhr.setRequestHeader('X-CSRF-Token', csrfInput.value);
            }

            xhr.onload = function() {
                if (xhr.status === 200) {
                    try {
                        const res = JSON.parse(xhr.responseText);
                        if (res.ok) {
                            // Remove from DOM
                            const row = btnElement.closest('.chat-msg');
                            if (row) row.remove();
                        } else {
                            alert('Delete failed: ' + (res.error || 'Unknown error'));
                        }
                    } catch (e) {
                        console.error(e);
                        alert('Delete failed');
                    }
                } else {
                    alert('Delete failed with status ' + xhr.status);
                }
            };
            xhr.send();
        }

        // Cancel Reply Button
        const btnCancel = document.getElementById('btn-cancel-reply');
        if (btnCancel) {
            btnCancel.addEventListener('click', function(e) {
                e.preventDefault();
                cancelReply();
            });
        }

        const threadEl = document.getElementById('chatThreadEmployer');
        const paneEl = document.querySelector('.chat-pane-body');
        const initialToId = (threadEl && threadEl.dataset && threadEl.dataset.toId)
            ? (Number(threadEl.dataset.toId) || null)
            : null;
        const initialJobId = (threadEl && threadEl.dataset && threadEl.dataset.jobId)
            ? (Number(threadEl.dataset.jobId) || null)
            : null;
        const ME_AVATAR = (threadEl && threadEl.dataset && threadEl.dataset.meAvatar) ? threadEl.dataset.meAvatar : '';
        const OTHER_AVATAR = (threadEl && threadEl.dataset && threadEl.dataset.otherAvatar) ? threadEl.dataset.otherAvatar : '';
        const meId = Number((threadEl && threadEl.dataset && threadEl.dataset.meId) ? threadEl.dataset.meId : 0);
        let lastId = 0;

        if (threadEl) {
            const msgEls = threadEl.querySelectorAll('[data-msg-id]');
            const lastMsg = msgEls && msgEls.length ? msgEls[msgEls.length - 1] : null;
            if (lastMsg) lastId = Number(lastMsg.getAttribute('data-msg-id')) || 0;
        }

        function scrollToBottom() {
            if (!paneEl) return;
            paneEl.scrollTop = paneEl.scrollHeight;
        }

        const emojiWrap = document.querySelector('[data-emoji-wrap]');
        const emojiToggle = document.querySelector('[data-emoji-toggle]');
        const emojiPanel = document.querySelector('[data-emoji-panel]');
        // EMOJIS array is loaded from /js/emojis.js
        function closeEmoji() {
            if (!emojiPanel) return;
            emojiPanel.hidden = true;
        }
        if (emojiPanel && !emojiPanel.dataset.built) {
            emojiPanel.dataset.built = '1';
            const frag = document.createDocumentFragment();
            EMOJIS.forEach((ch) => {
                const b = document.createElement('button');
                b.type = 'button';
                b.className = 'emoji-item';
                b.textContent = ch;
                frag.appendChild(b);
            });
            emojiPanel.appendChild(frag);
        }
        if (emojiToggle && emojiPanel && tx) {
            emojiToggle.addEventListener('click', (e) => {
                e.preventDefault();
                emojiPanel.hidden = !emojiPanel.hidden;
                if (!emojiPanel.hidden) tx.focus();
            });
            emojiPanel.addEventListener('click', (e) => {
                const target = e.target;
                if (!target || !target.classList || !target.classList.contains('emoji-item')) return;
                e.preventDefault();
                const emoji = target.textContent || '';
                if (tx) {
                    const start = tx.selectionStart;
                    const end = tx.selectionEnd;
                    const text = tx.value;
                    const before = text.substring(0, start);
                    const after = text.substring(end, text.length);
                    tx.value = (before + emoji + after);
                    tx.selectionStart = tx.selectionEnd = start + emoji.length;
                    tx.focus();
                    const event = new Event('input', { bubbles: true });
                    tx.dispatchEvent(event);
                }
            });
            document.addEventListener('click', (e) => {
                if (!emojiWrap.contains(e.target)) closeEmoji();
            });
        }
    </script>

    <!-- NEW TIMER SCRIPT -->
    <script>
    // Timer Logic & Polling
    (function() {
        const timerDisplay = document.getElementById('timerDisplay');
        const timerCost = document.getElementById('timerCost');
        const timerPending = document.getElementById('timerPending');
        const btnReleasePending = document.getElementById('btnReleasePending');
        const btnRefundPending = document.getElementById('btnRefundPending');
        const btnStartTimer = document.getElementById('btnStartTimer');
        const btnStopTimer = document.getElementById('btnStopTimer');
        
        // Initial State
        let timerState = {
            status: 'stopped',
            start_time: null,
            total_seconds: 0,
            paid_seconds: 0,
            pending_balance: 0,
            hourly_rate: <%- JSON.stringify((typeof proposalRate !== 'undefined' && proposalRate !== null) ? Number(proposalRate) : 0) %>,
        };

        let lastTimerSync = 0;
        const POLL_INTERVAL = 3000;
        const SYNC_INTERVAL = 30000; // 30s
        
        // Helper: Format Seconds to HH:MM:SS
        function formatTime(seconds) {
            const h = Math.floor(seconds / 3600);
            const m = Math.floor((seconds % 3600) / 60);
            const s = seconds % 60;
            return `${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
        }

        // Update UI
        function updateTimerUI() {
            if (!timerDisplay) return;

            let currentTotal = timerState.total_seconds;
            if (timerState.status === 'running' && timerState.start_time) {
                const start = new Date(timerState.start_time).getTime();
                const now = Date.now();
                const elapsed = Math.floor((now - start) / 1000);
                if (elapsed > 0) currentTotal += elapsed;
            }

            timerDisplay.textContent = formatTime(currentTotal);
            
            // Pending Amount (Include current running cost in Pending display for better UX)
            // Tính số giây chưa thanh toán (unpaid_seconds)
            const unpaidSeconds = Math.max(0, currentTotal - timerState.paid_seconds);
            const currentSessionCost = (unpaidSeconds / 3600) * timerState.hourly_rate;
            
            // Tiền Pending = Số tiền đã Pending trong DB + Số tiền của phiên đang chạy (chưa lưu)
            const dbPending = Number(timerState.pending_balance || 0);
            
            // Nếu timer đang chạy, hoặc có giây lẻ chưa trả, ta gộp nó vào hiển thị Pending
            // Lưu ý: dbPending đã bao gồm tiền của các phiên trước đó (nếu có)
            // Vì timerState.paid_seconds là tổng số giây ĐÃ ĐƯỢC TRẢ TIỀN, nên unpaidSeconds chính là số giây sinh ra currentSessionCost
            // Nhưng khi Stop, hệ thống đã cộng currentSessionCost vào dbPending và cập nhật paid_seconds = currentTotal.
            // Do đó, cách tính này an toàn cả khi chạy và khi dừng.
            const totalPendingDisplay = (timerState.status === 'running') 
                                        ? currentSessionCost // Khi chạy, hiển thị toàn bộ tiền của các giây chưa trả
                                        : dbPending;         // Khi dừng, hiển thị đúng dbPending (vì DB đã gom hết vào đây)
            
            if (timerPending) {
                timerPending.innerHTML = '<i class="bi bi-gem"></i> ' + totalPendingDisplay.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            }
            if (btnReleasePending) {
                btnReleasePending.hidden = (totalPendingDisplay <= 0);
            }
            if (btnRefundPending) {
                btnRefundPending.hidden = (totalPendingDisplay <= 0);
            }

            // Button States
            if (btnStartTimer && btnStopTimer) {
                if (timerState.status === 'running') {
                    btnStartTimer.disabled = true;
                    btnStopTimer.disabled = false;
                } else {
                    btnStartTimer.disabled = false;
                    btnStopTimer.disabled = true;
                }
            }
        }

        // Tick every second
        setInterval(updateTimerUI, 1000);

        // Polling Function
        async function pollData() {
            // Get current IDs from DOM
            const threadEl = document.getElementById('chatThreadEmployer');
            if (!threadEl) return;
            
            const toId = threadEl.dataset.toId;
            const jobId = threadEl.dataset.jobId;
            if (!toId || !jobId) return;

            // Get last message ID
            const msgEls = document.querySelectorAll('.chat-msg');
            const lastMsgId = (msgEls.length > 0) ? msgEls[msgEls.length - 1].dataset.msgId : 0;

            try {
                const res = await fetch(`/employer/messages/poll?to=${toId}&job=${jobId}&afterId=${lastMsgId}`);
                const data = await res.json();

                if (data.ok) {
                    // 1. Append New Messages
                    if (data.messages && data.messages.length > 0) {
                        appendMessages(data.messages, threadEl);
                    }

                    // 2. Update Timer State
                    if (data.timer) {
                        timerState.status = data.timer.status;
                        timerState.start_time = data.timer.start_time;
                        timerState.total_seconds = Number(data.timer.total_seconds);
                        timerState.paid_seconds = Number(data.timer.paid_seconds);
                        timerState.pending_balance = Number(data.timer.pending_balance || 0);
                        updateTimerUI();
                        
                        // Sync Payment Trigger if running
                        if (timerState.status === 'running') {
                            const now = Date.now();
                            if (now - lastTimerSync > SYNC_INTERVAL) {
                                syncTimerPayment(jobId, toId);
                                lastTimerSync = now;
                            }
                        }
                    }

                    // 3. Update Balance Header
                    if (data.balance !== undefined && data.balance !== null) {
                        const balEl = document.getElementById('headerBalanceValue');
                        if (balEl) {
                            balEl.textContent = Number(data.balance).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                        }
                    }
                }
            } catch (e) {
                console.error('Poll error', e);
            }
        }

        // Release Pending Payment
        if (btnReleasePending) {
            btnReleasePending.addEventListener('click', async () => {
                if (!confirm('Approve and release pending payment to freelancer?')) return;
                
                const threadEl = document.getElementById('chatThreadEmployer');
                const toId = threadEl.dataset.toId;
                const jobId = threadEl.dataset.jobId;
                const csrf = document.querySelector('input[name="_csrf"]');

                try {
                    const res = await fetch('/employer/messages/timer/release-pending', {
                        method: 'POST',
                        headers: { 
                            'Content-Type': 'application/json', 
                            'CSRF-Token': csrf ? csrf.value : '' 
                        },
                        body: JSON.stringify({ job_id: jobId, to_id: toId })
                    });
                    const data = await res.json();
                    if (data.ok) {
                        alert(`Released ${data.released} Diamonds successfully!`);
                        // Force update
                        timerState.pending_balance = 0;
                        updateTimerUI();
                    } else {
                        alert(data.error || 'Release failed');
                    }
                } catch(e) { alert('Network error'); }
            });
        }

        // Refund Pending Payment
        if (btnRefundPending) {
            btnRefundPending.addEventListener('click', async () => {
                if (!confirm('Refund pending payment back to your balance? This will cancel the pending transaction.')) return;
                
                const threadEl = document.getElementById('chatThreadEmployer');
                const toId = threadEl.dataset.toId;
                const jobId = threadEl.dataset.jobId;
                const csrf = document.querySelector('input[name="_csrf"]');

                try {
                    const res = await fetch('/employer/messages/timer/refund-pending', {
                        method: 'POST',
                        headers: { 
                            'Content-Type': 'application/json', 
                            'CSRF-Token': csrf ? csrf.value : '' 
                        },
                        body: JSON.stringify({ job_id: jobId, to_id: toId })
                    });
                    const data = await res.json();
                    if (data.ok) {
                        alert(`Refunded ${data.refunded} Diamonds successfully!`);
                        // Force update
                        timerState.pending_balance = 0;
                        updateTimerUI();
                    } else {
                        alert(data.error || 'Refund failed');
                    }
                } catch(e) { alert('Network error'); }
            });
        }

        // Sync Payment Call
        async function syncTimerPayment(jobId, toId) {
            try {
                const csrf = document.querySelector('input[name="_csrf"]');
                await fetch('/employer/messages/timer/sync', {
                     method: 'POST',
                     headers: { 
                        'Content-Type': 'application/json',
                        'CSRF-Token': csrf ? csrf.value : ''
                     },
                     body: JSON.stringify({ job_id: jobId, to_id: toId })
                });
            } catch(e) {}
        }

        // Start Polling
        setInterval(pollData, POLL_INTERVAL);
        pollData(); // Initial call

        // Event Listeners
        if (btnStartTimer) {
            btnStartTimer.addEventListener('click', async () => {
                const threadEl = document.getElementById('chatThreadEmployer');
                const toId = threadEl.dataset.toId;
                const jobId = threadEl.dataset.jobId;
                const csrf = document.querySelector('input[name="_csrf"]');

                try {
                    const res = await fetch('/employer/messages/timer/start', {
                        method: 'POST',
                        headers: { 
                            'Content-Type': 'application/json', 
                            'CSRF-Token': csrf ? csrf.value : '' 
                        },
                        body: JSON.stringify({ job_id: jobId, to_id: toId })
                    });
                    const data = await res.json();
                    if (data.ok) {
                        if (btnStartTimer) btnStartTimer.disabled = true;
                        if (btnStopTimer) btnStopTimer.disabled = false;
                        timerState.status = 'running';
                        timerState.start_time = new Date().toISOString();
                        updateTimerUI();
                        try { await pollData(); } catch (_) {}
                    } else {
                        alert(data.error || 'Error starting timer');
                    }
                } catch (e) { alert('Network error'); }
            });
        }

        if (btnStopTimer) {
            btnStopTimer.addEventListener('click', async () => {
                if(!confirm('Stop timer? This will calculate final time.')) return;
                
                const threadEl = document.getElementById('chatThreadEmployer');
                const toId = threadEl.dataset.toId;
                const jobId = threadEl.dataset.jobId;
                const csrf = document.querySelector('input[name="_csrf"]');

                try {
                    const res = await fetch('/employer/messages/timer/stop', {
                        method: 'POST',
                        headers: { 
                            'Content-Type': 'application/json', 
                            'CSRF-Token': csrf ? csrf.value : '' 
                        },
                        body: JSON.stringify({ job_id: jobId, to_id: toId })
                    });
                    const data = await res.json();
                    if (data.ok) {
                        timerState.status = 'stopped';
                        updateTimerUI();
                    } else {
                        alert(data.error || 'Error stopping timer');
                    }
                } catch (e) { alert('Network error'); }
            });
        }

        // Message Appender
        function appendMessages(msgs, container) {
            const meId = Number(container.dataset.meId || 0);
            const meAvatar = container.dataset.meAvatar || 'https://via.placeholder.com/28';
            const otherAvatar = container.dataset.otherAvatar || 'https://via.placeholder.com/28';
            
            msgs.forEach(m => {
                if (container.querySelector(`[data-msg-id="${m.id}"]`)) return;

                const isMe = (Number(m.sender_id) === meId);
                const rowClass = isMe ? 'from-me' : 'from-other';
                const avatar = isMe ? meAvatar : (m.sender_avatar || otherAvatar);
                
                const div = document.createElement('div');
                div.className = `chat-msg ${rowClass}`;
                div.dataset.msgId = m.id;
                
                let html = '';
                if (!isMe) html += `<img src="${avatar}" class="msg-avatar" alt="User">`;
                
                html += `<div class="bubble">`;
                html += `<div>${m.content || ''}</div>`;
                if (m.attachment_url) {
                    if (m.attachment_type === 'image') {
                        html += `<div class="mt-2"><img src="${m.attachment_url}" style="max-width:200px;border-radius:8px;"></div>`;
                    } else {
                        html += `<div class="mt-2"><a href="${m.attachment_url}" target="_blank">View Attachment</a></div>`;
                    }
                }
                let time = '';
                try {
                    if (typeof window.__formatUtcToLocal === 'function') {
                        time = window.__formatUtcToLocal(m.created_at, 'time');
                    } else {
                        const d = (typeof window.__parseUtcDate === 'function') ? window.__parseUtcDate(m.created_at) : new Date(m.created_at);
                        time = Number.isNaN(d.getTime())
                            ? ''
                            : d.toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});
                    }
                } catch (_) { time = ''; }
                html += `<div class="meta">${time}</div>`;
                html += `</div>`;
                
                div.innerHTML = html;
                container.appendChild(div);
                
                const pane = document.querySelector('.chat-pane-body');
                if (pane) pane.scrollTop = pane.scrollHeight;
            });
        }

        (function() {
            const form = document.getElementById('disputeForm');
            const evidenceInput = document.getElementById('disputeEvidence');
            const btnSubmit = document.getElementById('btnSubmitDispute');
            if (!form) return;

            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                if (btnSubmit) btnSubmit.disabled = true;
                try {
                    if (evidenceInput && evidenceInput.files && evidenceInput.files.length > 5) {
                        alert('Please upload up to 5 images.');
                        return;
                    }

                    const fd = new FormData(form);
                    if (evidenceInput && evidenceInput.files && evidenceInput.files.length) {
                        for (const f of evidenceInput.files) {
                            fd.append('evidence', f);
                        }
                    }

                    const csrf = fd.get('_csrf') || '';
                    const res = await fetch('/employer/disputes/create', {
                        method: 'POST',
                        headers: {
                            'CSRF-Token': csrf,
                            'X-CSRF-Token': csrf
                        },
                        body: fd
                    });

                    const data = await res.json().catch(() => null);
                    if (!res.ok || !data || !data.ok) {
                        throw new Error((data && data.error) ? data.error : 'Failed to submit dispute');
                    }

                    alert('Report submitted. Admin will review it shortly.');
                    try {
                        const modalEl = document.getElementById('disputeModal');
                        const modal = modalEl ? bootstrap.Modal.getInstance(modalEl) : null;
                        if (modal) modal.hide();
                    } catch (_) {}
                } catch (err) {
                    console.error(err);
                    alert(err && err.message ? err.message : 'Failed to submit dispute');
                } finally {
                    if (btnSubmit) btnSubmit.disabled = false;
                }
            });
        })();
    })();
    </script>
</body>

</html>
