<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vamper - Post a New Job</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <%- include('../../public/header') %>

        <main class="container-fluid py-3 py-md-4">
            <div class="row">
                <%- include('./layouts/menu') %>

                    <section class="col-md-9 ms-sm-auto col-lg-10 px-2 px-md-4 employer-post-job">
                        <div class="d-flex align-items-center pt-3 pb-2 mb-3 border-bottom">
                            <a href="/employer/jobs" class="btn btn-outline-secondary me-3">
                                <i class="bi bi-arrow-left"></i>
                            </a>
                            <h1 class="h2 mb-0">Post a New Job</h1>
                        </div>

                        <div class="card border-0 shadow-sm rounded-4">
                            <div class="card-body p-4">
                                <form action="/employer/jobs/create?_csrf=<%= csrfToken %>" method="POST"
                                    enctype="multipart/form-data">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">


                                    <div class="mb-3">
                                        <label for="title" class="form-label fw-bold">Job Title</label>
                                        <input type="text" class="form-control" id="title" name="title"
                                            placeholder="e.g. Senior React Developer needed for Fintech project"
                                            required>
                                    </div>

                                    <div class="row g-3 mb-3">
                                        <div class="col-md-6">
                                            <label for="category" class="form-label fw-bold">Category</label>
                                            <select class="form-select" id="category" name="category_id" required>
                                                <option value="" selected disabled>Select a category</option>
                                                <% if (typeof categories !=='undefined' && categories.length> 0) { %>
                                                    <% categories.forEach(function(category) { %>
                                                        <option value="<%= category.id %>">
                                                            <%= category.name %>
                                                        </option>
                                                        <% }); %>
                                                            <% } %>
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label for="job_type" class="form-label fw-bold">Job Type</label>
                                            <select class="form-select" id="job_type" name="job_type" required>
                                                <option value="fixed_price">Fixed Price</option>
                                                <option value="hourly">Hourly Rate</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="description" class="form-label fw-bold form-label-icon text-uppercase small text-muted mb-1">
                                            <i class="bi bi-card-text"></i>
                                            Description
                                        </label>
                                        <textarea class="d-none" id="description" name="description"
                                            placeholder="Describe your project details, requirements, and deliverables..."></textarea>
                                        <div id="description-editor" class="vamper-quill-editor"></div>
                                        <div class="form-text">Tip: mention scope, expected timeline, and what success looks like.</div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="thumbnail" class="form-label fw-bold">Job Thumbnail
                                            (Optional)</label>
                                        <div class="d-flex align-items-center gap-3">
                                            <div style="width: 100px; height: 100px; min-width: 100px; min-height: 100px; border-radius: 8px; background-color: #f8f9fa; border: 1px dashed #dee2e6; display: flex; align-items: center; justify-content: center; overflow: hidden;"
                                                id="thumbnail-preview-container">
                                                <i class="bi bi-image text-muted fs-2"></i>
                                            </div>
                                            <div class="flex-grow-1">
                                                <input class="form-control" type="file" id="thumbnail" name="thumbnail"
                                                    accept="image/*">
                                                <div class="form-text">Recommended size: 800x600px. Max size: 2MB.</div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row g-3 mb-3">
                                        <div class="col-md-6">
                                            <label for="budget" class="form-label fw-bold">Budget / Rate (Credits)</label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="bi bi-gem text-primary"></i></span>
                                                <input type="number" class="form-control" id="budget" name="budget"
                                                    placeholder="0.00" step="0.01" min="0" required>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label for="deadline" class="form-label fw-bold">Deadline (Optional)</label>
                                            <input type="date" class="form-control" id="deadline" name="deadline">
                                        </div>
                                    </div>

                                    <div class="mb-4">
                                        <label for="skills" class="form-label fw-bold">Required Skills (Comma
                                            separated)</label>
                                        <input type="text" class="form-control" id="skills" name="skills"
                                            placeholder="e.g. React, Node.js, MySQL">
                                    </div>

                                    <div class="d-flex justify-content-end gap-2">
                                        <a href="/employer/jobs" class="btn btn-outline-secondary">Cancel</a>
                                        <button type="submit" class="btn btn-primary px-4">Post Job</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </section>
            </div>
        </main>

        <%- include('../../public/footer') %>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>
            <script src="/js/employer-job-editor.js"></script>
</body>

</html>