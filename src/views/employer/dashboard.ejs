<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vamper - Employer Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <%- include('../../public/header') %>

        <main class="container-fluid py-3 py-md-4">
            <div class="row">
                <%- include('./layouts/menu') %>

                    <section class="col-md-9 ms-sm-auto col-lg-10 px-2 px-md-4">
                        <div class="d-md-none pt-2 pb-2 mb-2">
                            <div class="d-flex align-items-center justify-content-between">
                                <div class="fw-semibold">Employer Dashboard</div>
                                <a href="#" class="btn btn-sm btn-primary fw-semibold">
                                    <i class="bi bi-plus-lg me-1"></i>Post
                                </a>
                            </div>
                            <div class="mt-2" style="overflow-x: auto; -webkit-overflow-scrolling: touch;">
                                <div class="nav nav-pills flex-nowrap gap-2" style="white-space: nowrap;">
                                    <a class="nav-link active text-nowrap" href="#">Dashboard</a>
                                    <a class="nav-link text-nowrap" href="#">Post</a>
                                    <a class="nav-link text-nowrap" href="#">Applicants</a>
                                    <a class="nav-link text-nowrap" href="#">Company</a>
                                </div>
                            </div>
                        </div>

                        <div
                            class="d-none d-md-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between gap-3 pt-2 pt-md-3 pb-2 mb-3 border-bottom">
                            <div>
                                <h1 class="h3 fw-bold mb-1">Employer Dashboard</h1>
                                <div class="text-muted">Track your posts, applicants, and hiring progress</div>
                            </div>
                            <div class="d-flex flex-wrap gap-2">
                                <button type="button" class="btn btn-outline-secondary w-100 w-md-auto">
                                    <i class="bi bi-download me-2"></i>Export
                                </button>
                                <button type="button" class="btn btn-primary fw-semibold w-100 w-md-auto">
                                    <i class="bi bi-plus-lg me-2"></i>Post new project
                                </button>
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-12 col-md-6 col-xl-3">
                                <div class="card border-0 shadow-sm rounded-4 h-100">
                                    <div class="card-body">
                                        <div class="d-flex align-items-start justify-content-between">
                                            <div>
                                                <div class="text-muted small">Active posts</div>
                                                <div class="fs-3 fw-bold"><%= typeof stats !== 'undefined' ? stats.activePosts : 0 %></div>
                                                <div class="text-success small"><i class="bi bi-briefcase"></i> Total
                                                </div>
                                            </div>
                                            <div class="bg-primary bg-opacity-10 text-primary rounded-3 d-inline-flex align-items-center justify-content-center"
                                                style="width: 44px; height: 44px;">
                                                <i class="bi bi-briefcase"></i>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-md-6 col-xl-3">
                                <div class="card border-0 shadow-sm rounded-4 h-100">
                                    <div class="card-body">
                                        <div class="d-flex align-items-start justify-content-between">
                                            <div>
                                                <div class="text-muted small">New applicants</div>
                                                <div class="fs-3 fw-bold"><%= typeof stats !== 'undefined' ? stats.newApplicants : 0 %></div>
                                                <div class="text-muted small">Pending review</div>
                                            </div>
                                            <div class="bg-success bg-opacity-10 text-success rounded-3 d-inline-flex align-items-center justify-content-center"
                                                style="width: 44px; height: 44px;">
                                                <i class="bi bi-person-plus"></i>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-md-6 col-xl-3">
                                <div class="card border-0 shadow-sm rounded-4 h-100">
                                    <div class="card-body">
                                        <div class="d-flex align-items-start justify-content-between">
                                            <div>
                                                <div class="text-muted small">Interviews</div>
                                                <div class="fs-3 fw-bold"><%= typeof stats !== 'undefined' ? stats.interviews : 0 %></div>
                                                <div class="text-muted small">In progress</div>
                                            </div>
                                            <div class="bg-info bg-opacity-10 text-info rounded-3 d-inline-flex align-items-center justify-content-center"
                                                style="width: 44px; height: 44px;">
                                                <i class="bi bi-calendar-check"></i>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-md-6 col-xl-3">
                                <div class="card border-0 shadow-sm rounded-4 h-100">
                                    <div class="card-body">
                                        <div class="d-flex align-items-start justify-content-between">
                                            <div>
                                                <div class="text-muted small">Response rate</div>
                                                <div class="fs-3 fw-bold"><%= typeof stats !== 'undefined' ? stats.responseRate : 0 %>%</div>
                                                <div class="text-muted small">Overall</div>
                                            </div>
                                            <div class="bg-warning bg-opacity-10 text-warning rounded-3 d-inline-flex align-items-center justify-content-center"
                                                style="width: 44px; height: 44px;">
                                                <i class="bi bi-graph-up"></i>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-12 col-xl-8">
                                <div class="card border-0 shadow-sm rounded-4 h-100">
                                    <div class="card-body">
                                        <div class="d-flex align-items-center justify-content-between gap-2 mb-3">
                                            <div>
                                                <div class="fw-bold">Recent project posts</div>
                                                <div class="text-muted small">Latest activity on your posts</div>
                                            </div>
                                            <a class="text-decoration-none fw-semibold" href="#">View all</a>
                                        </div>

                                        <div class="table-responsive">
                                            <table class="table align-middle mb-0">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Project</th>
                                                        <th class="text-center">Applicants</th>
                                                        <th class="d-none d-md-table-cell">Status</th>
                                                        <th class="text-end">Action</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% if (typeof recentJobs !== 'undefined' && recentJobs.length > 0) { %>
                                                        <% recentJobs.forEach(job => { %>
                                                            <tr>
                                                                <td>
                                                                    <div class="fw-semibold"><%= job.title %></div>
                                                                    <div class="text-muted small"><i class="bi bi-clock me-1"></i><%= new Date(job.created_at).toLocaleDateString() %></div>
                                                                </td>
                                                                <td class="text-center"><span class="badge bg-primary-subtle text-primary"><%= job.applicant_count %></span></td>
                                                                <td class="d-none d-md-table-cell">
                                                                    <% if (job.status === 'open') { %>
                                                                        <span class="badge bg-success-subtle text-success text-capitalize"><%= job.status %></span>
                                                                    <% } else if (job.status === 'closed') { %>
                                                                        <span class="badge bg-secondary-subtle text-secondary text-capitalize"><%= job.status %></span>
                                                                    <% } else { %>
                                                                        <span class="badge bg-warning-subtle text-warning text-capitalize"><%= job.status %></span>
                                                                    <% } %>
                                                                </td>
                                                                <td class="text-end">
                                                                    <a href="/employer/browse-jobs/jobs/<%= job.slug %>" class="btn btn-sm btn-outline-secondary">
                                                                        <i class="bi bi-eye"></i><span class="d-none d-md-inline ms-1">View</span>
                                                                    </a>
                                                                </td>
                                                            </tr>
                                                        <% }); %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="4" class="text-center text-muted py-4">No recent projects found.</td>
                                                        </tr>
                                                    <% } %>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-xl-4">
                                <div class="card border-0 shadow-sm rounded-4 h-100">
                                    <div class="card-body">
                                        <div class="d-flex align-items-center justify-content-between mb-3">
                                            <div>
                                                <div class="fw-bold">Quick actions</div>
                                                <div class="text-muted small">Common tasks</div>
                                            </div>
                                            <i class="bi bi-grid text-muted"></i>
                                        </div>

                                        <div class="d-grid gap-2">
                                            <a href="/employer/jobs/create" class="btn btn-primary fw-semibold">
                                                <i class="bi bi-plus-lg me-2"></i>Create new post
                                            </a>
                                            <a href="/employer/applications" class="btn btn-outline-primary">
                                                <i class="bi bi-inbox me-2"></i>Review applicants
                                            </a>
                                            <a href="/employer/messages" class="btn btn-outline-secondary">
                                                <i class="bi bi-chat-dots me-2"></i>Messages
                                            </a>
                                        </div>

                                        <hr class="my-4">

                                        <div>
                                            <div class="fw-bold mb-2">Recent applicants</div>
                                            <div class="vstack gap-2">
                                                <div class="d-flex align-items-center justify-content-between">
                                                    <div class="d-flex align-items-center gap-2">
                                                        <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-inline-flex align-items-center justify-content-center"
                                                            style="width: 34px; height: 34px;">
                                                            <i class="bi bi-person"></i>
                                                        </div>
                                                        <div>
                                                            <div class="small fw-semibold">John Doe</div>
                                                            <div class="text-muted" style="font-size: 0.8rem;">Senior
                                                                React
                                                                Developer</div>
                                                        </div>
                                                    </div>
                                                    <span class="badge bg-warning-subtle text-warning">Pending</span>
                                                </div>
                                                <div class="d-flex align-items-center justify-content-between">
                                                    <div class="d-flex align-items-center gap-2">
                                                        <div class="rounded-circle bg-success bg-opacity-10 text-success d-inline-flex align-items-center justify-content-center"
                                                            style="width: 34px; height: 34px;">
                                                            <i class="bi bi-person"></i>
                                                        </div>
                                                        <div>
                                                            <div class="small fw-semibold">Jane Smith</div>
                                                            <div class="text-muted" style="font-size: 0.8rem;">UI/UX
                                                                Designer</div>
                                                        </div>
                                                    </div>
                                                    <span class="badge bg-success-subtle text-success">Reviewed</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>
            </div>
        </main>

        <%- include('../../public/footer') %>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>