<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vamper - Manage Jobs</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <%- include('../../public/header') %>

        <main class="container-fluid py-3 py-md-4">
            <div class="row">
                <%- include('./layouts/menu') %>

                    <section class="col-md-9 ms-sm-auto col-lg-10 px-2 px-md-4">
                        <% if (success_msg && success_msg.length> 0) { %>
                            <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
                                <i class="bi bi-check-circle-fill me-2"></i>
                                <%= success_msg %>
                                    <button type="button" class="btn-close" data-bs-dismiss="alert"
                                        aria-label="Close"></button>
                            </div>
                            <% } %>
                                <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between gap-3 pt-3 pb-2 mb-4 border-bottom">
                                    <h1 class="h2 mb-0 fw-bold">Manage Jobs</h1>
                                    <div class="d-flex gap-2">
                                        <button type="button" class="btn btn-outline-secondary"><i class="bi bi-download me-2"></i>Export</button>
                                        <a href="/employer/jobs/create" class="btn btn-primary fw-semibold"><i class="bi bi-plus-lg me-2"></i>Post New Job</a>
                                    </div>
                                </div>

                                <!-- Stats Cards -->
                                <div class="row g-3 mb-4">
                                    <div class="col-12 col-md-4">
                                        <div class="card border-0 shadow-sm rounded-4 h-100">
                                            <div class="card-body text-center p-4">
                                                <div class="text-muted mb-2">Active Jobs</div>
                                                <div class="display-5 fw-bold text-primary"><%= typeof stats !== 'undefined' ? stats.activeJobs : 0 %></div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <div class="card border-0 shadow-sm rounded-4 h-100">
                                            <div class="card-body text-center p-4">
                                                <div class="text-muted mb-2">Total Applicants</div>
                                                <div class="display-5 fw-bold text-success"><%= typeof stats !== 'undefined' ? stats.totalApplicants : 0 %></div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <div class="card border-0 shadow-sm rounded-4 h-100">
                                            <div class="card-body text-center p-4">
                                                <div class="text-muted mb-2">Views This Week</div>
                                                <div class="display-5 fw-bold text-info"><%= typeof stats !== 'undefined' ? stats.viewsThisWeek : 0 %></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Jobs List -->
                                <div class="alert alert-warning alert-dismissible fade show mb-4" role="alert">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                    <strong>Security Notice:</strong> Please be cautious with information provided by users. We are not responsible for any transactions or agreements made outside our platform!
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                                <div class="card border-0 shadow-sm rounded-4">
                                    <div class="card-header bg-white border-bottom-0 py-3">
                                        <h5 class="mb-0 fw-bold">Job Listings</h5>
                                    </div>
                                    <div class="card-body p-0">
                                        <% if (typeof jobs !== 'undefined' && jobs.length > 0) { %>
                                            <div class="row g-3 p-3">
                                                <% jobs.forEach(function(job) { %>
                                                    <div class="col-12 col-md-6 col-xl-4">
                                                        <div class="card job-card h-100 border rounded-4 shadow-sm" style="transition: transform 160ms ease, box-shadow 160ms ease;">
                                                            <div class="card-body p-3 p-lg-4">
                                                                <div class="d-flex align-items-start justify-content-between gap-2 mb-3">
                                                                    <div class="d-flex align-items-center gap-2">
                                                                        <div class="job-thumb" style="width: 56px; height: 56px; border-radius: 14px; overflow: hidden; border: 1px solid rgba(15, 23, 42, 0.08); background: #fff;">
                                                                            <% if (job.thumbnail_url) { %>
                                                                                <img src="<%= job.thumbnail_url %>" alt="<%= job.title %>" style="width: 100%; height: 100%; object-fit: cover; display: block;">
                                                                            <% } else { %>
                                                                                <div class="w-100 h-100 d-flex align-items-center justify-content-center">
                                                                                    <i class="bi bi-briefcase text-secondary fs-4"></i>
                                                                                </div>
                                                                            <% } %>
                                                                        </div>
                                                                        <div>
                                                                            <span class="badge <%= job.status === 'open' ? 'bg-success-subtle text-success' : (job.status === 'closed' ? 'bg-secondary-subtle text-secondary' : 'bg-warning-subtle text-warning text-dark') %> rounded-pill text-capitalize"><%= job.status %></span>
                                                                        </div>
                                                                    </div>
                                                                    <span class="badge <%= job.job_type === 'hourly' ? 'bg-warning-subtle text-warning text-dark' : 'bg-success-subtle text-success' %>"><%= job.job_type === 'hourly' ? 'Hourly' : 'Project' %></span>
                                                                </div>

                                                                <div class="fw-bold text-dark job-title mb-2" style="display: -webkit-box; line-clamp: 2; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"><%= job.title %></div>

                                                                <div class="d-flex align-items-center justify-content-between mb-3">
                                                                    <div class="text-muted small d-flex align-items-center gap-2">
                                                                        <i class="bi bi-clock"></i>
                                                                        <span><%= new Date(job.created_at).toLocaleDateString() %></span>
                                                                    </div>
                                                                    <div class="text-muted small d-flex flex-column align-items-end">
                                                                        <span><i class="bi bi-people me-1"></i> Applicants: <%= job.applicant_count || 0 %></span>
                                                                        <span><i class="bi bi-bar-chart me-1"></i> Views: <%= fmtViews(job.total_views) %></span>
                                                                    </div>
                                                                </div>
                                                                <hr class="my-3">
                                                                <div class="d-flex justify-content-between align-items-center">
                                                                    <a href="/employer/browse-jobs/jobs/<%= job.slug %>" class="btn btn-sm btn-outline-secondary" title="View Job"><i class="bi bi-eye"></i> View</a>
                                                                    <div>
                                                                        <a href="/employer/jobs/edit/<%= job.id %>" class="btn btn-sm btn-outline-primary me-1" title="Edit"><i class="bi bi-pencil"></i></a>
                                                                        <form action="/employer/jobs/delete/<%= job.id %>" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this job? This action cannot be undone.');">
                                                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
                                                                        </form>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                <% }); %>
                                            </div>
                                        <% } else { %>
                                            <div class="text-center py-5">
                                                <div class="text-muted mb-3">No jobs posted yet.</div>
                                                <a href="/employer/jobs/create" class="btn btn-primary">Post a Job</a>
                                            </div>
                                        <% } %>
                                    </div>
                                    <div class="card-footer bg-white border-top-0 py-3">
                                        <% if (typeof totalPages !=='undefined' && totalPages> 1) { %>
                                            <nav aria-label="Page navigation">
                                                <ul class="pagination pagination-sm justify-content-end mb-0">
                                                    <!-- Previous Button -->
                                                    <li class="page-item <%= currentPage == 1 ? 'disabled' : '' %>">
                                                        <a class="page-link"
                                                            href="/employer/jobs?page=<%= currentPage - 1 %>">Previous</a>
                                                    </li>

                                                    <!-- Page Numbers -->
                                                    <% for(let i=1; i <=totalPages; i++) { %>
                                                        <li class="page-item <%= currentPage == i ? 'active' : '' %>">
                                                            <a class="page-link" href="/employer/jobs?page=<%= i %>">
                                                                <%= i %>
                                                            </a>
                                                        </li>
                                                        <% } %>

                                                            <!-- Next Button -->
                                                            <li
                                                                class="page-item <%= currentPage == totalPages ? 'disabled' : '' %>">
                                                                <a class="page-link"
                                                                    href="/employer/jobs?page=<%= currentPage + 1 %>">Next</a>
                                                            </li>
                                                </ul>
                                            </nav>
                                            <% } %>
                                    </div>
                                </div>
                    </section>
            </div>
        </main>

        <%- include('../../public/footer') %>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>