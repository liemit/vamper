<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vamper - Company Profile</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <%- include('../../public/header') %>

        <main class="container-fluid py-3 py-md-4">
            <div class="row">
                <%- include('./layouts/menu') %>

                    <section class="col-md-9 ms-sm-auto col-lg-10 px-2 px-md-4 employer-company-profile">
                                    <% 
                                   const errorMsg = (typeof error_msg !== 'undefined' && error_msg && error_msg.length > 0) ? error_msg : (typeof success_msg !== 'undefined' && success_msg && success_msg.length > 0 ? '' : req.flash('error_msg'));
                                   const successMsg = (typeof success_msg !== 'undefined' && success_msg && success_msg.length > 0) ? success_msg : req.flash('success_msg');
                                %>

                                <% if (errorMsg && errorMsg.length > 0) { %>
                                    <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                        <%= errorMsg %>
                                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                    </div>
                                <% } %>
                                <% if (successMsg && successMsg.length > 0) { %>
                                    <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
                                        <i class="bi bi-check-circle-fill me-2"></i>
                                        <%= successMsg %>
                                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                    </div>
                                <% } %>

                        <div class="d-flex flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                            <h1 class="h2">Company Profile</h1>
                        </div>

                        <% const p = (typeof profile !== 'undefined' && profile) ? profile : {}; %>

                        <ul class="nav nav-tabs mb-3" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active" id="tab-company-profile" data-bs-toggle="tab" data-bs-target="#pane-company-profile" type="button" role="tab" aria-controls="pane-company-profile" aria-selected="true">
                                    <i class="bi bi-building me-1"></i>Company Profile
                                </button>
                            </li>
                            <!-- <li class="nav-item" role="presentation">
                                <button class="nav-link" id="tab-proposals" data-bs-toggle="tab" data-bs-target="#pane-proposals" type="button" role="tab" aria-controls="pane-proposals" aria-selected="false">
                                    <i class="bi bi-inbox me-1"></i>Proposals
                                </button>
                            </li> -->
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="tab-plan" data-bs-toggle="tab" data-bs-target="#pane-plan" type="button" role="tab" aria-controls="pane-plan" aria-selected="false">
                                    <i class="bi bi-box me-1"></i>Plan
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="tab-settings" data-bs-toggle="tab" data-bs-target="#pane-settings" type="button" role="tab" aria-controls="pane-settings" aria-selected="false">
                                    <i class="bi bi-gear me-1"></i>Settings
                                </button>
                            </li>
                        </ul>

                        <form id="mainProfileForm" method="POST" action="/employer/company-profile?_csrf=<%= csrfToken %>" enctype="multipart/form-data" class="card border-0 shadow-sm col-12 bg-transparent p-0">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <input type="hidden" name="existing_logo_url" value="<%= p.logo_url ? p.logo_url : '' %>">

                        <div class="tab-content">
                            <div class="tab-pane fade show active" id="pane-company-profile" role="tabpanel" aria-labelledby="tab-company-profile" tabindex="0">
                            <div class="card border-0 shadow-sm rounded-4">

                            <div class="card-body p-4">
                                <div class="d-flex flex-column flex-lg-row align-items-start gap-3 mb-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="user-avatar d-inline-flex align-items-center justify-content-center" style="width: 64px; height: 64px; min-width: 64px; min-height: 64px; border-radius: 8px; background-color: #f8f9fa; border: 1px solid #dee2e6; overflow: hidden;" id="logo-preview-container">
                                            <% if (p.logo_url) { %>
                                                <img src="<%= p.logo_url %>" alt="Company logo" style="width: 100%; height: 100%; object-fit: cover; display: block;" onerror="this.style.display='none'">
                                            <% } else { %>
                                                <i class="bi bi-building text-muted fs-2"></i>
                                            <% } %>
                                        </div>
    
                                        <div>
                                            <div class="fw-bold fs-5"><%= p.company_name ? p.company_name : 'Your Company' %></div>
                                            <div class="text-muted small"><%= p.website ? p.website : 'Add your company website' %></div>
                                        </div>
                                    </div>
    
                                    <div class="flex-grow-1 ms-lg-auto" style="max-width: 400px;">
                                        <label class="form-label">Company Logo (Optional)</label>
                                        <input class="form-control" type="file" id="logo" name="logo" accept="image/*">
                                        <div class="form-text">Recommended size: 400x400px. Max size: 2MB.</div>
                                    </div>
                                </div>

                                <hr class="my-4 text-secondary-subtle">

                                <div class="row g-3">
                                    <div class="col-12 col-lg-6">
                                        <label class="form-label">Company name</label>
                                        <input type="text" name="company_name" class="form-control" value="<%= p.company_name ? p.company_name : '' %>">
                                    </div>

                                    <div class="col-12 col-lg-6">
                                        <label class="form-label">Website</label>
                                        <input type="url" name="website" class="form-control" placeholder="https://" value="<%= p.website ? p.website : '' %>">
                                    </div>

                                    <div class="col-12 col-lg-6">
                                        <label class="form-label">Tax code</label>
                                        <input type="text" name="tax_code" class="form-control" value="<%= p.tax_code ? p.tax_code : '' %>">
                                    </div>

                                    <div class="col-12 col-lg-6">
                                        <label class="form-label">City</label>
                                        <input type="text" name="city" class="form-control" value="<%= p.city ? p.city : '' %>">
                                    </div>

                                    <div class="col-12">
                                        <label class="form-label">Address</label>
                                        <input type="text" name="address" class="form-control" value="<%= p.address ? p.address : '' %>">
                                    </div>

                                    <div class="col-12">
                                        <label class="form-label">Description</label>
                                        <textarea name="description" class="d-none" id="company-description"
                                            placeholder="Describe your company, services, and strengths..."><%= p.description ? p.description : '' %></textarea>
                                        <div id="company-description-editor" class="vamper-quill-editor"></div>
                                    </div>
                                </div>
                                </div>
                            </div>

                            </div>

                            <div class="tab-pane fade" id="pane-plan" role="tabpanel" aria-labelledby="tab-plan" tabindex="0">
                                <% const ps = (typeof planStatus !== 'undefined' && planStatus) ? planStatus : {}; %>
                                <div class="card border-0 shadow-sm rounded-4">
                                    <div class="card-body p-4">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <div class="h5 mb-0">Current Plan</div>
                                            <span class="badge <%= ps.code ? 'bg-primary' : 'bg-secondary' %>"><%= ps.name ? ps.name : 'None' %></span>
                                        </div>
                                        <div class="text-muted small mb-3">
                                            <span>Start (UTC): <%= ps.start_utc ? ps.start_utc : '—' %></span>
                                            <span class="ms-3">End (UTC): <%= ps.end_utc ? ps.end_utc : '—' %></span>
                                            <span class="ms-3">Price: <%= (ps.price_monthly !== null && ps.price_monthly !== undefined) ? ps.price_monthly : '—' %>/<%= ps.currency ? 'month · ' + ps.currency : 'month' %></span>
                                        </div>
                                        <div class="row g-3">
                                            <div class="col-12 col-md-6">
                                                <div class="border rounded-3 p-3 h-100">
                                                    <div class="fw-semibold mb-2">Limits</div>
                                                    <% const lim = ps.limits || {}; %>
                                                    <div class="text-muted small">Image: per-file <%= lim.image && lim.image.max_file_mb ? lim.image.max_file_mb : '—' %>MB · monthly <%= lim.image && lim.image.monthly_quota_mb ? lim.image.monthly_quota_mb : '—' %>MB</div>
                                                    <div class="text-muted small">Video: per-file <%= lim.video && lim.video.max_file_mb ? lim.video.max_file_mb : '—' %>MB · monthly <%= lim.video && lim.video.monthly_quota_mb ? lim.video.monthly_quota_mb : '—' %>MB</div>
                                                    <div class="text-muted small">File: per-file <%= lim.file && lim.file.max_file_mb ? lim.file.max_file_mb : '—' %>MB · monthly <%= lim.file && lim.file.monthly_quota_mb ? lim.file.monthly_quota_mb : '—' %>MB</div>
                                                </div>
                                            </div>
                                            <div class="col-12 col-md-6">
                                                <div class="border rounded-3 p-3 h-100">
                                                    <div class="fw-semibold mb-2">This Month Usage (UTC)</div>
                                                    <% const us = ps.usage || {}; %>
                                                    <div class="text-muted small">Period: <%= us.period_key ? us.period_key : '—' %></div>
                                                    <div class="text-muted small">Image: <%= us.image_bytes !== undefined ? Math.round(us.image_bytes/1024/1024) : 0 %>MB</div>
                                                    <div class="text-muted small">Video: <%= us.video_bytes !== undefined ? Math.round(us.video_bytes/1024/1024) : 0 %>MB</div>
                                                    <div class="text-muted small">File: <%= us.file_bytes !== undefined ? Math.round(us.file_bytes/1024/1024) : 0 %>MB</div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="mt-4">
                                            <div class="h6 mb-3">Available Plans</div>
                                            <div id="planCatalogEmployer" class="vstack gap-3"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="tab-pane fade" id="pane-proposals" role="tabpanel" aria-labelledby="tab-proposals" tabindex="0">
                                <% const proposalsList = (typeof proposals !== 'undefined' && Array.isArray(proposals)) ? proposals : []; %>
                                <div class="card border-0 shadow-sm rounded-4">
                                    <div class="card-header bg-transparent border-0 px-4 pt-4 pb-0 d-flex align-items-center justify-content-between flex-wrap gap-2">
                                        <div>
                                            <div class="h5 mb-1">Applications</div>
                                            <div class="text-muted small">Review freelancers who applied to your jobs</div>
                                        </div>
                                        <div class="text-muted small">
                                            Total: <span class="fw-semibold text-dark"><%= proposalsList.length %></span>
                                        </div>
                                    </div>

                                    <div class="card-body p-0">
                                        <% if (!proposalsList.length) { %>
                                            <div class="p-4">
                                                <div class="d-flex align-items-start gap-3">
                                                    <div class="rounded-circle bg-light d-inline-flex align-items-center justify-content-center" style="width: 44px; height: 44px;">
                                                        <i class="bi bi-inbox text-secondary"></i>
                                                    </div>
                                                    <div>
                                                        <div class="fw-bold">No proposals yet</div>
                                                        <div class="text-muted">When freelancers apply to your jobs, they will appear here.</div>
                                                    </div>
                                                </div>
                                            </div>
                                        <% } else { %>
                                            <div class="table-responsive">
                                                <table class="table align-middle mb-0">
                                                    <thead class="table-light">
                                                        <tr>
                                                            <th class="ps-4">Job</th>
                                                            <th>Freelancer</th>
                                                            <th class="text-end">Bid</th>
                                                            <th>Status</th>
                                                            <th>Applied</th>
                                                            <th class="text-end pe-4">Actions</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <% proposalsList.forEach(function(pr) { %>
                                                            <% const status = pr && pr.status ? String(pr.status) : 'pending'; %>
                                                            <% const badgeClass = status === 'accepted' ? 'bg-success-subtle text-success' : (status === 'rejected' ? 'bg-danger-subtle text-danger' : (status === 'withdrawn' ? 'bg-secondary-subtle text-secondary' : 'bg-warning-subtle text-warning text-dark')); %>
                                                            <tr>
                                                                <td class="ps-4" style="max-width: 340px;">
                                                                    <div class="fw-semibold text-truncate"><%= pr.job_title ? pr.job_title : ('Job #' + (pr.job_id || '')) %></div>
                                                                    <div class="text-muted small text-truncate"><%= pr.job_slug ? pr.job_slug : '' %></div>
                                                                </td>
                                                                <td style="max-width: 240px;">
                                                                    <div class="fw-semibold text-truncate"><%= pr.freelancer_name ? pr.freelancer_name : (pr.freelancer_email ? pr.freelancer_email : ('User #' + (pr.freelancer_id || ''))) %></div>
                                                                    <div class="text-muted small text-truncate"><%= pr.freelancer_headline ? pr.freelancer_headline : '' %></div>
                                                                </td>
                                                                <td class="text-end"><%= (pr.bid_amount !== undefined && pr.bid_amount !== null) ? ('$' + Number(pr.bid_amount).toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 2 })) : '-' %></td>
                                                                <td><span class="badge <%= badgeClass %>"><%= status %></span></td>
                                                                <td><%= pr.created_at ? new Date(pr.created_at).toLocaleDateString() : '' %></td>
                                                                <td class="text-end pe-4">
                                                                    <div class="btn-group btn-group-sm" role="group">
                                                                        <a class="btn btn-outline-secondary" href="#">View</a>
                                                                        <button type="button" class="btn btn-outline-success" disabled>Accept</button>
                                                                        <button type="button" class="btn btn-outline-danger" disabled>Reject</button>
                                                                    </div>
                                                                </td>
                                                            </tr>
                                                        <% }); %>
                                                    </tbody>
                                                </table>
                                            </div>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="pane-settings" role="tabpanel" aria-labelledby="tab-settings" tabindex="0">
                                <div class="card border-0 shadow-sm rounded-4">
                                    <div class="card-body p-4">
                                        <div class="row g-4">
                                            <div class="col-12 col-lg-6">
                                                <h6 class="fw-bold mb-3">Change Password</h6>
                                                <div id="changePasswordAlert" class="alert d-none small py-2" role="alert"></div>
                                                <div id="changePasswordWrapper">
                                                    <div class="mb-3">
                                                        <label class="form-label">Current Password</label>
                                                        <input type="password" name="current_password" class="form-control" placeholder="Enter current password">
                                                    </div>
                                                    <div class="mb-3">
                                                        <label class="form-label">New Password</label>
                                                        <input type="password" name="new_password" class="form-control" placeholder="Enter new password">
                                                    </div>
                                                    <div class="mb-3">
                                                        <label class="form-label">Confirm New Password</label>
                                                        <input type="password" name="confirm_new_password" class="form-control" placeholder="Confirm new password">
                                                    </div>
                                                </div>
                                            </div>
                                            
                                            <div class="col-12 col-lg-6">
                                                <h6 class="fw-bold mb-3">Active Sessions</h6>
                                                <div class="card border-0 bg-light rounded-4">
                                                    <div class="card-body" id="sessionsContainerEmployer">
                                                        <div class="d-flex align-items-center justify-content-center py-3">
                                                            <div class="spinner-border text-primary spinner-border-sm me-2" role="status"></div>
                                                            <span class="small text-muted">Loading sessions...</span>
                                                        </div>
                                                    </div>
                                                </div>
                                                <script>
                                                   document.addEventListener('DOMContentLoaded', async function() {
                                                       const container = document.getElementById('sessionsContainerEmployer');
                                                       if(!container) return;
                                                       try {
                                                           const res = await fetch('/employer/sessions');
                                                           const data = await res.json();
                                                           if(data.ok && data.sessions) {
                                                               container.innerHTML = '';
                                                               const PAGE_SIZE = 3;
                                                               const sessions = data.sessions;
                                                               let shown = 0;

                                                               function renderSessionEl(s) {
                                                                   const isCurrent = s.is_current;
                                                                   const dev = s.device;
                                                                   const loginTime = dev.login_time ? new Date(dev.login_time).toLocaleString() : 'Unknown time';
                                                                   const el = document.createElement('div');
                                                                   el.className = 'd-flex align-items-start gap-3 mb-3';
                                                                   el.innerHTML = `
                                                                       <i class="bi bi-display fs-4 ${isCurrent ? 'text-primary' : 'text-secondary'}"></i>
                                                                       <div class="flex-grow-1">
                                                                           <div class="fw-bold d-flex justify-content-between align-items-center">
                                                                               <span>${isCurrent ? 'Current Device' : 'Other Device'}</span>
                                                                           </div>
                                                                           <div class="text-muted small">${dev.os_browser} &bull; ${dev.ip || 'Unknown IP'}</div>
                                                                           <div class="text-muted small" style="font-size: 0.75rem;">Login: ${loginTime}</div>
                                                                           ${isCurrent ? 
                                                                               '<div class="text-success small fw-semibold mt-1"><i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i>Active now</div>' : 
                                                                               `<button type="button" class="btn btn-sm btn-outline-danger py-0 px-2 mt-2 revoke-btn" style="font-size:0.75rem" data-session-id="${s.id}">Log out</button>`}
                                                                       </div>
                                                                   `;
                                                                   if (!isCurrent) {
                                                                       const btn = el.querySelector('.revoke-btn');
                                                                       if (btn) btn.addEventListener('click', function() {
                                                                           window.revokeSessionEmployer(this.dataset.sessionId);
                                                                       });
                                                                   }
                                                                   return el;
                                                               }

                                                               function showMore() {
                                                                   const end = Math.min(shown + PAGE_SIZE, sessions.length);
                                                                   for (; shown < end; shown++) {
                                                                       container.insertBefore(renderSessionEl(sessions[shown]), loadMoreBtn);
                                                                   }
                                                                   const remaining = sessions.length - shown;
                                                                   if (remaining <= 0) {
                                                                       loadMoreBtn.style.display = 'none';
                                                                   } else {
                                                                       loadMoreBtn.textContent = `Load more (${remaining} more)`;
                                                                   }
                                                               }

                                                               const loadMoreBtn = document.createElement('button');
                                                               loadMoreBtn.type = 'button';
                                                               loadMoreBtn.className = 'btn btn-sm btn-outline-secondary w-100 mb-2';
                                                               loadMoreBtn.style.display = 'none';
                                                               loadMoreBtn.onclick = showMore;
                                                               container.appendChild(loadMoreBtn);

                                                               showMore();

                                                               const info = document.createElement('div');
                                                               info.innerHTML = '<hr class="my-2 border-secondary opacity-25"><p class="small text-muted mb-0 mt-2">Manage all active sessions across your devices.</p>';
                                                               container.appendChild(info);
                                                           } else {
                                                               container.innerHTML = '<div class="text-danger small">Failed to load sessions</div>';
                                                           }
                                                       } catch(e) {
                                                           container.innerHTML = '<div class="text-danger small">Error loading sessions</div>';
                                                       }
                                                   });

                                                   window.revokeSessionEmployer = async function(id) {
                                                       const btn = document.querySelector(`.revoke-btn[data-session-id="${id}"]`);
                                                       if (btn) { btn.disabled = true; btn.textContent = 'Logging out...'; }
                                                       try {
                                                           const csrfToken = window.__CSRF__ || '';
                                                           const res = await fetch('/employer/sessions/revoke', {
                                                               method: 'POST',
                                                               headers: {
                                                                   'Content-Type': 'application/json',
                                                                   ...(csrfToken ? {'CSRF-Token': csrfToken, 'X-CSRF-Token': csrfToken} : {})
                                                               },
                                                               body: JSON.stringify({session_id: id, _csrf: csrfToken})
                                                           });
                                                           const data = await res.json();
                                                           if (data.ok) {
                                                               const card = btn ? btn.closest('.d-flex.align-items-start') : null;
                                                               if (card) card.remove();
                                                               showSessionToastEmployer('Device has been logged out successfully.', 'success');
                                                           } else {
                                                               if (btn) { btn.disabled = false; btn.textContent = 'Log out'; }
                                                               showSessionToastEmployer(data.error || 'Failed to log out device.', 'danger');
                                                           }
                                                       } catch(e) {
                                                           if (btn) { btn.disabled = false; btn.textContent = 'Log out'; }
                                                           showSessionToastEmployer('Network error. Please try again.', 'danger');
                                                       }
                                                   }

                                                   function showSessionToastEmployer(message, type) {
                                                       const container = document.getElementById('sessionsContainerEmployer');
                                                       const toast = document.createElement('div');
                                                       toast.className = `alert alert-${type} alert-dismissible fade show mt-2 py-2 px-3`;
                                                       toast.style.fontSize = '0.85rem';
                                                       toast.innerHTML = `<i class="bi bi-${type === 'success' ? 'check-circle' : 'exclamation-triangle'} me-2"></i>${message}<button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>`;
                                                       if (container) container.prepend(toast);
                                                       setTimeout(() => { if (toast.parentNode) toast.remove(); }, 4000);
                                                   }
                                                </script>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer bg-transparent border-0 px-0 pt-3 pb-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save me-1"></i>Save changes
                            </button>
                        </div>
                    </form>
                    </section>
            </div>
        </main>
        <%- include('../../public/footer') %>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
        <script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>
        <script src="/js/employer-company-profile.js"></script>
        <script>
            (function(){
                const wrap = document.getElementById('planCatalogEmployer');
                if(!wrap) return;
                async function loadPlans(){
                    try{
                        const res = await fetch('/employer/plans',{credentials:'same-origin'});
                        if(!res.ok) return;
                        const data = await res.json();
                        const list = Array.isArray(data.items)?data.items:[];
                        const activeCode = data.active_plan_code || null;
                        const byPlan = {};
                        list.forEach(it=>{
                            const key = it.code || it.id;
                            if(!byPlan[key]) byPlan[key] = { code: it.code, name: it.name, price: it.price_monthly, currency: it.currency, limits:{} };
                            if(it.kind) byPlan[key].limits[it.kind] = { max: it.max_file_mb, quota: it.monthly_quota_mb };
                        });
                        wrap.innerHTML='';
                        Object.values(byPlan).forEach(p=>{
                            const box = document.createElement('div');
                            box.className='border rounded-4 p-3';
                            const h = document.createElement('div');
                            h.className='fw-bold mb-1';
                            h.textContent = p.name;
                            const price = document.createElement('div');
                            price.className='text-muted small mb-2';
                            const priceStr = (p.price!==undefined && p.price!==null) ? (p.price + '/month') : '—';
                            price.innerHTML = 'Price: <i class="bi bi-gem text-primary"></i> ' + priceStr;
                            const d = document.createElement('div');
                            d.className='text-muted small mb-2';
                            ['image','video','file'].forEach(k=>{
                                const line=document.createElement('div');
                                const lim=p.limits[k]||{};
                                line.textContent=(k.charAt(0).toUpperCase()+k.slice(1))+': Per-file '+(lim.max||'—')+'MB · Monthly '+(lim.quota||'—')+'MB';
                                d.appendChild(line);
                            });
                            const btn = document.createElement('button');
                            const isActive = p.code && p.code===activeCode;
                            if(isActive){
                                btn.className='btn btn-outline-secondary btn-sm';
                                btn.textContent='Free';
                                btn.type='button';
                                btn.onclick=()=>{};
                            }else{
                                btn.className='btn btn-primary btn-sm';
                                btn.textContent='Activate';
                                btn.type='button';
                                btn.onclick=async ()=>{
                                    const csrf = document.querySelector('input[name=\"_csrf\"]');
                                    const params = new URLSearchParams();
                                    params.set('plan_code', p.code);
                                    if(csrf) params.set('_csrf', csrf.value);
                                    const r = await fetch('/employer/plans/activate',{
                                        method:'POST',
                                        headers: Object.assign({'Content-Type':'application/x-www-form-urlencoded'}, csrf?{'CSRF-Token':csrf.value,'X-CSRF-Token':csrf.value}:{}),
                                        body: params.toString(),
                                        credentials:'same-origin'
                                    });
                                    let ok=r.ok, msg='';
                                    try{ const j=await r.json(); ok=j&&j.ok; msg=j&&j.error?j.error:''; if(j&&j.new_balance!==undefined&&j.new_balance!==null){ const valEl=document.getElementById('headerBalanceValue'); if(valEl){ const num=Number(j.new_balance); valEl.textContent = Number.isFinite(num)? num.toLocaleString('en-US',{minimumFractionDigits:2, maximumFractionDigits:2}) : String(j.new_balance); }}}catch(_){}
                                    if(ok){ 
                                        alert('Plan activated successfully!');
                                        location.reload(); 
                                    } else { 
                                        alert(msg||'Activation failed'); 
                                    }
                                };
                            }
                            box.appendChild(h);
                            box.appendChild(price);
                            box.appendChild(d);
                            box.appendChild(btn);
                            wrap.appendChild(box);
                        });
                    }catch(_){}
                }
                loadPlans();
            })();

            // Auto-open tab based on URL hash
            document.addEventListener("DOMContentLoaded", function() {
                let hash = window.location.hash;
                if (hash) {
                    let tabElement = document.querySelector('button[data-bs-target="' + hash + '"]');
                    if (tabElement) {
                        let tab = new bootstrap.Tab(tabElement);
                        tab.show();
                    }
                }
            });
        </script>
</body>

</html>
