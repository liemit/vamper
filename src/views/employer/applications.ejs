<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vamper - Manage Applications</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <%- include('../../public/header') %>

    <% const list = (typeof proposals !== 'undefined' && Array.isArray(proposals)) ? proposals : []; %>

    <main class="container-fluid py-3 py-md-4">
        <div class="row">
            <%- include('./layouts/menu') %>

            <section class="col-md-9 ms-sm-auto col-lg-10 px-2 px-md-4">

                <div class="d-flex flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                    <h1 class="h2">Manage Applications</h1>
                    <div class="ms-auto text-muted small">Total: <%= list.length %></div>
                </div>

                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-header bg-transparent border-0 px-4 pt-4 pb-0 d-flex align-items-center justify-content-between flex-wrap gap-2">
                        <div>
                            <div class="h5 mb-1">Applications</div>
                            <div class="text-muted small">Manage all freelancer applications for your jobs</div>
                        </div>
                        <div class="text-muted small">
                            Total: <span class="fw-semibold text-dark"><%= list.length %></span>
                        </div>
                    </div>

                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Job</th>
                                        <th>Freelancer</th>
                                        <th class="text-end">Bid</th>
                                        <th>Status</th>
                                        <th>Applied</th>
                                        <th class="text-end pe-4">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (!list.length) { %>
                                        <tr>
                                            <td class="ps-4 pe-4 py-4 text-muted" colspan="7">No applications yet.</td>
                                        </tr>
                                    <% } %>
                                    <% list.forEach(function(pr) { %>
                                        <% const status = pr && pr.status ? String(pr.status) : 'pending'; %>
                                        <% const isDeposited = (typeof pr.is_deposited !== 'undefined') ? Number(pr.is_deposited) : 0; %>
                                        <% let badgeClass = status === 'accepted' ? 'bg-success-subtle text-success' : (status === 'rejected' ? 'bg-danger-subtle text-danger' : (status === 'withdrawn' ? 'bg-secondary-subtle text-secondary' : 'bg-warning-subtle text-warning text-dark')); %>
                                        <% 
                                            let displayStatus = status;
                                            if (isDeposited === 1) {
                                                displayStatus = 'deposited';
                                                badgeClass = 'bg-info-subtle text-info';
                                            } else if (isDeposited === 2) {
                                                displayStatus = 'paid';
                                                badgeClass = 'bg-primary-subtle text-primary';
                                            }
                                        %>
                                        <% const freelancerName = pr && (pr.freelancer_name || pr.freelancer_email) ? (pr.freelancer_name || pr.freelancer_email) : ('User #' + (pr.freelancer_id || '')); %>
                                        <tr>
                                            <td class="ps-4" style="max-width: 360px;">
                                                <div class="fw-semibold text-truncate"><%= pr.job_title ? pr.job_title : ('Job #' + (pr.job_id || '')) %></div>
                                            </td>
                                            <td style="max-width: 260px;">
                                                <div class="fw-semibold text-truncate">
                                                    <% if (pr.freelancer_id) { %>
                                                        <a href="/employer/applications/freelancers/<%= pr.freelancer_id %>" class="text-decoration-none me-2"><%= freelancerName %></a>
                                                        <a href="/employer/messages?to=<%= pr.freelancer_id %>&job=<%= pr.job_id %>" class="btn btn-primary btn-sm p-1 rounded-circle" title="Message" style="width: 24px; height: 24px; line-height: 1;">
                                                            <i class="bi bi-chat-dots-fill" style="font-size: 12px;"></i>
                                                        </a>
                                                    <% } else { %>
                                                        <%= freelancerName %>
                                                    <% } %>
                                                </div>
                                                <% if (pr.freelancer_headline) { %>
                                                    <div class="small text-muted text-truncate"><%= pr.freelancer_headline %></div>
                                                <% } %>
                                            </td>
                                            <td class="text-end"><%- (pr.bid_amount !== undefined && pr.bid_amount !== null) ? ('<i class="bi bi-gem text-primary"></i> ' + Number(pr.bid_amount).toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 2 })) : '' %></td>
                                            <td><span class="badge <%= badgeClass %>"><%= displayStatus %></span></td>
                                            <td><%= pr.created_at ? new Date(pr.created_at).toLocaleDateString() : '' %></td>
                                            <td class="text-end pe-4">
                                                <% if (isDeposited === 2) { %>
                                                    <button type="button" class="btn btn-sm btn-outline-success" disabled><i class="bi bi-check-all me-1"></i>Completed</button>
                                                <% } else if (isDeposited === 1) { %>
                                                    <a href="/employer/messages?to=<%= pr.freelancer_id %>&job=<%= pr.job_id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-chat-dots me-1"></i>Chat to Release</a>
                                                <% } else if (status === 'withdrawn') { %>
                                                    <button type="button" class="btn btn-sm btn-outline-secondary" disabled>Withdrawn</button>
                                                <% } else { %>
                                                    <form method="POST" action="/employer/applications/<%= pr.id %>/status?_csrf=<%= csrfToken %>" class="d-inline">
                                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                        <select name="status" class="form-select form-select-sm d-inline-block" style="width: auto;" onchange="this.form.submit()">
                                                            <option value="pending" <%= status === 'pending' ? 'selected' : '' %>>pending</option>
                                                            <option value="accepted" <%= status === 'accepted' ? 'selected' : '' %>>accepted</option>
                                                            <option value="rejected" <%= status === 'rejected' ? 'selected' : '' %>>rejected</option>
                                                        </select>
                                                    </form>
                                                <% } %>
                                                <% if (pr.job_type === 'hourly' && (status === 'accepted' || pr.is_deposited)) { %>
                                                    <a href="/employer/timesheets/<%= pr.id %>" class="btn btn-sm btn-outline-warning text-dark d-inline-block ms-1" style="width: auto;">
                                                        <i class="bi bi-clock me-1"></i>Timesheets
                                                    </a>
                                                <% } %>
                                            </td>
                                        </tr>
                                        
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

            </section>
        </div>
    </main>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
</body>

</html>
