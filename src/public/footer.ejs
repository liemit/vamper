<% if (typeof footerBanners !== 'undefined' && footerBanners.length) { %>
<footer class="bg-dark text-light py-5 mt-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-4">
                <h4 class="fw-bold text-white mb-3"><i class="bi bi-code-square me-2"></i> Vamper</h4>
                <p class="text-secondary"><%= (typeof t === 'function') ? t('footer.tagline', 'A leading platform connecting IT students with real job and project opportunities.') : 'A leading platform connecting IT students with real job and project opportunities.' %></p>
                <div class="d-flex gap-3 mt-3">
                    <a href="#" class="text-secondary fs-5"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="text-secondary fs-5"><i class="bi bi-linkedin"></i></a>
                    <a href="#" class="text-secondary fs-5"><i class="bi bi-github"></i></a>
                </div>
            </div>
            <div class="col-6 col-lg-2">
                <h6 class="text-white fw-bold mb-3">For Students</h6>
                <ul class="list-unstyled text-secondary">
                    <li class="mb-2"><a href="#" class="text-secondary text-decoration-none">Find Jobs</a></li>
                    <li class="mb-2"><a href="#" class="text-secondary text-decoration-none">Internships</a></li>
                    <li class="mb-2"><a href="#" class="text-secondary text-decoration-none">Build a CV</a></li>
                </ul>
            </div>
            <div class="col-6 col-lg-2">
                <h6 class="text-white fw-bold mb-3">For Employers</h6>
                <ul class="list-unstyled text-secondary">
                    <li class="mb-2"><a href="#" class="text-secondary text-decoration-none">Post a Job</a></li>
                    <li class="mb-2"><a href="#" class="text-secondary text-decoration-none">Find Candidates</a></li>
                    <li class="mb-2"><a href="#" class="text-secondary text-decoration-none">Pricing</a></li>
                </ul>
            </div>
            <div class="col-lg-4">
                <h6 class="text-white fw-bold mb-3">Subscribe</h6>
                <p class="text-secondary small"><%= (typeof t === 'function') ? t('footer.tagline2', 'Get the latest job updates delivered to your inbox.') : 'Get the latest job updates delivered to your inbox.' %></p>
                <form class="input-group">
                    <input type="email" class="form-control border-0" placeholder="Your email...">
                    <button class="btn btn-primary" type="button">Send</button>
                </form>
            </div>
        </div>
        <hr class="border-secondary my-4">
        <div class="d-flex flex-wrap justify-content-center align-items-center gap-3 mb-4">
            <% footerBanners.forEach(b => { %>
                <% if (b.ad_code) { %>
                    <%- b.ad_code %>
                <% } else if (b.image_url) { %>
                    <% if (b.link_url) { %>
                        <a href="<%= b.link_url %>" target="_blank" rel="noopener sponsored">
                            <img src="<%= b.image_url %>" alt="<%= b.title %>" style="height:80px;width:auto;max-width:200px;object-fit:cover;border-radius:6px;">
                        </a>
                    <% } else { %>
                        <img src="<%= b.image_url %>" alt="<%= b.title %>" style="height:80px;width:auto;max-width:200px;object-fit:cover;border-radius:6px;">
                    <% } %>
                <% } %>
            <% }); %>
        </div>
        <div class="text-center text-secondary small">
            &copy; 2024 Vamper. All rights reserved.
        </div>
    </div>
</footer>
<% } else { %>
<footer class="bg-dark text-light py-5 mt-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-4">
                <h4 class="fw-bold text-white mb-3"><i class="bi bi-code-square me-2"></i> Vamper</h4>
                <p class="text-secondary"><%= (typeof t === 'function') ? t('footer.tagline', 'A leading platform connecting IT students with real job and project opportunities.') : 'A leading platform connecting IT students with real job and project opportunities.' %></p>
                <div class="d-flex gap-3 mt-3">
                    <a href="#" class="text-secondary fs-5"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="text-secondary fs-5"><i class="bi bi-linkedin"></i></a>
                    <a href="#" class="text-secondary fs-5"><i class="bi bi-github"></i></a>
                </div>
            </div>
            <div class="col-6 col-lg-2">
                <h6 class="text-white fw-bold mb-3">For Students</h6>
                <ul class="list-unstyled text-secondary">
                    <li class="mb-2"><a href="#" class="text-secondary text-decoration-none">Find Jobs</a></li>
                    <li class="mb-2"><a href="#" class="text-secondary text-decoration-none">Internships</a></li>
                    <li class="mb-2"><a href="#" class="text-secondary text-decoration-none">Build a CV</a></li>
                </ul>
            </div>
            <div class="col-6 col-lg-2">
                <h6 class="text-white fw-bold mb-3">For Employers</h6>
                <ul class="list-unstyled text-secondary">
                    <li class="mb-2"><a href="#" class="text-secondary text-decoration-none">Post a Job</a></li>
                    <li class="mb-2"><a href="#" class="text-secondary text-decoration-none">Find Candidates</a></li>
                    <li class="mb-2"><a href="#" class="text-secondary text-decoration-none">Pricing</a></li>
                </ul>
            </div>
            <div class="col-lg-4">
                <h6 class="text-white fw-bold mb-3">Subscribe</h6>
                <p class="text-secondary small"><%= (typeof t === 'function') ? t('footer.tagline2', 'Get the latest job updates delivered to your inbox.') : 'Get the latest job updates delivered to your inbox.' %></p>
                <form class="input-group">
                    <input type="email" class="form-control border-0" placeholder="Your email...">
                    <button class="btn btn-primary" type="button">Send</button>
                </form>
            </div>
        </div>
        <hr class="border-secondary my-4">
        <div class="text-center text-secondary small">
            &copy; 2024 Vamper. All rights reserved.
        </div>
    </div>
</footer>
<% } %>
