<header class="shadow-sm bg-white sticky-top">
<script>window.__CSRF__ = '<%= csrfToken %>';window.__UPLOAD_BASE__ = '<%= uploadBaseUrl %>';</script>
    <nav class="navbar navbar-expand-lg navbar-light container py-3">
        <div class="d-flex w-100 justify-content-between align-items-center d-lg-none">
            <a class="navbar-brand d-flex align-items-center fw-bold text-primary fs-3" href="#">
                <i class="bi bi-code-square me-2"></i> Vamper
            </a>
            <div class="d-flex align-items-center gap-2">
