                    aria-controls="mobileNavOffcanvas" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
            </div>
        </div>

        <a class="navbar-brand d-none d-lg-flex align-items-center fw-bold text-primary fs-3" href="#">
            <i class="bi bi-code-square me-2"></i> Vamper
        </a>

        <div class="navbar-collapse d-none d-lg-block" id="navbarNav">
            <style>
                .dropdown-submenu {
                    position: relative;
                }

                .dropdown-submenu>.dropdown-menu {
                    top: 0;
                    left: 100%;
                    margin-top: -0.25rem;
                }

                @media (max-width: 991.98px) {
                    .dropdown-submenu>.dropdown-menu {
                        left: 0;
                        margin-left: 1rem;
                    }

                    header .navbar {
                        padding-top: 0.75rem;
                        padding-bottom: 0.75rem;
                    }

                    header .navbar-collapse {
                        margin-top: 0.75rem;
                    }

                    header .navbar-nav {
                        width: 100%;
                    }

                    header .navbar-nav .nav-item {
                        width: 100%;
                        margin-right: 0 !important;
                    }

                    header .navbar-nav .nav-link,
                    header .navbar-nav .dropdown-item,
                    header .navbar-nav .btn {
                        width: 100%;
                        text-align: left;
                    }

                    header .navbar-nav .nav-link {
                        padding-top: 0.65rem;
                        padding-bottom: 0.65rem;
                    }

                    header .navbar-nav .dropdown-menu {
                        width: 100%;
                        max-width: 100%;
                    }

                    header .navbar-nav .dropdown-submenu>.dropdown-menu {
                        margin-left: 0;
                        padding-left: 0.75rem;
                    }

                    header #notificationDropdown + .dropdown-menu,
                    header #notificationDropdown ~ .dropdown-menu {
                        width: min(92vw, 360px) !important;
                        max-height: min(60vh, 420px) !important;
                        overflow-y: auto;
                    }

                    header .offcanvas {
                        width: min(92vw, 420px);
                    }

                    header .offcanvas .nav-link,
                    header .offcanvas .btn {
                        padding-top: 0.65rem;
                        padding-bottom: 0.65rem;
                    }

                    header .offcanvas .dropdown-toggle {
                        display: flex;
                        align-items: center;
                        gap: 0.75rem;
                    }

                    header .offcanvas .dropdown-toggle::after {
                        margin-left: 0.5rem;
                    }

                    header .offcanvas .mobile-lang-code {
                        margin-left: auto;
                    }
                }
            </style>

            <% function renderNavItems(items, isSubmenu) { %>
                <% if (!items || items.length === 0) { %>
                    <% return; %>
                <% } %>
                <% items.forEach(function(it) { %>
                    <% const labelKeyMap = { 'home': 'nav.home', 'jobs': 'nav.jobs', 'how it works': 'nav.how_it_works', 'pricing': 'nav.pricing', 'contact': 'nav.contact', 'policy': 'nav.policy' }; %>
                    <% const rawLabel = (it && it.label !== undefined && it.label !== null) ? String(it.label) : ''; %>
                    <% const normalizedLabel = rawLabel.toLowerCase().trim(); %>
                    <% const labelKey = labelKeyMap[normalizedLabel]; %>
                    <% const displayLabel = (typeof t === 'function' && labelKey) ? t(labelKey, rawLabel) : rawLabel; %>
                    <% if (it.item_type === 'divider') { %>
                        <li><hr class="dropdown-divider"></li>
                    <% } else if (it.item_type === 'header') { %>
                        <li><h6 class="dropdown-header"><%= displayLabel %></h6></li>
                    <% } else if (it.children && it.children.length) { %>
                        <% if (isSubmenu) { %>
                            <li class="dropdown-submenu">
                                <a class="dropdown-item dropdown-toggle" href="#" data-bs-toggle="dropdown" aria-expanded="false">
                                    <% if (it.icon) { %><i class="bi <%= it.icon %> me-2"></i><% } %><%= displayLabel %>
                                </a>
                                <ul class="dropdown-menu">
                                    <% renderNavItems(it.children, true); %>
                                </ul>
                            </li>
                        <% } else { %>
                            <% const parentHref = it.url ? it.url : (it.route_name ? ('/' + it.route_name) : '#'); %>
                            <li class="nav-item dropdown me-3 d-flex align-items-center">
                                <a class="nav-link" href="<%= parentHref %>" target="<%= it.target || '_self' %>">
                                    <% if (it.icon) { %><i class="bi <%= it.icon %> me-1"></i><% } %><%= displayLabel %>
                                </a>
                                <button class="btn btn-link nav-link dropdown-toggle p-0 ms-1" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Toggle <%= displayLabel %> menu"></button>
                                <ul class="dropdown-menu">
                                    <% renderNavItems(it.children, true); %>
                                </ul>
                            </li>
                        <% } %>
                    <% } else { %>
                        <% const href = it.url ? it.url : (it.route_name ? ('/' + it.route_name) : '#'); %>
                        <% if (isSubmenu) { %>
                            <li>
                                <a class="dropdown-item" href="<%= href %>" target="<%= it.target || '_self' %>">
                                    <% if (it.icon) { %><i class="bi <%= it.icon %> me-2"></i><% } %><%= displayLabel %>
                                </a>
                            </li>
                        <% } else { %>
                            <li class="nav-item me-3">
                                <a class="nav-link" href="<%= href %>" target="<%= it.target || '_self' %>">
                                    <% if (it.icon) { %><i class="bi <%= it.icon %> me-1"></i><% } %><%= displayLabel %>
                                </a>
                            </li>
                        <% } %>
                    <% } %>
                <% }) %>
            <% } %>
